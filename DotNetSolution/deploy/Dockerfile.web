# Build context: DotNetSolution repository root (parent of this folder).
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY Directory.Build.props ./
COPY src ./src
RUN dotnet publish "src/NightmareV2.CommandCenter/NightmareV2.CommandCenter.csproj" \
    -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "NightmareV2.CommandCenter.dll"]
