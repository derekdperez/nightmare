@page "/ops"
@rendermode InteractiveServer
@using NightmareV2.CommandCenter.Models
@using static Microsoft.AspNetCore.Components.QuickGrid.SortDirection
@implements IDisposable
@inject HttpClient Http

<PageTitle>Operations · Nightmare v2</PageTitle>

<h1>Operations</h1>
<p class="muted">Live bus shows recent publishes. History includes publishes and consumes as each host records them. Toggles are checked at the start of each message: disabling <strong>Gatekeeper</strong> skips Raw admissions (no Indexed fan-out); disabling <strong>Spider</strong> / <strong>Enum</strong> / <strong>PortScan</strong> skips that worker’s step for that message (already-running HTTP on one message may still finish).</p>

<section class="panel">
    <h2>Data overview</h2>
    @if (_snapshot is null)
    {
        <p>Loading summary…</p>
    }
    else
    {
        <p class="muted">Counts are from Postgres (<code>stored_assets</code>, <code>recon_targets</code>, <code>bus_journal</code>). Rabbit queue depth requires <code>RabbitMq:ManagementUrl</code> (set in Docker compose).</p>
        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Total assets</div>
                <div class="stat-value">@_snapshot.Assets.TotalAssets</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Targets</div>
                <div class="stat-value">@_snapshot.Assets.TotalTargets</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Assets last 1h / 24h</div>
                <div class="stat-value">@_snapshot.Assets.AssetsLast1Hour / @_snapshot.Assets.AssetsLast24Hours</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Last asset discovered (UTC)</div>
                <div class="stat-value small">@(_snapshot.Assets.LastAssetDiscoveredUtc is { } la ? la.UtcDateTime.ToString("O") : "—")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Lifecycle: Discovered / Confirmed</div>
                <div class="stat-value">@_snapshot.Assets.AssetsInDiscoveredState / @_snapshot.Assets.AssetsConfirmedState</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Fetchable still “Discovered”</div>
                <div class="stat-value" title="URL-like kinds not yet confirmed (often waiting on Spider / queue)">@_snapshot.Assets.FetchableAssetsStillDiscovered</div>
            </div>
        </div>

        <h3 class="subhead">Bus journal traffic</h3>
        <div class="ops-qg-host short" tabindex="-1">
            <QuickGrid Items="BusTrafficRows" Class="nightmare-qg" Theme="default">
                <PropertyColumn Title="" Property="@(r => r.Label)" Sortable="true" />
                <PropertyColumn Title="Last 1 hour" Property="@(r => r.LastHour)" Sortable="true" />
                <PropertyColumn Title="Last 24 hours" Property="@(r => r.Last24Hours)" Sortable="true" />
            </QuickGrid>
        </div>

        <h3 class="subhead">Assets by root domain (top @(_snapshot.Assets.TopDomainsByAssetCount.Count))</h3>
        @if (_snapshot.Assets.TopDomainsByAssetCount.Count == 0)
        {
            <p class="muted">No assets yet.</p>
        }
        else
        {
            <div class="ops-qg-toolbar">
                <input type="search" class="ops-filter" placeholder="Filter by domain…" @bind="_filterTopDomains" @bind:event="oninput" />
            </div>
            <div class="ops-qg-host short" tabindex="-1">
                <QuickGrid Items="FilteredTopDomains" Class="nightmare-qg" Theme="default">
                    <TemplateColumn Title="Root domain" Context="r" SortBy="@SortTopDomainByRoot">
                        <code class="mono">@r.RootDomain</code>
                    </TemplateColumn>
                    <PropertyColumn Title="Assets" Property="@(r => r.Count)" Sortable="true" />
                </QuickGrid>
            </div>
        }

        <h3 class="subhead">Assets by <code>discovered_by</code></h3>
        <div class="ops-qg-toolbar">
            <input type="search" class="ops-filter" placeholder="Filter by pipeline key…" @bind="_filterDiscoveredBy" @bind:event="oninput" />
        </div>
        <div class="ops-qg-host short" tabindex="-1">
            <QuickGrid Items="FilteredDiscoveredBy" Class="nightmare-qg" Theme="default">
                <TemplateColumn Title="Discovered by" Context="r" SortBy="@SortDiscoveredByPipeline">
                    <code class="mono">@r.DiscoveredBy</code>
                </TemplateColumn>
                <PropertyColumn Title="Count" Property="@(r => r.Count)" Sortable="true" />
            </QuickGrid>
        </div>
    }
</section>

<section class="panel">
    <h2>Worker metrics</h2>
    @if (_snapshot is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <p class="muted">Per-worker bus consumes (journal) correlate to the MassTransit <strong>consumer</strong> CLR type recorded on each consume row. DB “assets attributed” counts rows by <code>discovered_by</code> (Spider uses <code>spider-worker</code>; HighValue workers mostly emit findings or child URLs, so those columns may stay low). Rabbit columns sum queues whose names match that worker (heuristic). <strong>Ready + unacked</strong> approximates messages waiting to be processed (incl. in-flight unacked).</p>
        <div class="ops-qg-toolbar">
            <input type="search" class="ops-filter" placeholder="Filter workers, queues, timestamps…" @bind="_filterWorkerMetrics" @bind:event="oninput" />
        </div>
        <div class="ops-qg-host mid" tabindex="-1">
            <QuickGrid Items="FilteredWorkerMetrics" Class="nightmare-qg" Theme="default">
                <PropertyColumn Title="Worker" Property="@(m => m.WorkerKey)" Sortable="true" />
                <TemplateColumn Title="Bus consumes 1h / 24h" Context="m" SortBy="@SortWorkerBus1h">
                    @m.BusConsumesLast1Hour / @m.BusConsumesLast24Hours
                </TemplateColumn>
                <TemplateColumn Title="Last consume (UTC)" Context="m" SortBy="@SortWorkerLastConsume">
                    @(m.LastConsumeUtc is { } t ? t.UtcDateTime.ToString("O") : "—")
                </TemplateColumn>
                <TemplateColumn Title="DB assets 1h / 24h" Context="m" SortBy="@SortWorkerDbAssets1h">
                    @m.DbAssetsAttributedLast1Hour / @m.DbAssetsAttributedLast24Hours
                </TemplateColumn>
                <TemplateColumn Title="Rabbit ready / unacked" Context="m" SortBy="@SortWorkerRabbitReady">
                    @if (_snapshot.RabbitManagementAvailable)
                    {
                        <span>@m.RabbitMessagesReady / @m.RabbitMessagesUnacked</span>
                    }
                    else
                    {
                        <span class="muted">n/a</span>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Matched queues" Context="m">
                    @(m.MatchedRabbitQueueNames.Count == 0 ? "—" : string.Join(", ", m.MatchedRabbitQueueNames))
                </TemplateColumn>
            </QuickGrid>
        </div>

        @if (_snapshot.RabbitManagementAvailable && _snapshot.RabbitQueues.Count > 0)
        {
            <h3 class="subhead">All Rabbit queues (management API)</h3>
            <div class="ops-qg-toolbar">
                <input type="search" class="ops-filter" placeholder="Filter queue name or worker…" @bind="_filterRabbitQueues" @bind:event="oninput" />
            </div>
            <div class="ops-qg-host vq mid" tabindex="-1">
                <QuickGrid Items="FilteredRabbitQueues" Class="nightmare-qg" Theme="default" Virtualize="true" ItemSize="40" ItemKey="@(q => q.Name)" OverscanCount="5">
                    <TemplateColumn Title="Queue" Context="q" SortBy="@SortRabbitQueueName">
                        <code class="mono">@q.Name</code>
                    </TemplateColumn>
                    <PropertyColumn Title="Msgs" Property="@(q => q.Messages)" Sortable="true" />
                    <PropertyColumn Title="Ready" Property="@(q => q.MessagesReady)" Sortable="true" />
                    <PropertyColumn Title="Unacked" Property="@(q => q.MessagesUnacknowledged)" Sortable="true" />
                    <PropertyColumn Title="Consumers" Property="@(q => q.Consumers)" Sortable="true" />
                    <PropertyColumn Title="Guess worker" Property="@(q => q.LikelyWorkerKey ?? "")" Sortable="true" />
                </QuickGrid>
            </div>
        }
        else if (!_snapshot.RabbitManagementAvailable)
        {
            <p class="muted">RabbitMQ management URL not configured or unreachable — queue depths hidden. Set <code>RabbitMq:ManagementUrl</code> (e.g. <code>http://rabbitmq:15672</code> in Docker).</p>
        }
    }
</section>

<section class="panel">
    <h2>Worker activity (from bus journal)</h2>
    <p class="muted">Each container/process writes consumes to the shared journal with its hostname. <strong>Hot / Recently active</strong> means a message <em>completed</em> on that instance recently — not live in-flight work. <strong>Stale</strong> usually means the container is gone or idle. Unknown consumers appear under <code>Other</code>.</p>
    @if (_snapshot?.WorkerActivity is null)
    {
        <p>Loading activity…</p>
    }
    else if (_snapshot.WorkerActivity.Summaries.Count == 0 && _snapshot.WorkerActivity.Instances.Count == 0)
    {
        <p>No consume activity recorded in the last 24 hours.</p>
    }
    else
    {
        <h3 class="subhead">By worker type</h3>
        <div class="ops-qg-toolbar">
            <input type="search" class="ops-filter" placeholder="Filter worker or status…" @bind="_filterWorkerSummaries" @bind:event="oninput" />
        </div>
        <div class="ops-qg-host short" tabindex="-1">
            <QuickGrid Items="FilteredWorkerSummaries" Class="nightmare-qg" Theme="default">
                <PropertyColumn Title="Worker" Property="@(s => s.WorkerKey)" Sortable="true" />
                <TemplateColumn Title="Toggle" Context="s" SortBy="@SortWorkerSummaryToggle">
                    @(s.ToggleEnabled ? "on" : "off")
                </TemplateColumn>
                <PropertyColumn Title="Instances (24h)" Property="@(s => s.InstanceCount)" Sortable="true" />
                <TemplateColumn Title="Last completed (UTC)" Context="s" SortBy="@SortWorkerSummaryLastActivity">
                    @(s.LastActivityUtc is { } t ? t.UtcDateTime.ToString("O") : "—")
                </TemplateColumn>
                <PropertyColumn Title="Roll-up status" Property="@(s => s.RollupActivityLabel)" Sortable="true" />
            </QuickGrid>
        </div>

        <h3 class="subhead">By host &amp; consumer</h3>
        @if (_snapshot.WorkerActivity.Instances.Count == 0)
        {
            <p class="muted">No per-instance consume rows (journal may only have publishes).</p>
        }
        else
        {
            <div class="ops-qg-toolbar">
                <input type="search" class="ops-filter" placeholder="Filter host, consumer, payload…" @bind="_filterWorkerInstances" @bind:event="oninput" />
            </div>
            <div class="ops-qg-host vq tall" tabindex="-1">
                <QuickGrid Items="FilteredWorkerInstances" Class="nightmare-qg" Theme="default" Virtualize="true" ItemSize="40"
                           ItemKey="@InstanceRowKey" OverscanCount="5">
                    <PropertyColumn Title="Host" Property="@(i => i.HostName)" Sortable="true" />
                    <PropertyColumn Title="Worker" Property="@(i => i.WorkerKind)" Sortable="true" />
                    <PropertyColumn Title="Consumer" Property="@(i => i.ConsumerShortName)" Sortable="true" />
                    <TemplateColumn Title="Toggle" Context="i" SortBy="@SortInstanceToggle">
                        @(i.ToggleEnabled is null ? "—" : (i.ToggleEnabled.Value ? "on" : "off"))
                    </TemplateColumn>
                    <PropertyColumn Title="Status" Property="@(i => i.ActivityLabel)" Sortable="true" />
                    <PropertyColumn Title="Last completed (UTC)" Property="@(i => i.LastCompletedAtUtc)" Format="O" Sortable="true" />
                    <PropertyColumn Title="Message type" Property="@(i => i.LastMessageType)" Sortable="true" />
                    <TemplateColumn Title="Last payload (truncated)" Context="i" SortBy="@SortInstancePayload">
                        <span class="mono">@i.LastPayloadPreview</span>
                    </TemplateColumn>
                </QuickGrid>
            </div>
        }
    }
</section>

<section class="panel">
    <h2>Workers</h2>
    @if (_snapshot is null)
    {
        <p>Loading…</p>
    }
    else if (_snapshot.Workers.Count == 0)
    {
        <p>No worker switches (seed the database).</p>
    }
    else
    {
        <div class="ops-qg-toolbar">
            <input type="search" class="ops-filter" placeholder="Filter worker key…" @bind="_filterWorkers" @bind:event="oninput" />
        </div>
        <div class="ops-qg-host short" tabindex="-1">
            <QuickGrid Items="FilteredWorkers" Class="nightmare-qg" Theme="default">
                <PropertyColumn Title="Key" Property="@(w => w.WorkerKey)" Sortable="true" />
                <TemplateColumn Title="Enabled" Context="w" SortBy="@SortWorkerSwitchEnabled">
                    @(w.IsEnabled ? "yes" : "no")
                </TemplateColumn>
                <PropertyColumn Title="Updated (UTC)" Property="@(w => w.UpdatedAtUtc)" Format="u" Sortable="true" />
                <TemplateColumn Title="Actions" Context="w">
                    <button type="button" disabled="@_busyWorkers" @onclick="@(() => SetWorkerAsync(w.WorkerKey, true))">Start</button>
                    <button type="button" disabled="@_busyWorkers" @onclick="@(() => SetWorkerAsync(w.WorkerKey, false))">Stop</button>
                </TemplateColumn>
            </QuickGrid>
        </div>
    }
</section>

<section class="panel">
    <h2>Assets</h2>
    <div class="row">
        <label>Target filter</label>
        <select @bind="_targetFilter" @bind:after="ReloadAssetsAsync">
            <option value="">All targets</option>
            @foreach (var t in _targets)
            {
                <option value="@t.Id.ToString()">@t.RootDomain</option>
            }
        </select>
        <button type="button" @onclick="ReloadAllAsync">Refresh now</button>
    </div>
    <div class="ops-qg-toolbar">
        <input type="search" class="ops-filter" placeholder="Filter kind, status, raw URL, pipeline, how found…" @bind="_filterAssets" @bind:event="oninput" />
    </div>
    <div class="ops-qg-host vq tall" tabindex="-1">
        <QuickGrid Items="FilteredAssets" Class="nightmare-qg" Theme="default" Virtualize="true" ItemSize="40" ItemKey="@(a => a.Id)" OverscanCount="6">
            <PropertyColumn Title="Discovered (UTC)" Property="@(a => a.DiscoveredAtUtc)" Format="u" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="Descending" />
            <PropertyColumn Title="Kind" Property="@(a => a.Kind)" Sortable="true" />
            <PropertyColumn Title="Status" Property="@(a => a.LifecycleStatus)" Sortable="true" />
            <PropertyColumn Title="Depth" Property="@(a => a.Depth)" Sortable="true" />
            <PropertyColumn Title="Raw" Property="@(a => a.RawValue)" Sortable="true" />
            <PropertyColumn Title="Pipeline" Property="@(a => a.DiscoveredBy)" Sortable="true" />
            <TemplateColumn Title="How found" Context="a" SortBy="@SortAssetDiscoveryContext">
                <span title="@a.DiscoveryContext">@(string.IsNullOrWhiteSpace(a.DiscoveryContext) ? "—" : a.DiscoveryContext)</span>
            </TemplateColumn>
        </QuickGrid>
    </div>
</section>

<section class="panel">
    <h2>Event bus (live — recent publishes)</h2>
    <div class="ops-qg-toolbar">
        <input type="search" class="ops-filter" placeholder="Filter type, host, payload…" @bind="_filterLiveBus" @bind:event="oninput" />
    </div>
    <div class="ops-qg-host vq tall" tabindex="-1">
        <QuickGrid Items="FilteredLiveBus" Class="nightmare-qg" Theme="default" Virtualize="true" ItemSize="40" ItemKey="@(e => e.Id)" OverscanCount="5">
            <PropertyColumn Title="Time (UTC)" Property="@(e => e.OccurredAtUtc)" Format="O" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="Descending" />
            <PropertyColumn Title="Type" Property="@(e => e.MessageType)" Sortable="true" />
            <PropertyColumn Title="Host" Property="@(e => e.HostName)" Sortable="true" />
            <PropertyColumn Title="Payload (truncated)" Property="@(e => e.PayloadJson)" Sortable="true" />
        </QuickGrid>
    </div>
</section>

<section class="panel">
    <h2>Historic bus journal</h2>
    <div class="ops-qg-toolbar">
        <input type="search" class="ops-filter" placeholder="Filter id, direction, type, host, payload…" @bind="_filterHistoryBus" @bind:event="oninput" />
    </div>
    <div class="ops-qg-host vq tall" tabindex="-1">
        <QuickGrid Items="FilteredHistoryBus" Class="nightmare-qg" Theme="default" Virtualize="true" ItemSize="40" ItemKey="@(e => e.Id)" OverscanCount="5">
            <PropertyColumn Title="Id" Property="@(e => e.Id)" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="Descending" />
            <PropertyColumn Title="Dir" Property="@(e => e.Direction)" Sortable="true" />
            <PropertyColumn Title="Time (UTC)" Property="@(e => e.OccurredAtUtc)" Format="O" Sortable="true" />
            <PropertyColumn Title="Type" Property="@(e => e.MessageType)" Sortable="true" />
            <PropertyColumn Title="Consumer" Property="@(e => e.ConsumerType)" Sortable="true" />
            <PropertyColumn Title="Host" Property="@(e => e.HostName)" Sortable="true" />
            <PropertyColumn Title="Payload (truncated)" Property="@(e => e.PayloadJson)" Sortable="true" />
        </QuickGrid>
    </div>
</section>

@code {
    private readonly CancellationTokenSource _pollCts = new();
    private readonly List<TargetSummary> _targets = [];
    private readonly List<AssetGridRowDto> _assets = [];
    private readonly List<BusJournalRowDto> _liveBus = [];
    private readonly List<BusJournalRowDto> _historyBus = [];
    private OpsSnapshotDto? _snapshot;
    private string _targetFilter = "";
    private bool _busyWorkers;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAllAsync().ConfigureAwait(false);
        _ = PollAsync();
    }

    private async Task PollAsync()
    {
        try
        {
            while (!_pollCts.IsCancellationRequested)
            {
                await Task.Delay(2000, _pollCts.Token).ConfigureAwait(false);
                await ReloadVolatileAsync().ConfigureAwait(false);
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            // shutdown
        }
    }

    private async Task ReloadVolatileAsync()
    {
        try
        {
            var live = await Http.GetFromJsonAsync<List<BusJournalRowDto>>("/api/bus/live?minutes=3&take=120").ConfigureAwait(false);
            _liveBus.Clear();
            if (live is not null)
                _liveBus.AddRange(live);

            var hist = await Http.GetFromJsonAsync<List<BusJournalRowDto>>("/api/bus/history?take=350").ConfigureAwait(false);
            _historyBus.Clear();
            if (hist is not null)
                _historyBus.AddRange(hist);

            var snap = await Http.GetFromJsonAsync<OpsSnapshotDto>("/api/ops/snapshot").ConfigureAwait(false);
            _snapshot = snap;
        }
        catch
        {
            // keep last good snapshot
        }
    }

    private async Task ReloadAllAsync()
    {
        try
        {
            var targets = await Http.GetFromJsonAsync<List<TargetSummary>>("/api/targets").ConfigureAwait(false);
            _targets.Clear();
            if (targets is not null)
                _targets.AddRange(targets);
        }
        catch
        {
            _targets.Clear();
        }

        await ReloadAssetsAsync().ConfigureAwait(false);
        await ReloadVolatileAsync().ConfigureAwait(false);
    }

    private async Task ReloadAssetsAsync()
    {
        try
        {
            var qs = string.IsNullOrEmpty(_targetFilter) ? "?take=800" : $"?targetId={Uri.EscapeDataString(_targetFilter)}&take=800";
            var list = await Http.GetFromJsonAsync<List<AssetGridRowDto>>($"/api/assets{qs}").ConfigureAwait(false);
            _assets.Clear();
            if (list is not null)
                _assets.AddRange(list);
        }
        catch
        {
            _assets.Clear();
        }
    }

    private async Task SetWorkerAsync(string key, bool enabled)
    {
        _busyWorkers = true;
        try
        {
            var resp = await Http.PutAsJsonAsync($"/api/workers/{Uri.EscapeDataString(key)}", new WorkerPatchRequest(enabled)).ConfigureAwait(false);
            resp.EnsureSuccessStatusCode();
            await ReloadVolatileAsync().ConfigureAwait(false);
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
        finally
        {
            _busyWorkers = false;
        }
    }

    public void Dispose() => _pollCts.Cancel();
}
