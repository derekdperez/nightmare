POSTGRES_DB=nightmare
POSTGRES_USER=nightmare
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
COORDINATOR_API_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
LOG_DATABASE_URL=postgresql://nightmare_logs:CHANGE_ME_LOG_DB_PASSWORD@10.0.0.50:5432/nightmare_logs
TLS_CERT_FILE=/absolute/path/to/fullchain.pem
TLS_KEY_FILE=/absolute/path/to/privkey.pem
COORDINATOR_BASE_URL=https://your-coordinator-hostname
# Optional AWS worker-provision defaults (used by deploy/provision-workers-aws.sh)
AWS_REGION=us-east-1
AWS_AMI_ID=ami-REPLACE_ME
AWS_INSTANCE_TYPE=m7i-flex.large
AWS_SUBNET_ID=subnet-REPLACE_ME
AWS_SECURITY_GROUP_IDS=sg-REPLACE_ME
AWS_KEY_NAME=kp-REPLACE_ME
AWS_IAM_INSTANCE_PROFILE=ec2
REPO_URL=https://github.com/<owner>/<repo>.git
REPO_BRANCH=main
AUTO_PROVISION_WORKERS=2
