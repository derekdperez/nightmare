<style>
  .app-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: -16px -16px 16px;
    padding: 0 16px;
    background: rgba(248, 250, 252, 0.94);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #cbd5e1;
  }
  .app-nav-inner {
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 58px;
    flex-wrap: wrap;
    padding: 10px 0;
  }
  .app-nav-brand {
    font-size: 18px;
    font-weight: 700;
    color: #0f172a;
    text-decoration: none;
    margin-right: 4px;
    white-space: nowrap;
  }
  .app-nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  #workflowInterfaceNav { display: contents; }
  .app-nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 12px;
    border: 1px solid #cbd5e1;
    border-radius: 999px;
    background: #fff;
    color: #334155;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: background-color .15s ease, border-color .15s ease, color .15s ease, box-shadow .15s ease;
  }
  .app-nav-link:hover {
    background: #eff6ff;
    border-color: #93c5fd;
    color: #1d4ed8;
  }
  .app-nav-link.active {
    background: #0ea5e9;
    border-color: #0284c7;
    color: #fff;
    box-shadow: 0 4px 14px rgba(2, 132, 199, 0.18);
  }
  @media (max-width: 900px) {
    .app-nav { margin-left: -16px; margin-right: -16px; }
    .app-nav-brand { width: 100%; margin-bottom: 2px; }
  }
  .app-net-indicator {
    position: fixed;
    right: 12px;
    bottom: 12px;
    z-index: 120;
    pointer-events: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(15, 23, 42, 0.88);
    color: #e2e8f0;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }
  .app-net-indicator.active {
    opacity: 1;
    transform: translateY(0);
  }
  .app-net-spinner {
    width: 12px;
    height: 12px;
    border: 2px solid rgba(186, 230, 253, 0.7);
    border-top-color: #0ea5e9;
    border-radius: 50%;
    animation: app-net-spin 0.8s linear infinite;
  }
  @keyframes app-net-spin {
    to { transform: rotate(360deg); }
  }
</style>
<nav class="app-nav" aria-label="Primary">
  <div class="app-nav-inner">
    <a class="app-nav-brand" href="/operations">Nightmare</a>
    <div class="app-nav-links">
      <a class="app-nav-link" href="/operations" data-nav-path="/operations">Operations</a>
      <a class="app-nav-link" href="/workers" data-nav-path="/workers">Workers</a>
      <a class="app-nav-link" href="/workflows" data-nav-path="/workflows">Workflows</a>
      <span id="workflowInterfaceNav"></span>
      <a class="app-nav-link" href="/workflow-definitions" data-nav-path="/workflow-definitions">Workflow Builder</a>
      <a class="app-nav-link" href="/plugin-definitions" data-nav-path="/plugin-definitions">Plugins</a>
      <a class="app-nav-link" href="/workflow-runs" data-nav-path="/workflow-runs">Workflow Runs</a>
      <a class="app-nav-link" href="/http-requests" data-nav-path="/http-requests">HTTP Requests</a>
      <a class="app-nav-link" href="/database" data-nav-path="/database">Database</a>
      <a class="app-nav-link" href="/crawl-progress" data-nav-path="/crawl-progress">Crawl Progress</a>
      <a class="app-nav-link" href="/discovered-targets" data-nav-path="/discovered-targets">Discovered Targets</a>
      <a class="app-nav-link" href="/discovered-files" data-nav-path="/discovered-files">Discovered Files</a>
      <a class="app-nav-link" href="/extractor-matches" data-nav-path="/extractor-matches">Extractor Matches</a>
      <a class="app-nav-link" href="/fuzzing" data-nav-path="/fuzzing">Fuzzing</a>
      <a class="app-nav-link" href="/docker-status" data-nav-path="/docker-status">Docker Status</a>
      <a class="app-nav-link" href="/view-logs" data-nav-path="/view-logs">View Logs</a>
      <a class="app-nav-link" href="/events" data-nav-path="/events">Events</a>
      <a class="app-nav-link" href="/auth0r" data-nav-path="/auth0r">Auth0r</a>
      <a class="app-nav-link" href="/errors" data-nav-path="/errors">Errors</a>
    </div>
  </div>
</nav>
<div id="appNetIndicator" class="app-net-indicator" aria-live="polite">
  <span class="app-net-spinner" aria-hidden="true"></span>
  <span id="appNetIndicatorText">Working...</span>
</div>
<script>
  (() => {
    const path = window.location.pathname === "/" ? "/workers" : window.location.pathname;
    const hash = String(window.location.hash || "").toLowerCase();
    const currentWithHash = `${path}${hash}`;
    function markActiveNav() {
      let matched = false;
      document.querySelectorAll(".app-nav-link").forEach((link) => {
        link.classList.remove("active");
        if (String(link.dataset.navPath || "") === currentWithHash) {
          link.classList.add("active");
          matched = true;
        }
      });
      if (matched) return;
      document.querySelectorAll(".app-nav-link").forEach((link) => {
        if (String(link.dataset.navPath || "") === path) link.classList.add("active");
      });
    }
    markActiveNav();

    if (!window.NightmareUX) {
      const indicator = document.getElementById("appNetIndicator");
      const indicatorText = document.getElementById("appNetIndicatorText");
      let activeRequests = 0;
      let hiddenTimer = null;

      function setIndicatorVisible(show, text) {
        if (!indicator) return;
        if (hiddenTimer) {
          clearTimeout(hiddenTimer);
          hiddenTimer = null;
        }
        if (show) {
          indicator.classList.add("active");
          if (indicatorText) indicatorText.textContent = String(text || "Working...");
        } else {
          hiddenTimer = setTimeout(() => {
            indicator.classList.remove("active");
            if (indicatorText) indicatorText.textContent = "Working...";
          }, 140);
        }
      }

      function beginNetwork(label) {
        activeRequests += 1;
        const text = label || `Loading (${activeRequests})...`;
        setIndicatorVisible(true, text);
      }

      function endNetwork() {
        activeRequests = Math.max(0, activeRequests - 1);
        if (activeRequests <= 0) {
          setIndicatorVisible(false);
          return;
        }
        setIndicatorVisible(true, `Loading (${activeRequests})...`);
      }

      const TOKEN_COOKIE_NAME = "nightmare_coord_token";
      function readCookie(name) {
        return document.cookie.split(";").map((p) => p.trim()).find((p) => p.startsWith(`${name}=`))?.slice(name.length + 1) || "";
      }
      function readAuthToken() {
        const cookieToken = decodeURIComponent(readCookie(TOKEN_COOKIE_NAME) || "").trim();
        if (cookieToken) return cookieToken;
        const tokenInput = document.getElementById("token");
        const inputToken = tokenInput && "value" in tokenInput ? String(tokenInput.value || "").trim() : "";
        if (inputToken) return inputToken;
        try { return String(window.localStorage.getItem(TOKEN_COOKIE_NAME) || "").trim(); } catch { return ""; }
      }
      function withAuthHeaders(init) {
        const next = { ...(init || {}) };
        const headers = new Headers(next.headers || {});
        const token = readAuthToken();
        if (token && !headers.has("Authorization")) headers.set("Authorization", `Bearer ${token}`);
        next.headers = headers;
        next.credentials = next.credentials || "same-origin";
        return next;
      }
      const originalFetch = window.fetch ? window.fetch.bind(window) : null;
      if (originalFetch) {
        window.fetch = async (input, init = {}) => {
          beginNetwork();
          try {
            let requestUrl = "";
            try { requestUrl = typeof input === "string" ? input : String(input && input.url || ""); } catch { requestUrl = ""; }
            const sameOrigin = !/^https?:\/\//i.test(requestUrl) || requestUrl.startsWith(window.location.origin);
            const finalInit = sameOrigin ? withAuthHeaders(init) : init;
            return await originalFetch(input, finalInit);
          } finally {
            endNetwork();
          }
        };
      }
      window.NightmareAuth = { readAuthToken, withAuthHeaders, fetchJson: async (url, init = {}) => {
        const rsp = await window.fetch(url, withAuthHeaders(init));
        const text = await rsp.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch { data = { raw: text }; }
        if (!rsp.ok) throw new Error([data.error, data.detail].filter(Boolean).join(': ') || text || `HTTP ${rsp.status}`);
        return data;
      }};

      window.NightmareUX = {
        beginNetwork,
        endNetwork,
        setIndicatorVisible,
      };
    }

    async function hydrateWorkflowInterfaceNav() {
      const host = document.getElementById("workflowInterfaceNav");
      if (!host || !window.NightmareAuth || typeof window.NightmareAuth.fetchJson !== "function") return;
      try {
        const payload = await window.NightmareAuth.fetchJson("/api/coord/workflow-interfaces", { method: "GET", cache: "no-store" });
        const items = Array.isArray(payload.interfaces) ? payload.interfaces : [];
        const links = items
          .map((item) => {
            if (!item || typeof item !== "object") return "";
            const route = String(item.route || "").trim();
            const label = String(item.nav_label || item.title || "").trim();
            if (!route || !label) return "";
            const navPath = `${route}${String(item.hash || "")}`;
            return `<a class="app-nav-link" href="${route}" data-nav-path="${navPath}">${label}</a>`;
          })
          .filter(Boolean)
          .join("");
        host.innerHTML = links;
        markActiveNav();
      } catch (_) {
        host.innerHTML = "";
      }
    }
    hydrateWorkflowInterfaceNav();
  })();
</script>
