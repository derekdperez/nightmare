<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>View Logs</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f8fafc; color: #0f172a; }
    h1 { margin-bottom: 8px; }
    .meta { margin-bottom: 12px; color: #475569; font-size: 13px; }
    .toolbar { display: flex; gap: 8px; align-items: center; margin: 10px 0 16px; flex-wrap: wrap; }
    input, select { padding: 6px 8px; border: 1px solid #94a3b8; border-radius: 6px; min-width: 220px; }
    button { border: 1px solid #94a3b8; background: #fff; border-radius: 6px; padding: 6px 10px; cursor: pointer; }
    button.primary { background: #0ea5e9; border-color: #0284c7; color: white; }
    .muted { color: #64748b; }
    .status-pill { display: inline-flex; align-items: center; gap: 8px; border: 1px solid #cbd5e1; border-radius: 999px; padding: 5px 10px; font-size: 12px; font-weight: 600; background: #fff; color: #334155; }
    .status-dot { width: 9px; height: 9px; border-radius: 999px; background: #94a3b8; }
    .status-loading .status-dot { background: #0284c7; animation: pulse 1s ease-in-out infinite; }
    .status-success .status-dot { background: #16a34a; }
    .status-error .status-dot { background: #dc2626; }
    .status-timeout .status-dot { background: #d97706; }
    @keyframes pulse { 0%, 100% { transform: scale(0.8); opacity: 0.7; } 50% { transform: scale(1.2); opacity: 1; } }
    .table-wrap { max-height: 68vh; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; margin-top: 8px; }
    .diag-wrap { max-height: 36vh; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; margin-top: 8px; }
    table { width: 100%; border-collapse: collapse; background: #fff; border: 0; }
    #logEventsTable { table-layout: fixed; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; font-size: 12px; vertical-align: top; text-align: left; }
    th { background: #e2e8f0; position: sticky; top: 0; z-index: 3; }
    #logEventsTable th, #logEventsTable td { overflow-wrap: anywhere; word-break: break-word; }
    code { white-space: pre-wrap; word-break: break-word; }
    .cell-clamp { display: block; max-height: 8.5em; overflow: auto; white-space: pre-wrap; word-break: break-word; }
    .copyable-cell { cursor: copy; }
    .sev-debug { color: #64748b; }
    .sev-info { color: #0369a1; font-weight: 600; }
    .sev-warning { color: #b45309; font-weight: 600; }
    .sev-error { color: #dc2626; font-weight: 700; }
    .sev-critical { color: #991b1b; font-weight: 700; }
    .diag-ok { color: #15803d; font-weight: 700; }
    .diag-error { color: #b91c1c; font-weight: 700; }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <h1>View Logs</h1>
  <div class="meta">Fleet log viewer (central server + worker VMs + AWS console output). Time shown in EST (UTC-5). Auto-refresh every 30s.</div>
  <div class="toolbar">
    <input id="token" type="password" placeholder="Coordinator token">
    <select id="sourceSelect"></select>
    <input id="searchText" type="text" placeholder="Search description/raw line">
    <select id="severityFilter">
      <option value="">All severities</option>
      <option value="debug">debug</option>
      <option value="info">info</option>
      <option value="warning">warning</option>
      <option value="error">error</option>
      <option value="critical">critical</option>
    </select>
    <input id="machineFilter" type="text" placeholder="Machine filter">
    <select id="sortKey">
      <option value="event_time_utc">Sort: time</option>
      <option value="severity">Sort: severity</option>
      <option value="machine">Sort: machine</option>
      <option value="description">Sort: description</option>
    </select>
    <select id="sortDir">
      <option value="desc">Newest first</option>
      <option value="asc">Oldest first</option>
    </select>
    <button class="primary" onclick="loadEvents()">Refresh</button>
    <button onclick="refreshSources(true)">Refresh Sources</button>
    <button onclick="runDiagnostics(true)">Run Diagnostics</button>
    <button onclick="downloadSource()">Download Zip</button>
    <span id="loadState" class="status-pill status-idle"><span class="status-dot"></span><span id="loadStateText">Idle</span></span>
    <span id="msg" class="muted"></span>
  </div>
  <div class="table-wrap">
    <table id="logEventsTable">
      <thead>
        <tr>
          <th data-col-key="date">Date</th>
          <th data-col-key="time_est">Time (EST)</th>
          <th data-col-key="severity">Severity</th>
          <th data-col-key="description">Description</th>
          <th data-col-key="machine">Machine</th>
          <th data-col-key="source_id">Source</th>
          <th data-col-key="raw_line">Raw</th>
        </tr>
      </thead>
      <tbody id="eventsRows"><tr><td colspan="7">Loading...</td></tr></tbody>
    </table>
  </div>
  <h3 style="margin-top:16px;margin-bottom:6px;">Log Source Diagnostics</h3>
  <div id="diagMeta" class="meta">Run diagnostics to see which sources are readable and which are failing.</div>
  <div class="diag-wrap">
    <table id="diagTable">
      <thead>
        <tr>
          <th>Time (EST)</th>
          <th>Status</th>
          <th>Source</th>
          <th>System</th>
          <th>Type</th>
          <th>Container</th>
          <th>Instance</th>
          <th>Lines</th>
          <th>Error</th>
          <th>Preview</th>
        </tr>
      </thead>
      <tbody id="diagRows"><tr><td colspan="10">No diagnostics run yet.</td></tr></tbody>
    </table>
  </div>
  {% include '_grid_controls.html.j2' %}
  <script>
    const TOKEN_COOKIE_NAME = "nightmare_coord_token";
    const SOURCE_PREF_KEY = "nightmare_view_logs_source_v2";
    const SOURCES_CACHE_KEY = "nightmare_view_logs_sources_cache_v1";
    const EVENTS_CACHE_KEY = "nightmare_view_logs_events_cache_v1";
    const LOG_LINES = 300;
    const SOURCES_CACHE_TTL_MS = 12 * 60 * 60 * 1000;
    const EVENTS_CACHE_TTL_MS = 3 * 60 * 1000;
    const SOURCE_LOAD_TIMEOUT_MS = 30000;
    const EVENTS_LOAD_TIMEOUT_MS = 45000;
    const DIAG_LOAD_TIMEOUT_MS = 90000;
    let logGridCtrl = null;
    let autoRefreshInFlight = false;

    function esc(v){ return String(v ?? "").replace(/[&<>\"']/g, (ch) => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[ch])); }
    function readCookie(name) {
      const needle = `${name}=`;
      for (const part of String(document.cookie || "").split(";")) {
        const item = part.trim();
        if (item.startsWith(needle)) return decodeURIComponent(item.slice(needle.length));
      }
      return "";
    }
    function writeCookie(name, value, days) {
      const maxAge = Math.max(1, Number(days || 30)) * 24 * 60 * 60;
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`;
    }
    function deleteCookie(name) {
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`;
    }
    function persistTokenCookie() {
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      else deleteCookie(TOKEN_COOKIE_NAME);
    }
    function hydrateTokenFromCookie() {
      const token = readCookie(TOKEN_COOKIE_NAME);
      if (token) document.getElementById("token").value = token;
    }
    function authHeaders() {
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      return token ? { Authorization: `Bearer ${token}` } : {};
    }
    function saveSelectedSource(value) {
      if (value) localStorage.setItem(SOURCE_PREF_KEY, value);
    }
    function loadSelectedSource() {
      return localStorage.getItem(SOURCE_PREF_KEY) || "";
    }
    function readLocalJson(key) {
      try {
        const raw = localStorage.getItem(String(key || ""));
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : null;
      } catch (_e) {
        return null;
      }
    }
    function writeLocalJson(key, value) {
      try {
        localStorage.setItem(String(key || ""), JSON.stringify(value ?? {}));
      } catch (_e) {
        // Ignore quota/serialization issues and continue with live fetches.
      }
    }
    function readFreshCache(key, ttlMs) {
      const row = readLocalJson(key);
      if (!row) return null;
      const cachedAt = Number(row.cached_at_epoch_ms || 0);
      if (!Number.isFinite(cachedAt) || cachedAt <= 0) return null;
      const ttl = Math.max(1000, Number(ttlMs || 0));
      if ((Date.now() - cachedAt) > ttl) return null;
      return row;
    }
    function saveSourcesCache(payload) {
      writeLocalJson(SOURCES_CACHE_KEY, {
        cached_at_epoch_ms: Date.now(),
        payload: payload || {},
      });
    }
    function loadSourcesCache() {
      const row = readFreshCache(SOURCES_CACHE_KEY, SOURCES_CACHE_TTL_MS);
      if (!row || !row.payload || typeof row.payload !== "object") return null;
      const payload = row.payload;
      return Array.isArray(payload.sources) ? payload : null;
    }
    function saveEventsCache(queryKey, payload) {
      writeLocalJson(EVENTS_CACHE_KEY, {
        cached_at_epoch_ms: Date.now(),
        query_key: String(queryKey || ""),
        payload: payload || {},
      });
    }
    function loadEventsCache(queryKey) {
      const row = readFreshCache(EVENTS_CACHE_KEY, EVENTS_CACHE_TTL_MS);
      if (!row) return null;
      if (String(row.query_key || "") !== String(queryKey || "")) return null;
      if (!row.payload || typeof row.payload !== "object") return null;
      const payload = row.payload;
      return Array.isArray(payload.events) ? payload : null;
    }
    function buildSourceLabel(source) {
      const type = String(source.source_type || "");
      if (type === "docker") return `[docker/${source.system || "local"}] ${source.label || source.container_name || "unknown"} (${source.status || "unknown"})`;
      if (type === "ec2_console") return `[ec2-console] ${source.label || source.instance_id || "unknown"} (${source.status || "unknown"})`;
      return `[file] ${source.relative_path || source.label || "unknown"}`;
    }
    function renderSources(payload) {
      const select = document.getElementById("sourceSelect");
      const sources = Array.isArray(payload && payload.sources) ? payload.sources : [];
      const prior = loadSelectedSource();
      const allOption = { source_id: "__all__", source_type: "virtual", label: "All Sources" };
      const options = [allOption, ...sources];
      select.innerHTML = options.map((source) => `<option value="${esc(source.source_id)}">${esc(source.source_id === "__all__" ? "[all] All Sources" : buildSourceLabel(source))}</option>`).join("");
      if (prior && options.some((source) => String(source.source_id || "") === prior)) select.value = prior;
      if (!select.value && options.length) select.value = String(options[0].source_id || "__all__");
      if (select.value) saveSelectedSource(select.value);
      return sources.length;
    }
    function buildEventsQuery(sourceId) {
      const params = new URLSearchParams();
      params.set("source_id", sourceId);
      params.set("lines", String(LOG_LINES));
      const searchText = String(document.getElementById("searchText").value || "").trim();
      const severity = String(document.getElementById("severityFilter").value || "").trim();
      const machine = String(document.getElementById("machineFilter").value || "").trim();
      const sortKey = String(document.getElementById("sortKey").value || "event_time_utc").trim();
      const sortDir = String(document.getElementById("sortDir").value || "desc").trim();
      if (searchText) params.set("search", searchText);
      if (severity) params.set("severity", severity);
      if (machine) params.set("machine", machine);
      params.set("sort_key", sortKey);
      params.set("sort_dir", sortDir);
      params.set("limit", "1000");
      return {
        params,
        cacheKey: JSON.stringify({
          source_id: sourceId,
          lines: LOG_LINES,
          search: searchText,
          severity,
          machine,
          sort_key: sortKey,
          sort_dir: sortDir,
          limit: 1000,
        }),
      };
    }
    function setLoadState(state, text) {
      const pill = document.getElementById("loadState");
      const txt = document.getElementById("loadStateText");
      if (!pill || !txt) return;
      pill.classList.remove("status-loading", "status-success", "status-error", "status-timeout");
      const safeState = String(state || "idle").toLowerCase();
      if (safeState === "loading") pill.classList.add("status-loading");
      else if (safeState === "success") pill.classList.add("status-success");
      else if (safeState === "error") pill.classList.add("status-error");
      else if (safeState === "timeout") pill.classList.add("status-timeout");
      txt.textContent = String(text || "Idle");
    }
    async function apiGet(path, timeoutMs) {
      const controller = new AbortController();
      const timeout = Math.max(1000, Number(timeoutMs || 30000));
      const timer = setTimeout(() => controller.abort(new Error("request_timeout")), timeout);
      let rsp;
      try {
        rsp = await fetch(path, { cache: "no-store", headers: authHeaders(), signal: controller.signal });
      } finally {
        clearTimeout(timer);
      }
      if (!rsp.ok) throw new Error(await rsp.text());
      return rsp.json();
    }
    async function refreshSources(forceRefresh, options) {
      const msg = document.getElementById("msg");
      const useCacheFirst = Boolean(options && options.useCacheFirst);
      let showedCached = false;
      if (useCacheFirst) {
        const cached = loadSourcesCache();
        if (cached) {
          const count = renderSources(cached);
          setLoadState("loading", "Refreshing log sources...");
          msg.textContent = `Loaded ${count} cached source(s). Refreshing...`;
          showedCached = true;
        }
      }
      if (!showedCached) {
        setLoadState("loading", "Loading log sources...");
        msg.textContent = "Loading sources...";
      }
      try {
        const force = Boolean(forceRefresh);
        const payload = await apiGet(`/api/coord/log-sources?force_refresh=${force ? "1" : "0"}`, SOURCE_LOAD_TIMEOUT_MS);
        const count = renderSources(payload);
        saveSourcesCache(payload);
        msg.textContent = `Loaded ${count} source(s).`;
        setLoadState("success", `Loaded ${count} source(s)`);
      } catch (e) {
        const isTimeout = String(e && (e.name || "")).toLowerCase() === "aborterror";
        if (showedCached) {
          msg.textContent = isTimeout
            ? "Source refresh timed out. Showing cached sources."
            : `Source refresh failed. Showing cached sources. (${e.message || e})`;
        } else {
          msg.textContent = isTimeout ? "Source load timed out." : `Source load failed: ${e.message || e}`;
        }
        setLoadState(isTimeout ? "timeout" : "error", isTimeout ? "Source load timed out" : "Source load failed");
      }
    }
    function renderEvents(payload) {
      const rows = Array.isArray(payload.events) ? payload.events : [];
      const tbody = document.getElementById("eventsRows");
      if (!rows.length) {
        tbody.innerHTML = "<tr><td colspan='7'>No log events returned.</td></tr>";
      } else {
        tbody.innerHTML = rows.map((row) => {
          const est = String(row.event_time_est || "");
          const datePart = est ? est.slice(0, 10) : "";
          const timePart = est ? est.slice(11) : "";
          const sev = String(row.severity || "info").toLowerCase();
          return `<tr>
            <td>${esc(datePart)}</td>
            <td>${esc(timePart)}</td>
            <td><span class="sev-${esc(sev)}">${esc(sev)}</span></td>
            <td><div class="cell-clamp copyable-cell" title="Double-click to copy full text">${esc(row.description || "")}</div></td>
            <td>${esc(row.machine || "")}</td>
            <td>${esc(row.source_id || "")}</td>
            <td><code class="cell-clamp copyable-cell" title="Double-click to copy full text">${esc(row.raw_line || "")}</code></td>
          </tr>`;
        }).join("");
      }
      if (!logGridCtrl) {
        logGridCtrl = window.NightmareGridControls.enhance({
          table: "logEventsTable",
          page: "view_logs",
          prefKey: "log_events_table_v1",
          tokenInputId: "token",
          mode: "columnsOnly",
          allowReorder: true,
          minColumnWidth: 80,
          maxColumnWidth: 2200,
          defaultWidths: {
            date: 120,
            time_est: 130,
            severity: 100,
            description: 880,
            machine: 240,
            source_id: 300,
            raw_line: 700,
          },
          maxWidths: {
            date: 220,
            time_est: 240,
            severity: 180,
            description: 1600,
            machine: 600,
            source_id: 900,
            raw_line: 1800,
          },
        });
      } else {
        logGridCtrl.refresh();
      }
    }
    function renderDiagnostics(payload) {
      const rows = Array.isArray(payload.rows) ? payload.rows : [];
      const meta = document.getElementById("diagMeta");
      meta.textContent = `Diagnosed ${payload.diagnosed_sources || 0}/${payload.total_sources || 0} sources | ok=${payload.ok_sources || 0} | error=${payload.error_sources || 0} | generated=${payload.generated_at_utc || ""}`;
      const tbody = document.getElementById("diagRows");
      if (!rows.length) {
        tbody.innerHTML = "<tr><td colspan='10'>No diagnostics data returned.</td></tr>";
        return;
      }
      tbody.innerHTML = rows.map((row) => {
        const ok = Boolean(row.ok);
        const status = ok ? "ok" : "error";
        const statusCls = ok ? "diag-ok" : "diag-error";
        return `<tr>
          <td>${esc(row.checked_at_est_time || "")}</td>
          <td><span class="${statusCls}">${esc(status)}</span></td>
          <td>${esc(row.label || row.source_id || "")}</td>
          <td>${esc(row.system || "")}</td>
          <td>${esc(row.source_type || "")}</td>
          <td>${esc(row.container_name || "")}</td>
          <td>${esc(row.instance_id || "")}</td>
          <td>${esc(row.line_count || 0)}</td>
          <td><div class="cell-clamp copyable-cell" title="Double-click to copy full text">${esc(row.error || "")}</div></td>
          <td><code class="cell-clamp copyable-cell" title="Double-click to copy full text">${esc(row.preview || "")}</code></td>
        </tr>`;
      }).join("");
    }
    async function loadEvents(options) {
      const msg = document.getElementById("msg");
      const useCacheFirst = Boolean(options && options.useCacheFirst);
      const sourceId = String(document.getElementById("sourceSelect").value || "__all__").trim() || "__all__";
      saveSelectedSource(sourceId);
      const query = buildEventsQuery(sourceId);
      let showedCached = false;
      if (useCacheFirst) {
        const cached = loadEventsCache(query.cacheKey);
        if (cached) {
          renderEvents(cached);
          setLoadState("loading", "Refreshing log events...");
          msg.textContent = `Loaded ${rowsCount(cached.events)} cached log event(s). Refreshing...`;
          showedCached = true;
        }
      }
      if (!showedCached) {
        setLoadState("loading", "Loading log events...");
        msg.textContent = "Loading log events...";
      }
      try {
        const payload = await apiGet(`/api/coord/log-events?${query.params.toString()}`, EVENTS_LOAD_TIMEOUT_MS);
        renderEvents(payload);
        saveEventsCache(query.cacheKey, payload);
        msg.textContent = `Loaded ${rowsCount(payload.events)} / ${payload.total || 0} log event(s).`;
        setLoadState("success", `Loaded ${rowsCount(payload.events)} event(s)`);
      } catch (e) {
        const isTimeout = String(e && (e.name || "")).toLowerCase() === "aborterror";
        if (!showedCached) {
          document.getElementById("eventsRows").innerHTML = `<tr><td colspan="7">Failed to load events: ${esc(e.message || e)}</td></tr>`;
        }
        if (showedCached) {
          msg.textContent = isTimeout
            ? "Event refresh timed out. Showing cached events."
            : `Event refresh failed. Showing cached events. (${e.message || e})`;
        } else {
          msg.textContent = isTimeout ? "Event load timed out." : `Event load failed: ${e.message || e}`;
        }
        setLoadState(isTimeout ? "timeout" : "error", isTimeout ? "Event load timed out" : "Event load failed");
      }
    }
    async function runDiagnostics(forceRefresh) {
      const msg = document.getElementById("msg");
      setLoadState("loading", "Running log diagnostics...");
      msg.textContent = "Running log diagnostics...";
      try {
        const force = Boolean(forceRefresh);
        const payload = await apiGet(`/api/coord/log-source-diagnostics?force_refresh=${force ? "1" : "0"}&lines=20&limit=200`, DIAG_LOAD_TIMEOUT_MS);
        renderDiagnostics(payload);
        setLoadState("success", `Diagnostics: ok=${payload.ok_sources || 0}, error=${payload.error_sources || 0}`);
        msg.textContent = `Diagnostics complete: ${payload.ok_sources || 0} readable, ${payload.error_sources || 0} failing source(s).`;
      } catch (e) {
        const isTimeout = String(e && (e.name || "")).toLowerCase() === "aborterror";
        document.getElementById("diagRows").innerHTML = `<tr><td colspan="10">Diagnostics failed: ${esc(e.message || e)}</td></tr>`;
        setLoadState(isTimeout ? "timeout" : "error", isTimeout ? "Diagnostics timed out" : "Diagnostics failed");
        msg.textContent = isTimeout ? "Diagnostics timed out." : `Diagnostics failed: ${e.message || e}`;
      }
    }
    function rowsCount(rows) {
      return Array.isArray(rows) ? rows.length : 0;
    }
    function downloadSource() {
      const sourceId = String(document.getElementById("sourceSelect").value || "").trim();
      if (!sourceId || sourceId === "__all__") {
        document.getElementById("msg").textContent = "Select a specific source to download.";
        return;
      }
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      const href = `/api/coord/log-download?source_id=${encodeURIComponent(sourceId)}`;
      window.open(href, "_blank", "noopener,noreferrer");
    }
    hydrateTokenFromCookie();
    document.getElementById("token").addEventListener("change", persistTokenCookie);
    document.getElementById("token").addEventListener("blur", persistTokenCookie);
    document.getElementById("sourceSelect").addEventListener("change", () => { saveSelectedSource(document.getElementById("sourceSelect").value); loadEvents({ useCacheFirst: true }); });
    document.getElementById("searchText").addEventListener("keydown", (e) => { if (e.key === "Enter") loadEvents({ useCacheFirst: true }); });
    document.getElementById("severityFilter").addEventListener("change", () => loadEvents({ useCacheFirst: true }));
    document.getElementById("machineFilter").addEventListener("keydown", (e) => { if (e.key === "Enter") loadEvents({ useCacheFirst: true }); });
    document.getElementById("sortKey").addEventListener("change", () => loadEvents({ useCacheFirst: true }));
    document.getElementById("sortDir").addEventListener("change", () => loadEvents({ useCacheFirst: true }));
    document.addEventListener("dblclick", async (event) => {
      const origin = event ? event.target : null;
      const target = origin instanceof Element ? origin.closest(".copyable-cell") : null;
      if (!target) return;
      const text = String(target.textContent || "");
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        document.getElementById("msg").textContent = "Copied full cell text.";
      } catch (_e) {
        document.getElementById("msg").textContent = "Copy failed.";
      }
    });
    (async () => {
      await refreshSources(false, { useCacheFirst: true });
      await loadEvents({ useCacheFirst: true });
      await runDiagnostics(false);
    })();
    setInterval(() => {
      if (autoRefreshInFlight) return;
      autoRefreshInFlight = true;
      (async () => {
        await refreshSources(false);
        await loadEvents();
        await runDiagnostics(false);
      })()
        .catch(() => {})
        .finally(() => {
          autoRefreshInFlight = false;
        });
    }, 30000);
  </script>
</body>
</html>
