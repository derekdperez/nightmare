
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Fuzzing</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f8fafc; color: #0f172a; }
    h1 { margin-bottom: 8px; }
    .meta { margin-bottom: 12px; color: #475569; font-size: 13px; }
    .toolbar { display: flex; gap: 8px; align-items: center; margin: 10px 0 14px; flex-wrap: wrap; }
    input, select { padding: 6px 8px; border: 1px solid #94a3b8; border-radius: 6px; }
    button { border: 1px solid #94a3b8; background: #fff; border-radius: 6px; padding: 6px 10px; cursor: pointer; }
    button.primary { background: #0ea5e9; border-color: #0284c7; color: #fff; }
    button:disabled { opacity: 0.55; cursor: default; }
    .cards { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-bottom: 14px; }
    .card { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .k { font-size: 12px; color: #64748b; }
    .v { font-size: 20px; font-weight: 700; margin-top: 4px; word-break: break-word; }
    .muted { color: #64748b; }
    .panel { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; margin-bottom: 14px; }
    .table-wrap { max-height: 680px; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; }
    table { width: max-content; min-width: 1450px; border-collapse: collapse; background: #fff; border: 0; table-layout: fixed; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; font-size: 12px; text-align: left; vertical-align: top; }
    th { background: #e2e8f0; cursor: pointer; user-select: none; position: sticky; top: 0; z-index: 6; }
    .sort-ind { color: #0f172a; font-weight: 700; margin-left: 4px; }
    .col-url { width: 420px; max-width: 420px; word-break: break-all; }
    .col-parameter { width: 140px; max-width: 140px; }
    .col-payload { width: 320px; max-width: 320px; word-break: break-all; }
    .col-code { width: 90px; max-width: 90px; }
    .col-actions { width: 260px; max-width: 260px; }
    .col-size-diff { width: 140px; max-width: 140px; }
    .col-time-diff { width: 140px; max-width: 140px; }
    .col-notes { width: 200px; max-width: 200px; }
    .mini-btn { padding: 4px 8px; font-size: 12px; }
    .diff-pos { color: #15803d; font-weight: 700; }
    .diff-neg { color: #b91c1c; font-weight: 700; }
    .modal-backdrop { position: fixed; inset: 0; background: rgba(2, 6, 23, 0.55); display: none; align-items: center; justify-content: center; z-index: 50; }
    .modal-backdrop.open { display: flex; }
    .modal-window { width: 94vw; height: 90vh; max-width: 1700px; background: #fff; border: 1px solid #94a3b8; border-radius: 10px; box-shadow: 0 12px 28px rgba(15, 23, 42, 0.28); display: flex; flex-direction: column; overflow: hidden; }
    .modal-head { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; border-bottom: 1px solid #cbd5e1; background: #e2e8f0; gap: 12px; }
    .modal-title { font-weight: 700; }
    .modal-body { flex: 1; min-height: 0; padding: 10px; overflow: auto; display: flex; flex-direction: column; gap: 10px; }
    .stack-box { display: flex; flex-direction: column; gap: 6px; min-height: 0; }
    .stack-box textarea { width: 100%; resize: none; border: 1px solid #cbd5e1; border-radius: 6px; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12px; padding: 8px; background: #f8fafc; color: #0f172a; min-height: 210px; overflow: auto; }
    .diff-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; height: 100%; min-height: 0; }
    .diff-pane { display: flex; flex-direction: column; border: 1px solid #cbd5e1; border-radius: 6px; min-height: 0; overflow: hidden; background: #fff; }
    .diff-pane h4 { margin: 0; padding: 8px; border-bottom: 1px solid #cbd5e1; background: #f1f5f9; font-size: 13px; }
    .diff-scroll { flex: 1; min-height: 0; overflow: auto; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12px; line-height: 1.35; background: #f8fafc; }
    .diff-line { white-space: pre-wrap; word-break: break-word; padding: 0 8px; border-bottom: 1px solid #e2e8f0; }
    .diff-line.same { background: #f8fafc; }
    .diff-line.changed { background: #fef3c7; }
    .diff-line.added { background: #dcfce7; }
    .diff-line.removed { background: #fee2e2; }
    .diff-line.pad { background: #f1f5f9; color: #94a3b8; }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <h1>Fuzzing</h1>
  <div class="meta">Fozzy run findings from coordinator artifacts (anomalies + reflections).</div>
  <div class="toolbar">
    <input id="token" type="password" placeholder="Coordinator token">
    <select id="domainSelect" style="min-width: 320px;"></select>
    <input id="searchText" type="text" placeholder="Global search">
    <input id="limit" type="number" min="1" max="2000" value="250" title="Rows per page">
    <button class="primary" onclick="refreshDomainsAndRows()">Refresh</button>
    <a id="downloadZip" href="#" target="_blank" rel="noopener noreferrer"><button type="button">Download Results Zip</button></a>
    <span id="msg" class="muted"></span>
  </div>
  <div id="cards" class="cards"></div>
  <div class="panel">
    <div class="table-wrap">
      <table id="findingsTable">
        <thead>
          <tr>
            <th data-key="url" data-col-key="url" class="col-url">URL <span class="sort-ind" id="sort_url"></span></th>
            <th data-key="mutated_parameter" data-col-key="mutated_parameter" class="col-parameter">Parameter <span class="sort-ind" id="sort_mutated_parameter"></span></th>
            <th data-key="mutated_value" data-col-key="mutated_value" class="col-payload">Payload <span class="sort-ind" id="sort_mutated_value"></span></th>
            <th data-key="new_status" data-col-key="new_status" class="col-code">Code <span class="sort-ind" id="sort_new_status"></span></th>
            <th data-col-key="response_actions" class="col-actions">Full Response | Diff</th>
            <th data-key="size_difference" data-col-key="size_difference" class="col-size-diff">Size Diff (bytes) <span class="sort-ind" id="sort_size_difference"></span></th>
            <th data-key="duration_difference_ms" data-col-key="duration_difference_ms" class="col-time-diff">Time Diff (ms) <span class="sort-ind" id="sort_duration_difference_ms"></span></th>
            <th data-col-key="notes_placeholder" class="col-notes">Notes</th>
          </tr>
        </thead>
        <tbody id="rows"><tr><td colspan="8">Loading...</td></tr></tbody>
      </table>
    </div>
  </div>
  <div class="modal-backdrop" id="responseModal">
    <div class="modal-window">
      <div class="modal-head">
        <div class="modal-title" id="responseModalTitle">Response</div>
        <button type="button" id="responseModalCloseBtn">Close</button>
      </div>
      <div class="modal-body">
        <div class="stack-box"><strong>Headers</strong><textarea id="responseHeadersBox" readonly></textarea></div>
        <div class="stack-box"><strong>Body</strong><textarea id="responseBodyBox" readonly></textarea></div>
      </div>
    </div>
  </div>
  <div class="modal-backdrop" id="diffModal">
    <div class="modal-window">
      <div class="modal-head">
        <div class="modal-title" id="diffModalTitle">Baseline vs Fuzzing Diff</div>
        <button type="button" id="diffModalCloseBtn">Close</button>
      </div>
      <div class="modal-body">
        <div class="diff-layout">
          <section class="diff-pane"><h4>Baseline</h4><div id="diffLeft" class="diff-scroll"></div></section>
          <section class="diff-pane"><h4>Fuzzing</h4><div id="diffRight" class="diff-scroll"></div></section>
        </div>
      </div>
    </div>
  </div>
  {% include '_grid_controls.html.j2' %}
  <script>
    const TOKEN_COOKIE_NAME = "nightmare_coord_token";
    const DEFAULT_LIMIT = 250;
    const FUZZING_DOMAINS_CACHE_KEY = "nightmare_fuzzing_domains_cache_v1";
    const FUZZING_ROWS_CACHE_PREFIX = "nightmare_fuzzing_rows_cache_v1";
    const FUZZING_DOMAINS_CACHE_TTL_MS = 10 * 60 * 1000;
    const FUZZING_ROWS_CACHE_TTL_MS = 2 * 60 * 1000;
    const DEFAULT_COLUMN_WIDTHS = { url: 420, mutated_parameter: 140, mutated_value: 320, new_status: 90, response_actions: 260, size_difference: 140, duration_difference_ms: 140, notes_placeholder: 200 };
    let debounceHandle = null;
    let currentRows = [];
    let currentOffset = 0;
    let sortKey = "size_difference";
    let sortDir = "desc";
    let fuzzingGridCtrl = null;
    const resultPayloadCache = new Map();

    function readCookie(name) { const needle = `${name}=`; const cookies = String(document.cookie || "").split(";"); for (const part of cookies) { const item = part.trim(); if (item.startsWith(needle)) return decodeURIComponent(item.slice(needle.length)); } return ""; }
    function writeCookie(name, value, days) { const maxAge = Math.max(1, Number(days || 30)) * 24 * 60 * 60; const secure = location.protocol === "https:" ? "; Secure" : ""; document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`; }
    function deleteCookie(name) { const secure = location.protocol === "https:" ? "; Secure" : ""; document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`; }
    function persistTokenCookie() { const token = document.getElementById("token").value.trim(); if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30); else deleteCookie(TOKEN_COOKIE_NAME); }
    function hydrateTokenFromCookie() { const token = readCookie(TOKEN_COOKIE_NAME); if (token) document.getElementById("token").value = token; }
    function esc(v) { return String(v ?? "").replace(/[&<>\"']/g, (ch) => ({ "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;" }[ch])); }
    function authHeaders() { const token = document.getElementById("token").value.trim(); if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30); return token ? { Authorization: `Bearer ${token}` } : {}; }
    function readLocalJson(key) {
      try {
        const raw = localStorage.getItem(String(key || ""));
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : null;
      } catch (_e) {
        return null;
      }
    }
    function writeLocalJson(key, value) {
      try {
        localStorage.setItem(String(key || ""), JSON.stringify(value ?? {}));
      } catch (_e) {
        // Ignore cache write failures.
      }
    }
    function saveTimedCache(key, payload) {
      writeLocalJson(key, { cached_at_epoch_ms: Date.now(), payload: payload || {} });
    }
    function loadTimedCache(key, ttlMs) {
      const row = readLocalJson(key);
      if (!row) return null;
      const cachedAt = Number(row.cached_at_epoch_ms || 0);
      if (!Number.isFinite(cachedAt) || cachedAt <= 0) return null;
      if ((Date.now() - cachedAt) > Math.max(1000, Number(ttlMs || 0))) return null;
      const payload = row.payload;
      return payload && typeof payload === "object" ? payload : null;
    }
    function loadCachedFuzzDomains() {
      const payload = loadTimedCache(FUZZING_DOMAINS_CACHE_KEY, FUZZING_DOMAINS_CACHE_TTL_MS);
      return payload && Array.isArray(payload.domains) ? payload : null;
    }
    function saveCachedFuzzDomains(payload) {
      saveTimedCache(FUZZING_DOMAINS_CACHE_KEY, payload);
    }
    function loadCachedFuzzRows(cacheKey) {
      return loadTimedCache(`${FUZZING_ROWS_CACHE_PREFIX}:${cacheKey}`, FUZZING_ROWS_CACHE_TTL_MS);
    }
    function saveCachedFuzzRows(cacheKey, payload) {
      saveTimedCache(`${FUZZING_ROWS_CACHE_PREFIX}:${cacheKey}`, payload);
    }
    async function apiGet(path) { const rsp = await fetch(path, { cache: "no-store", headers: authHeaders() }); if (!rsp.ok) throw new Error(await rsp.text()); const ct = String(rsp.headers.get("content-type") || ""); if (ct.includes("application/json")) return rsp.json(); return rsp.text(); }

    function selectedDomain() { return String(document.getElementById("domainSelect").value || "__all__"); }
    function updateDownloadLink() {
      const domain = selectedDomain();
      const link = document.getElementById("downloadZip");
      if (!domain || domain === "__all__") { link.style.pointerEvents = "none"; link.style.opacity = "0.5"; link.href = "#"; return; }
      link.href = `/api/coord/fuzzing/download?artifact_type=fozzy_results_zip&root_domain=${encodeURIComponent(domain)}`;
      link.style.pointerEvents = "auto"; link.style.opacity = "1";
    }
    function setSortIndicators() { document.querySelectorAll("[id^='sort_']").forEach((el) => { el.textContent = ""; }); const node = document.getElementById(`sort_${sortKey}`); if (node) node.textContent = sortDir === "asc" ? "^" : "v"; }
    function renderCards(payload) {
      const counts = payload.counts || {};
      const page = Math.floor((Number(payload.offset || 0)) / Math.max(1, Number(payload.limit || DEFAULT_LIMIT))) + 1;
      const cards = [["Domain", payload.root_domain || "__all__"], ["Page", page], ["Page Size", payload.limit || DEFAULT_LIMIT], ["Rows (Page)", payload.rows_returned || 0], ["Rows (Filtered)", payload.total_rows || 0], ["Anomalies", counts.filtered_anomalies || 0], ["Reflections", counts.filtered_reflections || 0]];
      document.getElementById("cards").innerHTML = cards.map(([k,v]) => `<div class="card"><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`).join("");
    }
    function formatSignedInt(value) { const n = Number(value || 0); if (!Number.isFinite(n) || n === 0) return { text: "0", cls: "" }; return { text: (n > 0 ? `+${Math.round(n)}` : String(Math.round(n))), cls: n > 0 ? "diff-pos" : "diff-neg" }; }

    function scheduleLoad(resetOffset = true) { if (debounceHandle) clearTimeout(debounceHandle); debounceHandle = setTimeout(() => { debounceHandle = null; if (resetOffset) currentOffset = 0; loadRows(); }, 220); }

    function renderRows(rows) {
      if (!rows.length) { document.getElementById("rows").innerHTML = "<tr><td colspan='8'>No findings found.</td></tr>"; return; }
      document.getElementById("rows").innerHTML = rows.map((r, idx) => {
        const sizeDiff = formatSignedInt(r.size_difference || 0);
        const timeDiff = formatSignedInt(r.duration_difference_ms || 0);
        return `<tr>
          <td data-col-key="url" class="col-url">${esc(r.url || "")}</td>
          <td data-col-key="mutated_parameter" class="col-parameter">${esc(r.mutated_parameter || "")}</td>
          <td data-col-key="mutated_value" class="col-payload">${esc(r.mutated_value || "")}</td>
          <td data-col-key="new_status" class="col-code">${esc(r.new_status || 0)}</td>
          <td data-col-key="response_actions" class="col-actions"><button type="button" class="mini-btn view-response-btn" data-row-index="${idx}">View Response</button> | <button type="button" class="mini-btn view-diff-btn" data-row-index="${idx}">View Diff</button></td>
          <td data-col-key="size_difference" class="col-size-diff"><span class="${sizeDiff.cls}">${esc(sizeDiff.text)}</span></td>
          <td data-col-key="duration_difference_ms" class="col-time-diff"><span class="${timeDiff.cls}">${esc(timeDiff.text)}</span></td>
          <td data-col-key="notes_placeholder" class="col-notes"></td>
        </tr>`;
      }).join("");
      if (!fuzzingGridCtrl) {
        fuzzingGridCtrl = window.NightmareGridControls.enhance({
          table: "findingsTable",
          page: "fuzzing",
          prefKey: "fuzzing_findings_table_v1",
          tokenInputId: "token",
          mode: "columnsOnly",
          allowReorder: true,
          minColumnWidth: 80,
          maxColumnWidth: 1600,
          defaultWidths: DEFAULT_COLUMN_WIDTHS,
        });
      } else {
        fuzzingGridCtrl.refresh();
      }
    }
    function applyDomainsPayload(payload) {
      const domains = Array.isArray(payload.domains) ? payload.domains : [];
      const select = document.getElementById("domainSelect");
      const current = String(select.value || "__all__");
      select.innerHTML = `<option value="__all__">All domains (${esc(domains.length)} domains)</option>` + domains.map((d) => `<option value="${esc(d.root_domain)}">${esc(d.root_domain)} (A:${esc(d.anomalies || 0)} R:${esc(d.reflections || 0)})</option>`).join("");
      if ([...select.options].some((o) => o.value === current)) select.value = current;
      updateDownloadLink();
    }
    async function loadDomains(options) {
      const useCacheFirst = Boolean(options && options.useCacheFirst);
      let showedCached = false;
      if (useCacheFirst) {
        const cached = loadCachedFuzzDomains();
        if (cached) {
          applyDomainsPayload(cached);
          showedCached = true;
        }
      }
      try {
        const payload = await apiGet("/api/coord/fuzzing/domains?limit=20000");
        applyDomainsPayload(payload);
        saveCachedFuzzDomains(payload);
      } catch (e) {
        if (!showedCached) throw e;
      }
    }
    function buildRowsRequest() {
      const domain = selectedDomain();
      const q = String(document.getElementById("searchText").value || "").trim();
      const limit = Math.max(1, Math.min(2000, Number(document.getElementById("limit").value || DEFAULT_LIMIT)));
      const params = new URLSearchParams();
      params.set("limit", String(limit));
      params.set("offset", String(Math.max(0, currentOffset)));
      params.set("sort_key", sortKey);
      params.set("sort_dir", sortDir);
      if (domain && domain !== "__all__") params.set("root_domain", domain);
      if (q) params.set("q", q);
      return {
        path: `/api/coord/fuzzing?${params.toString()}`,
        cacheKey: JSON.stringify({
          domain,
          q,
          limit,
          offset: Math.max(0, currentOffset),
          sort_key: sortKey,
          sort_dir: sortDir,
        }),
      };
    }
    function applyRowsPayload(payload) {
      currentRows = Array.isArray(payload.rows) ? payload.rows : [];
      currentOffset = Number(payload.offset || 0);
      renderCards(payload);
      renderRows(currentRows);
      setSortIndicators();
    }
    function rowsCount(rows) {
      return Array.isArray(rows) ? rows.length : 0;
    }
    async function loadRows(options) {
      const msg = document.getElementById("msg");
      const useCacheFirst = Boolean(options && options.useCacheFirst);
      const request = buildRowsRequest();
      let showedCached = false;
      if (useCacheFirst) {
        const cached = loadCachedFuzzRows(request.cacheKey);
        if (cached) {
          applyRowsPayload(cached);
          msg.textContent = `Loaded ${cached.rows_returned || rowsCount(cached.rows)} cached row(s). Refreshing...`;
          showedCached = true;
        }
      }
      if (!showedCached) msg.textContent = "Loading...";
      try {
        const payload = await apiGet(request.path);
        applyRowsPayload(payload);
        saveCachedFuzzRows(request.cacheKey, payload);
        msg.textContent = `Loaded ${payload.rows_returned || 0} row(s) from offset ${payload.offset || 0}.`;
      } catch (e) {
        if (!showedCached) {
          document.getElementById("rows").innerHTML = `<tr><td colspan='8'>Failed to load fuzzing results: ${esc(e.message)}</td></tr>`;
          msg.textContent = "Load failed.";
        } else {
          msg.textContent = "Refresh failed. Showing cached fuzzing data.";
        }
      }
    }
    async function refreshDomainsAndRows(options) { try { await loadDomains(options); } catch (_) {} currentOffset = 0; await loadRows(options); }

    function normalizeResponseRecord(payload) {
      const baseline = (payload && typeof payload.baseline === "object" && payload.baseline) ? payload.baseline : {};
      let fuzzing = (payload && typeof payload.anomaly === "object" && payload.anomaly) ? payload.anomaly : {};
      if (!fuzzing || !Object.keys(fuzzing).length) fuzzing = (payload && typeof payload.response === "object" && payload.response) ? payload.response : {};
      return { baseline, fuzzing };
    }
    function _headerLinesFromAny(rawHeaders) {
      if (!rawHeaders) return [];
      if (typeof rawHeaders === "object" && !Array.isArray(rawHeaders)) {
        return Object.entries(rawHeaders).map(([k, v]) => {
          if (Array.isArray(v)) return `${String(k)}: ${v.map((item) => String(item ?? "")).join(", ")}`;
          return `${String(k)}: ${String(v ?? "")}`;
        });
      }
      if (Array.isArray(rawHeaders)) {
        const lines = [];
        for (const item of rawHeaders) {
          if (Array.isArray(item) && item.length >= 2) {
            lines.push(`${String(item[0])}: ${String(item[1] ?? "")}`);
            continue;
          }
          if (item && typeof item === "object") {
            const key = item.name ?? item.key ?? item.header ?? "";
            const value = item.value ?? item.val ?? "";
            if (String(key).trim()) {
              lines.push(`${String(key)}: ${String(value ?? "")}`);
              continue;
            }
          }
          const rawLine = String(item ?? "");
          if (rawLine.includes(":")) lines.push(rawLine);
        }
        return lines;
      }
      return [];
    }
    function formatHeadersText(responseObj) {
      if (!responseObj || typeof responseObj !== "object") return "";
      const candidateKeys = ["response_headers", "headers", "responseHeaders", "header_map", "headerMap"];
      for (const key of candidateKeys) {
        const lines = _headerLinesFromAny(responseObj[key]);
        if (lines.length) return lines.join("\n");
      }
      const names = Array.isArray(responseObj.response_header_names) ? responseObj.response_header_names : [];
      if (names.length) return names.map((name) => `${String(name)}: [value unavailable]`).join("\n");
      return "";
    }
    function formatBodyText(responseObj) { if (!responseObj || typeof responseObj !== "object") return ""; return String(responseObj.body_preview || ""); }
    async function fetchResultPayloadForRow(row) {
      const domain = String(row.root_domain || "").trim().toLowerCase(); const resultPath = String(row.result_file || "").trim();
      if (!domain || !resultPath) throw new Error("result file metadata missing");
      const cacheKey = `${domain}::${resultPath}`; if (resultPayloadCache.has(cacheKey)) return resultPayloadCache.get(cacheKey);
      const data = await apiGet(`/api/coord/fuzzing/file?root_domain=${encodeURIComponent(domain)}&path=${encodeURIComponent(resultPath)}`);
      let payload = data; if (typeof data === "string") { try { payload = JSON.parse(data); } catch { payload = {}; } }
      if (!payload || typeof payload !== "object") payload = {};
      resultPayloadCache.set(cacheKey, payload);
      return payload;
    }
    function openResponseModal(title, headersText, bodyText) {
      document.getElementById("responseModalTitle").textContent = title;
      document.getElementById("responseHeadersBox").value = headersText;
      document.getElementById("responseBodyBox").value = bodyText;
      document.getElementById("responseModal").classList.add("open");
    }
    function closeResponseModal() { document.getElementById("responseModal").classList.remove("open"); }
    function renderDiffLines(leftText, rightText) {
      const a = String(leftText || "").split("\n");
      const b = String(rightText || "").split("\n");
      const outA = []; const outB = []; let i = 0; let j = 0;
      while (i < a.length || j < b.length) {
        const left = i < a.length ? a[i] : null;
        const right = j < b.length ? b[j] : null;
        if (left !== null && right !== null && left === right) { outA.push({ text: left, cls: "same" }); outB.push({ text: right, cls: "same" }); i += 1; j += 1; continue; }
        const nextLeftInB = left === null ? -1 : b.indexOf(left, j + 1);
        const nextRightInA = right === null ? -1 : a.indexOf(right, i + 1);
        if (right !== null && (nextLeftInB === -1 || (nextRightInA !== -1 && (nextRightInA - i) < (nextLeftInB - j)))) { outA.push({ text: "", cls: "pad" }); outB.push({ text: right, cls: "added" }); j += 1; continue; }
        if (left !== null && (nextRightInA === -1 || (nextLeftInB !== -1 && (nextLeftInB - j) < (nextRightInA - i)))) { outA.push({ text: left, cls: "removed" }); outB.push({ text: "", cls: "pad" }); i += 1; continue; }
        outA.push({ text: left ?? "", cls: "changed" }); outB.push({ text: right ?? "", cls: "changed" });
        i += left === null ? 0 : 1; j += right === null ? 0 : 1;
      }
      return { outA, outB };
    }
    function renderDiffPane(node, lines) { node.innerHTML = lines.map((line) => `<div class="diff-line ${line.cls}">${esc(line.text)}</div>`).join(""); }
    function enableSyncedScroll(leftEl, rightEl) {
      let syncing = false;
      function sync(source, target) {
        if (syncing) return;
        syncing = true;
        const sourceRange = Math.max(1, source.scrollHeight - source.clientHeight);
        const ratio = source.scrollTop / sourceRange;
        const targetRange = Math.max(1, target.scrollHeight - target.clientHeight);
        target.scrollTop = ratio * targetRange;
        syncing = false;
      }
      leftEl.onscroll = () => sync(leftEl, rightEl);
      rightEl.onscroll = () => sync(rightEl, leftEl);
    }
    function openDiffModal(title, leftText, rightText) {
      document.getElementById("diffModalTitle").textContent = title;
      const leftNode = document.getElementById("diffLeft");
      const rightNode = document.getElementById("diffRight");
      const diff = renderDiffLines(leftText, rightText);
      renderDiffPane(leftNode, diff.outA);
      renderDiffPane(rightNode, diff.outB);
      enableSyncedScroll(leftNode, rightNode);
      leftNode.scrollTop = 0; rightNode.scrollTop = 0;
      document.getElementById("diffModal").classList.add("open");
    }
    function closeDiffModal() { document.getElementById("diffModal").classList.remove("open"); }

    async function handleViewResponse(rowIndex) {
      const row = currentRows[rowIndex]; if (!row) return;
      const title = `Response: ${String(row.url || "")}`;
      try {
        const payload = await fetchResultPayloadForRow(row);
        const rec = normalizeResponseRecord(payload);
        openResponseModal(title, formatHeadersText(rec.fuzzing), formatBodyText(rec.fuzzing));
      } catch (err) {
        openResponseModal(title, "", `Failed to load response: ${String((err && err.message) || err || "unknown error")}`);
      }
    }
    async function handleViewDiff(rowIndex) {
      const row = currentRows[rowIndex]; if (!row) return;
      const title = `Diff: ${String(row.url || "")}`;
      try {
        const payload = await fetchResultPayloadForRow(row);
        const rec = normalizeResponseRecord(payload);
        const leftText = `Headers\n${formatHeadersText(rec.baseline)}\n\nBody\n${formatBodyText(rec.baseline)}`;
        const rightText = `Headers\n${formatHeadersText(rec.fuzzing)}\n\nBody\n${formatBodyText(rec.fuzzing)}`;
        openDiffModal(title, leftText, rightText);
      } catch (err) {
        const failed = `Failed to load diff: ${String((err && err.message) || err || "unknown error")}`;
        openDiffModal(title, failed, failed);
      }
    }

    hydrateTokenFromCookie();
    document.getElementById("token").addEventListener("change", persistTokenCookie);
    document.getElementById("token").addEventListener("blur", persistTokenCookie);
    document.getElementById("domainSelect").addEventListener("change", () => { updateDownloadLink(); scheduleLoad(true); });
    document.getElementById("searchText").addEventListener("input", () => scheduleLoad(true));
    document.getElementById("limit").addEventListener("change", () => scheduleLoad(true));
    document.querySelectorAll("th[data-key]").forEach((th) => {
      th.addEventListener("click", () => {
        const key = String(th.getAttribute("data-key") || "");
        if (!key) return;
        if (sortKey === key) sortDir = sortDir === "asc" ? "desc" : "asc";
        else { sortKey = key; sortDir = (key === "new_status" || key === "size_difference" || key === "duration_difference_ms") ? "desc" : "asc"; }
        scheduleLoad(true);
      });
    });
    document.getElementById("rows").addEventListener("click", (ev) => {
      const responseBtn = ev.target.closest(".view-response-btn");
      if (responseBtn) { const idx = Number(responseBtn.getAttribute("data-row-index") || "-1"); if (idx >= 0) handleViewResponse(idx); return; }
      const diffBtn = ev.target.closest(".view-diff-btn");
      if (diffBtn) { const idx = Number(diffBtn.getAttribute("data-row-index") || "-1"); if (idx >= 0) handleViewDiff(idx); }
    });
    document.getElementById("responseModalCloseBtn").addEventListener("click", closeResponseModal);
    document.getElementById("diffModalCloseBtn").addEventListener("click", closeDiffModal);
    document.getElementById("responseModal").addEventListener("click", (ev) => { if (ev.target === document.getElementById("responseModal")) closeResponseModal(); });
    document.getElementById("diffModal").addEventListener("click", (ev) => { if (ev.target === document.getElementById("diffModal")) closeDiffModal(); });
    setSortIndicators();
    refreshDomainsAndRows({ useCacheFirst: true });
  </script>
</body>
</html>
