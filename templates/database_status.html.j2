<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Database Status</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f8fafc; color: #0f172a; }
    h1 { margin-bottom: 8px; }
    .meta { margin-bottom: 12px; color: #475569; font-size: 13px; }
    .cards { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 14px; }
    .card { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .k { font-size: 12px; color: #64748b; }
    .v { font-size: 18px; font-weight: 700; margin-top: 4px; word-break: break-word; }
    .toolbar { display: flex; gap: 8px; align-items: center; margin: 10px 0 16px; flex-wrap: wrap; }
    input { padding: 6px 8px; border: 1px solid #94a3b8; border-radius: 6px; min-width: 340px; }
    button { border: 1px solid #94a3b8; background: #fff; border-radius: 6px; padding: 6px 10px; cursor: pointer; }
    button.primary { background: #0ea5e9; border-color: #0284c7; color: white; }
    .muted { color: #64748b; }
    .tableCard { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; margin-bottom: 16px; overflow: hidden; }
    .tableHead { padding: 10px 12px; border-bottom: 1px solid #cbd5e1; background: #e2e8f0; }
    .tableBody { padding: 10px 12px; }
    .table-wrap { max-height: 520px; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; margin-top: 10px; }
    table { width: 100%; border-collapse: collapse; background: #fff; border: 0; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; font-size: 12px; vertical-align: top; text-align: left; }
    th { background: #f1f5f9; position: sticky; top: 0; z-index: 3; }
    pre { white-space: pre-wrap; word-break: break-word; margin: 0; font-size: 12px; }
    .empty { padding: 12px; background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; }
  </style>
</head>
<body>
  <h1>Database Status</h1>
  <div class="meta">Shows current PostgreSQL status, all non-system tables, exact row counts, and up to the 20 most recent rows per table. <a href="/dashboard">Dashboard</a> | <a href="/workers">Workers</a> | <a href="/crawl-progress">Crawl Progress</a> | <a href="/extractor-matches">Extractor Matches</a> | <a href="/fuzzing">Fuzzing</a> | <a href="/docker-status">Docker Status</a> | <a href="/view-logs">View Logs</a></div>
  <div class="toolbar">
    <input id="token" type="password" placeholder="Coordinator token">
    <button class="primary" onclick="refresh()">Refresh</button>
    <span id="msg" class="muted"></span>
  </div>
  <div id="cards" class="cards"></div>
  <div id="tables"><div class="empty">Loading...</div></div>
  {% include '_grid_controls.html.j2' %}
  <script>
    const TOKEN_COOKIE_NAME = "nightmare_coord_token";
    const DB_STATUS_CACHE_KEY = "nightmare_database_status_cache_v1";
    const DB_STATUS_CACHE_TTL_MS = 60 * 1000;
    const dbGridControllers = {};

    function readCookie(name) {
      const needle = `${name}=`;
      const cookies = String(document.cookie || "").split(";");
      for (const part of cookies) {
        const item = part.trim();
        if (item.startsWith(needle)) {
          return decodeURIComponent(item.slice(needle.length));
        }
      }
      return "";
    }
    function writeCookie(name, value, days) {
      const maxAge = Math.max(1, Number(days || 30)) * 24 * 60 * 60;
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`;
    }
    function deleteCookie(name) {
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`;
    }
    function persistTokenCookie() {
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      else deleteCookie(TOKEN_COOKIE_NAME);
    }
    function hydrateTokenFromCookie() {
      const token = readCookie(TOKEN_COOKIE_NAME);
      if (token) document.getElementById("token").value = token;
    }
    function esc(v) {
      return String(v ?? "").replace(/[&<>"']/g, (ch) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;"
      }[ch]));
    }
    function authHeaders() {
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      return token ? { Authorization: `Bearer ${token}` } : {};
    }
    function readLocalJson(key) {
      try {
        const raw = localStorage.getItem(String(key || ""));
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : null;
      } catch (_e) {
        return null;
      }
    }
    function writeLocalJson(key, value) {
      try {
        localStorage.setItem(String(key || ""), JSON.stringify(value ?? {}));
      } catch (_e) {
        // Ignore local cache write issues.
      }
    }
    function loadCachedDbStatus() {
      const row = readLocalJson(DB_STATUS_CACHE_KEY);
      if (!row) return null;
      const cachedAt = Number(row.cached_at_epoch_ms || 0);
      if (!Number.isFinite(cachedAt) || cachedAt <= 0) return null;
      if ((Date.now() - cachedAt) > DB_STATUS_CACHE_TTL_MS) return null;
      const payload = row.payload;
      return payload && typeof payload === "object" ? payload : null;
    }
    function saveCachedDbStatus(payload) {
      writeLocalJson(DB_STATUS_CACHE_KEY, {
        cached_at_epoch_ms: Date.now(),
        payload: payload || {},
      });
    }
    async function apiGet(path) {
      const rsp = await fetch(path, { cache: "no-store", headers: authHeaders() });
      if (!rsp.ok) throw new Error(await rsp.text());
      return rsp.json();
    }
    function renderCards(data) {
      const db = data.database || {};
      const cards = [
        ["Database", db.name || ""],
        ["User", db.current_user || ""],
        ["Server Time", db.server_time_utc || ""],
        ["Tables", data.table_count || 0],
        ["Rows / table", data.max_rows_per_table || 20],
      ];
      document.getElementById("cards").innerHTML = cards
        .map(([k, v]) => `<div class="card"><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`)
        .join("");
    }
    function renderValue(v) {
      if (v === null || v === undefined) return '<span class="muted">null</span>';
      if (typeof v === "object") return `<pre>${esc(JSON.stringify(v, null, 2))}</pre>`;
      return esc(v);
    }
    function renderTables(data) {
      const tables = data.tables || [];
      if (!tables.length) {
        document.getElementById("tables").innerHTML = '<div class="empty">No non-system tables found.</div>';
        return;
      }
      document.getElementById("tables").innerHTML = tables.map((t) => {
        const columns = (t.columns || [])
          .map((c) => `${esc(c.name)} <span class="muted">(${esc(c.data_type)}${c.nullable ? ", nullable" : ""})</span>`)
          .join("<br>");
        const rows = t.rows || [];
        const headerNames = (t.columns || []).map((c) => c.name);
        const domIdSafe = `db_${String(t.schema || "").replace(/[^a-zA-Z0-9_]+/g, "_")}_${String(t.name || "").replace(/[^a-zA-Z0-9_]+/g, "_")}`;
        const tableHtml = rows.length
          ? `
          <div class="table-wrap">
            <table class="dbDataTable" id="${esc(domIdSafe)}">
              <thead><tr>${headerNames.map((name) => `<th>${esc(name)}</th>`).join("")}</tr></thead>
              <tbody>
                ${rows.map((row) => `<tr>${headerNames.map((name) => `<td>${renderValue(row[name])}</td>`).join("")}</tr>`).join("")}
              </tbody>
            </table>
          </div>`
          : '<div class="empty">No rows.</div>';
        const tableError = String(t.table_error || "");
        const tableErrorHtml = tableError
          ? `<div class="empty" style="margin-top:10px;">Table query failed: ${esc(tableError)}</div>`
          : "";
        const returned = Number(t.rows_returned || rows.length || 0);
        const limitedLabel = t.rows_limited
          ? ` | showing first ${esc(returned)} row(s)`
          : "";
        return `<section class="tableCard">
          <div class="tableHead"><strong>${esc(t.schema)}.${esc(t.name)}</strong> | ${esc(t.row_count)} row(s)${limitedLabel}</div>
          <div class="tableBody">
            <div><strong>Columns</strong><br>${columns || '<span class="muted">none</span>'}</div>
            ${tableHtml}
            ${tableErrorHtml}
          </div>
        </section>`;
      }).join("");
      document.querySelectorAll("table.dbDataTable").forEach((table) => {
        const key = String(table.id || "db_table");
        if (!dbGridControllers[key]) {
          dbGridControllers[key] = window.NightmareGridControls.enhance({
            table,
            page: "database_status",
            prefKey: `${key}_v1`,
            tokenInputId: "token",
            mode: "full",
          });
        } else {
          dbGridControllers[key].refresh();
        }
      });
    }
    async function refresh(options) {
      const msg = document.getElementById("msg");
      const useCacheFirst = Boolean(options && options.useCacheFirst);
      let showedCached = false;
      if (useCacheFirst) {
        const cached = loadCachedDbStatus();
        if (cached) {
          renderCards(cached);
          renderTables(cached);
          msg.textContent = `Loaded ${cached.table_count || 0} cached table(s). Refreshing...`;
          showedCached = true;
        }
      }
      if (!showedCached) msg.textContent = "Loading...";
      try {
        const data = await apiGet("/api/coord/database-status");
        renderCards(data);
        renderTables(data);
        saveCachedDbStatus(data);
        msg.textContent = `Loaded ${data.table_count || 0} table(s).`;
      } catch (e) {
        if (!showedCached) {
          document.getElementById("tables").innerHTML = `<div class="empty">Failed to load database status: ${esc(e.message)}</div>`;
          msg.textContent = "Load failed.";
        } else {
          msg.textContent = "Refresh failed. Showing cached data.";
        }
      }
    }
    hydrateTokenFromCookie();
    document.getElementById("token").addEventListener("change", persistTokenCookie);
    document.getElementById("token").addEventListener("blur", persistTokenCookie);
    refresh({ useCacheFirst: true });
  </script>
</body>
</html>
