<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Workflows</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f8fafc; color: #0f172a; }
    h1 { margin-bottom: 8px; }
    .meta { margin-bottom: 12px; color: #475569; font-size: 13px; }
    .toolbar { display: flex; gap: 8px; align-items: center; margin: 10px 0 16px; flex-wrap: wrap; }
    input, select { padding: 6px 8px; border: 1px solid #94a3b8; border-radius: 6px; }
    input[type="text"], input[type="password"] { min-width: 180px; }
    button { border: 1px solid #94a3b8; background: #fff; border-radius: 6px; padding: 6px 10px; cursor: pointer; }
    button.primary { background: #0ea5e9; border-color: #0284c7; color: #fff; }
    button.warn { background: #dc2626; border-color: #b91c1c; color: #fff; }
    .cards { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-bottom: 14px; }
    .card { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .k { font-size: 12px; color: #64748b; }
    .v { font-size: 20px; font-weight: 700; margin-top: 4px; word-break: break-word; }
    .muted { color: #64748b; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    .status-pill { display: inline-flex; align-items: center; gap: 8px; border: 1px solid #cbd5e1; border-radius: 999px; padding: 5px 10px; font-size: 12px; font-weight: 600; background: #fff; color: #334155; }
    .status-dot { width: 9px; height: 9px; border-radius: 999px; background: #94a3b8; }
    .status-loading .status-dot { background: #0284c7; animation: pulse 1s ease-in-out infinite; }
    .status-success .status-dot { background: #16a34a; }
    .status-error .status-dot { background: #dc2626; }
    @keyframes pulse { 0%, 100% { transform: scale(0.8); opacity: 0.7; } 50% { transform: scale(1.2); opacity: 1; } }
    .layout { display: grid; gap: 12px; grid-template-columns: minmax(320px, 1fr) minmax(420px, 2fr); }
    .panel { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .panel h2 { margin: 0 0 10px; font-size: 16px; }
    .table-wrap { max-height: 62vh; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; }
    table { width: 100%; border-collapse: collapse; background: #fff; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; font-size: 12px; vertical-align: top; text-align: left; }
    th { background: #f1f5f9; position: sticky; top: 0; z-index: 2; }
    tr.selected { background: #ecfeff; }
    .badge { display: inline-flex; border: 1px solid #cbd5e1; border-radius: 999px; padding: 2px 8px; font-weight: 600; font-size: 11px; background: #fff; color: #334155; }
    .b-ready, .b-running { border-color: #38bdf8; color: #0369a1; background: #f0f9ff; }
    .b-completed { border-color: #86efac; color: #166534; background: #f0fdf4; }
    .b-failed { border-color: #fca5a5; color: #991b1b; background: #fef2f2; }
    .b-paused { border-color: #fcd34d; color: #92400e; background: #fffbeb; }
    .b-created, .b-canceled { border-color: #ddd6fe; color: #5b21b6; background: #f5f3ff; }
    .b-pending { border-color: #cbd5e1; color: #334155; background: #f8fafc; }
    .task-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .run-panel { display: grid; gap: 8px; grid-template-columns: 1.2fr 2fr auto auto; align-items: end; margin: 10px 0 14px; }
    .run-panel label { display: grid; gap: 4px; font-size: 12px; color: #475569; }
    .run-panel input[type="text"] { min-width: 220px; }
    .run-panel .check { display: flex; align-items: center; gap: 6px; padding-bottom: 7px; color: #334155; }
    .notice { border: 1px solid #bae6fd; background: #f0f9ff; color: #075985; border-radius: 8px; padding: 8px 10px; margin-bottom: 12px; font-size: 13px; }
    @media (max-width: 1200px) {
      .layout { grid-template-columns: 1fr; }
      .table-wrap { max-height: 42vh; }
    }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <h1>Workflow Monitor</h1>
  <div class="meta">Live view of workflow/plugin readiness and execution state. Auto-refresh every 30s.</div>

  <div class="cards">
    <div class="card"><div class="k">Visible Domains</div><div class="v" id="visibleDomains">0</div></div>
    <div class="card"><div class="k">Total Domains</div><div class="v" id="totalDomains">0</div></div>
    <div class="card"><div class="k">Visible Tasks</div><div class="v" id="visibleTasks">0</div></div>
    <div class="card"><div class="k">Running Tasks</div><div class="v" id="runningTasks">0</div></div>
    <div class="card"><div class="k">Ready Tasks</div><div class="v" id="readyTasks">0</div></div>
    <div class="card"><div class="k">Paused Tasks</div><div class="v" id="pausedTasks">0</div></div>
  </div>

  <div class="toolbar">
    <input id="token" type="password" placeholder="Coordinator token">
    <input id="searchDomain" type="text" placeholder="Filter domain">
    <input id="searchWorkflow" type="text" placeholder="Filter workflow">
    <input id="searchPlugin" type="text" placeholder="Filter plugin">
    <select id="statusFilter">
      <option value="">All statuses</option>
      <option value="created">created</option>
      <option value="pending">waiting</option>
      <option value="ready">ready</option>
      <option value="running">running</option>
      <option value="paused">paused</option>
      <option value="canceled">canceled</option>
      <option value="completed">completed</option>
      <option value="failed">failed</option>
    </select>
    <select id="limitSelect">
      <option value="250">250 domains</option>
      <option value="1000">1000 domains</option>
      <option value="2000">2000 domains</option>
      <option value="5000" selected>5000 domains</option>
    </select>
    <button class="primary" id="refreshButton">Refresh</button>
    <button class="warn" id="forceClaimButton">Force workers to claim</button>
    <button id="pauseButton">Pause</button>
    <span id="statusPill" class="status-pill"><span class="status-dot"></span><span id="statusText">Idle</span></span>
  </div>



  <div class="panel">
    <h2>Run Workflow</h2>
    <div class="notice">Launch a workflow for one or more root domains. Use “force ready” when you intentionally want workers to pick up tasks immediately, bypassing prerequisites.</div>
    <div class="run-panel">
      <label>Workflow ID
        <input id="runWorkflowId" type="text" value="run-recon" placeholder="run-recon">
      </label>
      <label>Root domains
        <input id="runRootDomains" type="text" placeholder="example.com, example.org">
      </label>
      <label class="check">
        <input id="runForceReady" type="checkbox">
        Force ready
      </label>
      <button class="primary" id="runWorkflowButton">Run Workflow</button>
    </div>
  </div>

  <div class="layout">    <section class="panel">
      <h2>Domains</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Domain</th>
              <th>Targets</th>
              <th>Artifacts</th>
              <th>Task States</th>
            </tr>
          </thead>
          <tbody id="domainRows">
            <tr><td colspan="4" class="muted">Loading domains...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 id="taskPanelTitle">Plugin Tasks</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Workflow</th>
              <th>Plugin</th>
              <th>Status</th>
              <th>Worker</th>
              <th>Updated</th>
              <th>Progress</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="taskRows">
            <tr><td colspan="8" class="muted">Select a domain to inspect plugin tasks.</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <section class="panel">
    <h2>Global Task Queue</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Domain</th>
            <th>Plugin/Stage</th>
            <th>Status</th>
            <th>Worker</th>
            <th>Attempts</th>
            <th>Updated</th>
            <th>Reason / Error</th>
          </tr>
        </thead>
        <tbody id="globalTaskRows">
          <tr><td colspan="8" class="muted">Loading task queue...</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <script>
    const TOKEN_COOKIE_NAME = "nightmare_coord_token";
    const state = { paused: false, timer: null, snapshot: null, selectedDomain: "", taskMonitor: null };

    function readCookie(name) {
      const needle = `${name}=`;
      const cookies = String(document.cookie || "").split(";");
      for (const part of cookies) {
        const item = part.trim();
        if (item.startsWith(needle)) return decodeURIComponent(item.slice(needle.length));
      }
      return "";
    }
    function writeCookie(name, value, days) {
      const maxAge = Math.max(1, Number(days || 30)) * 24 * 60 * 60;
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`;
    }
    function deleteCookie(name) {
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`;
    }
    function authHeaders() {
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      else deleteCookie(TOKEN_COOKIE_NAME);
      return token ? { Authorization: `Bearer ${token}` } : {};
    }
    function hydrateTokenFromCookie() {
      const token = readCookie(TOKEN_COOKIE_NAME);
      if (token) document.getElementById("token").value = token;
    }
    function setStatus(kind, text) {
      const pill = document.getElementById("statusPill");
      const label = document.getElementById("statusText");
      pill.className = "status-pill";
      if (kind) pill.classList.add(`status-${kind}`);
      label.textContent = text;
    }
    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }
    function statusLabel(status) {
      const value = String(status || "").trim().toLowerCase();
      if (value === "created") return "Created";
      if (value === "canceled") return "Canceled";
      if (value === "pending") return "Waiting for Prerequisites...";
      return value || "Waiting for Prerequisites...";
    }
    function badgeClass(status) {
      const value = String(status || "").trim().toLowerCase();
      if (value === "running") return "badge b-running";
      if (value === "completed") return "badge b-completed";
      if (value === "failed") return "badge b-failed";
      if (value === "ready") return "badge b-ready";
      if (value === "paused") return "badge b-paused";
      if (value === "created") return "badge b-created";
      if (value === "canceled") return "badge b-canceled";
      return "badge b-pending";
    }
    function formatStamp(value) {
      if (!value) return "";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return String(value);
      return date.toLocaleString();
    }
    function flattenTasks(domain) {
      const rows = [];
      const pluginTasks = domain && typeof domain === "object" && domain.plugin_tasks && typeof domain.plugin_tasks === "object"
        ? domain.plugin_tasks
        : {};
      for (const [workflowId, pluginMap] of Object.entries(pluginTasks)) {
        if (!pluginMap || typeof pluginMap !== "object") continue;
        for (const [pluginName, task] of Object.entries(pluginMap)) {
          if (!task || typeof task !== "object") continue;
          rows.push({
            workflow_id: String(workflowId || "default").toLowerCase(),
            plugin_name: String(pluginName || "").toLowerCase(),
            status: String(task.status || "").toLowerCase(),
            worker_id: String(task.worker_id || ""),
            updated_at_utc: task.updated_at_utc || task.heartbeat_at_utc || task.started_at_utc || "",
            completed_at_utc: task.completed_at_utc || "",
            progress: task.progress || {},
          });
        }
      }
      return rows;
    }
    function progressSummary(task) {
      const progress = task && typeof task.progress === "object" && task.progress ? task.progress : {};
      if (progress.status) return String(progress.status);
      if (progress.message) return String(progress.message);
      if (typeof progress.percent === "number") return `${Math.max(0, Math.min(100, Math.round(progress.percent)))}%`;
      if (task.error) return String(task.error).slice(0, 80);
      return "";
    }
    function filteredDomains() {
      const payload = state.snapshot || {};
      const all = Array.isArray(payload.domains) ? payload.domains : [];
      const domainFilter = document.getElementById("searchDomain").value.trim().toLowerCase();
      return all.filter((domain) => {
        const rootDomain = String(domain.root_domain || "").toLowerCase();
        if (!domainFilter) return true;
        return rootDomain.includes(domainFilter);
      });
    }
    function taskFiltersMatch(task) {
      const workflowFilter = document.getElementById("searchWorkflow").value.trim().toLowerCase();
      const pluginFilter = document.getElementById("searchPlugin").value.trim().toLowerCase();
      const statusFilter = document.getElementById("statusFilter").value.trim().toLowerCase();
      if (workflowFilter && !String(task.workflow_id || "").includes(workflowFilter)) return false;
      if (pluginFilter && !String(task.plugin_name || "").includes(pluginFilter)) return false;
      if (statusFilter && String(task.status || "") !== statusFilter) return false;
      return true;
    }
    function renderDomainRows(domains) {
      const body = document.getElementById("domainRows");
      if (!domains.length) {
        body.innerHTML = '<tr><td colspan="4" class="muted">No domains match the current filter.</td></tr>';
        return;
      }
      if (!state.selectedDomain || !domains.some((item) => String(item.root_domain || "") === state.selectedDomain)) {
        state.selectedDomain = String(domains[0].root_domain || "");
      }
      body.innerHTML = domains.map((domain) => {
        const root = String(domain.root_domain || "");
        const tasks = flattenTasks(domain).filter(taskFiltersMatch);
        const statuses = { created: 0, pending: 0, ready: 0, running: 0, paused: 0, canceled: 0, completed: 0, failed: 0 };
        for (const task of tasks) {
          const key = String(task.status || "").toLowerCase();
          if (Object.prototype.hasOwnProperty.call(statuses, key)) statuses[key] += 1;
        }
        const targetStats = domain.targets || {};
        const targetText = `p:${Number(targetStats.pending || 0)} r:${Number(targetStats.running || 0)} c:${Number(targetStats.completed || 0)} f:${Number(targetStats.failed || 0)}`;
        const statusText = `created:${statuses.created} waiting:${statuses.pending} ready:${statuses.ready} running:${statuses.running} paused:${statuses.paused} canceled:${statuses.canceled} completed:${statuses.completed} failed:${statuses.failed}`;
        const selectedClass = state.selectedDomain === root ? "selected" : "";
        return `
          <tr class="${selectedClass}" data-domain="${escapeHtml(root)}">
            <td class="mono">${escapeHtml(root)}</td>
            <td class="mono">${escapeHtml(targetText)}</td>
            <td>${Number(Array.isArray(domain.artifact_types) ? domain.artifact_types.length : 0)}</td>
            <td class="mono">${escapeHtml(statusText)}</td>
          </tr>
        `;
      }).join("");
      body.querySelectorAll("tr[data-domain]").forEach((row) => {
        row.addEventListener("click", () => {
          state.selectedDomain = String(row.getAttribute("data-domain") || "");
          renderAll();
        });
      });
    }
    async function controlTask(action, workflowId, rootDomain, pluginName) {
      const payload = {
        workflow_id: String(workflowId || "default").toLowerCase(),
        root_domain: String(rootDomain || "").toLowerCase(),
        stage: String(pluginName || "").toLowerCase(),
        action: String(action || "").toLowerCase(),
      };
      const rsp = await fetch("/api/coord/stage/control", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json", ...authHeaders() },
        body: JSON.stringify(payload),
      });
      const body = await rsp.json().catch(() => ({}));
      if (!rsp.ok) {
        throw new Error(String(body.error || body.detail || `HTTP ${rsp.status}`));
      }
      return body;
    }
    function renderTaskRows(domains) {
      const body = document.getElementById("taskRows");
      const selected = domains.find((domain) => String(domain.root_domain || "") === state.selectedDomain);
      if (!selected) {
        document.getElementById("taskPanelTitle").textContent = "Plugin Tasks";
        body.innerHTML = '<tr><td colspan="8" class="muted">Select a domain to inspect plugin tasks.</td></tr>';
        return;
      }
      const root = String(selected.root_domain || "");
      document.getElementById("taskPanelTitle").textContent = `Plugin Tasks: ${root}`;
      const tasks = flattenTasks(selected).filter(taskFiltersMatch);
      if (!tasks.length) {
        body.innerHTML = '<tr><td colspan="8" class="muted">No plugin tasks match filters for this domain.</td></tr>';
        return;
      }
      body.innerHTML = tasks.map((task) => `
        <tr>
          <td class="mono">${escapeHtml(task.workflow_id || "default")}</td>
          <td class="mono">${escapeHtml(task.plugin_name)}</td>
          <td><span class="${badgeClass(task.status)}">${escapeHtml(statusLabel(task.status))}</span></td>
          <td class="mono">${escapeHtml(task.worker_id || "")}</td>
          <td class="mono">${escapeHtml(formatStamp(task.updated_at_utc || task.completed_at_utc || ""))}</td>
          <td title="${escapeHtml(JSON.stringify(task.progress || {}))}">${escapeHtml(progressSummary(task))}</td>
          <td>
            <div class="task-actions">
              <button type="button" data-action="delete" data-workflow="${escapeHtml(task.workflow_id)}" data-root="${escapeHtml(root)}" data-plugin="${escapeHtml(task.plugin_name)}" class="warn">Delete</button>
              <button type="button" data-action="pause" data-workflow="${escapeHtml(task.workflow_id)}" data-root="${escapeHtml(root)}" data-plugin="${escapeHtml(task.plugin_name)}">Pause</button>
              <button type="button" data-action="run" data-workflow="${escapeHtml(task.workflow_id)}" data-root="${escapeHtml(root)}" data-plugin="${escapeHtml(task.plugin_name)}" class="primary">Run</button>
            </div>
          </td>
        </tr>
      `).join("");
      body.querySelectorAll("button[data-action]").forEach((button) => {
        button.addEventListener("click", async () => {
          const action = String(button.getAttribute("data-action") || "").toLowerCase();
          const workflow = String(button.getAttribute("data-workflow") || "default").toLowerCase();
          const domain = String(button.getAttribute("data-root") || "").toLowerCase();
          const plugin = String(button.getAttribute("data-plugin") || "").toLowerCase();
          if (action === "delete") {
            if (!window.confirm(`Delete task ${workflow}/${plugin} for ${domain}?`)) return;
          }
          if (action === "run") {
            if (!window.confirm(`Run task ${workflow}/${plugin} for ${domain} now and bypass prerequisites?`)) return;
          }
          try {
            setStatus("loading", `${action} ${plugin}...`);
            await controlTask(action, workflow, domain, plugin);
            await refreshAllData();
            setStatus("success", `${action} completed for ${plugin}.`);
          } catch (error) {
            setStatus("error", String(error && error.message ? error.message : error));
          }
        });
      });
    }
    function updateCards(domains) {
      const payload = state.snapshot || {};
      let visibleTaskCount = 0;
      let runningTaskCount = 0;
      let readyTaskCount = 0;
      let pausedTaskCount = 0;
      for (const domain of domains) {
        for (const task of flattenTasks(domain).filter(taskFiltersMatch)) {
          visibleTaskCount += 1;
          const status = String(task.status || "").toLowerCase();
          if (status === "running") runningTaskCount += 1;
          if (status === "ready") readyTaskCount += 1;
          if (status === "paused") pausedTaskCount += 1;
        }
      }
      document.getElementById("visibleDomains").textContent = String(domains.length);
      document.getElementById("totalDomains").textContent = String(Number(payload.domain_count || 0));
      document.getElementById("visibleTasks").textContent = String(visibleTaskCount);
      document.getElementById("runningTasks").textContent = String(runningTaskCount);
      document.getElementById("readyTasks").textContent = String(readyTaskCount);
      document.getElementById("pausedTasks").textContent = String(pausedTaskCount);
    }
    function renderAll() {
      const domains = filteredDomains();
      renderDomainRows(domains);
      renderTaskRows(domains);
      updateCards(domains);
    }
    async function fetchWorkflowSnapshotData() {
      const limit = Number(document.getElementById("limitSelect").value || 5000);
      const qs = new URLSearchParams({
        limit: String(Math.max(1, Math.min(5000, limit))),
        cache_mode: "refresh",
      });
      const response = await fetch(`/api/coord/workflow-snapshot?${qs.toString()}`, {
        credentials: "same-origin",
        headers: authHeaders(),
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(String(payload.error || `HTTP ${response.status}`));
      state.snapshot = payload;
    }
    async function fetchTaskMonitorData() {
      const rsp = await fetch("/api/coord/stage-tasks?limit=1000", {
        credentials: "same-origin",
        headers: authHeaders(),
      });
      const payload = await rsp.json().catch(() => ({}));
      if (!rsp.ok) throw new Error(String(payload.error || payload.detail || `HTTP ${rsp.status}`));
      state.taskMonitor = payload;
    }
    function renderGlobalTaskRows() {
      const body = document.getElementById("globalTaskRows");
      const payload = state.taskMonitor || {};
      const items = Array.isArray(payload.items) ? payload.items : [];
      if (!items.length) {
        body.innerHTML = '<tr><td colspan="8" class="muted">No stage tasks found.</td></tr>';
        return;
      }
      body.innerHTML = items.map((task) => `
        <tr>
          <td class="mono">${escapeHtml(task.workflow_id || "")}</td>
          <td class="mono">${escapeHtml(task.root_domain || "")}</td>
          <td class="mono">${escapeHtml(task.stage || "")}</td>
          <td><span class="${badgeClass(task.status)}">${escapeHtml(statusLabel(task.status))}</span></td>
          <td class="mono">${escapeHtml(task.worker_id || "")}</td>
          <td>${Number(task.attempt_count || 0)}</td>
          <td class="mono">${escapeHtml(formatStamp(task.updated_at_utc || task.heartbeat_at_utc || task.created_at_utc || ""))}</td>
          <td>${escapeHtml(task.error || "")}</td>
        </tr>
      `).join("");
    }
    async function forceWorkersToClaimNow() {
      const button = document.getElementById("forceClaimButton");
      button.disabled = true;
      try {
        setStatus("loading", "Forcing workers to claim...");
        const rsp = await fetch("/api/coord/workers/force-claim", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json", ...authHeaders() },
          body: JSON.stringify({ lease_seconds: 60 }),
        });
        const payload = await rsp.json().catch(() => ({}));
        if (!rsp.ok) throw new Error(String(payload.error || payload.detail || `HTTP ${rsp.status}`));
        await refreshAllData();
        setStatus(
          "success",
          `Force claim complete: ${Number(payload.claimed_total || 0)} claimed, ${Number(payload.workers_considered || 0)} workers checked.`
        );
      } catch (error) {
        setStatus("error", String(error && error.message ? error.message : error));
      } finally {
        button.disabled = false;
      }
    }
    async function refreshAllData() {
      if (state.paused) return;
      setStatus("loading", "Refreshing...");
      try {
        await Promise.all([fetchWorkflowSnapshotData(), fetchTaskMonitorData()]);
        renderAll();
        renderGlobalTaskRows();
        setStatus("success", `Live at ${new Date().toLocaleTimeString()}`);
      } catch (error) {
        setStatus("error", String(error && error.message ? error.message : error));
      }
    }
    function scheduleRefresh() {
      if (state.timer) clearInterval(state.timer);
      state.timer = setInterval(refreshAllData, 30000);
    }

    async function runWorkflowNow() {
      const workflowId = document.getElementById("runWorkflowId").value.trim() || "run-recon";
      const rootDomains = document.getElementById("runRootDomains").value
        .split(/[,\n]/)
        .map((item) => item.trim().toLowerCase())
        .filter(Boolean);
      if (!rootDomains.length) {
        setStatus("error", "Enter at least one root domain to run.");
        return;
      }
      const forceRun = document.getElementById("runForceReady").checked;
      const payload = {
        workflow_id: workflowId,
        root_domains: rootDomains,
        force_run: forceRun,
        allow_retry_failed: forceRun,
        reason: `ui_run:${workflowId}`,
      };
      const button = document.getElementById("runWorkflowButton");
      button.disabled = true;
      try {
        setStatus("loading", `Scheduling ${workflowId}...`);
        const rsp = await fetch("/api/coord/workflow/run", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json", ...authHeaders() },
          body: JSON.stringify(payload),
        });
        const body = await rsp.json().catch(() => ({}));
        if (!rsp.ok) {
          const detail = typeof body.detail === "object" ? JSON.stringify(body.detail) : String(body.detail || body.error || `HTTP ${rsp.status}`);
          throw new Error(detail);
        }
        await refreshAllData();
        const counts = body.counts || {};
        setStatus("success", `Scheduled ${Number(counts.scheduled || 0)} task(s); ${Number(counts.already_running || 0)} already running.`);
      } catch (error) {
        setStatus("error", String(error && error.message ? error.message : error));
      } finally {
        button.disabled = false;
      }
    }

    document.getElementById("refreshButton").addEventListener("click", refreshAllData);
    document.getElementById("forceClaimButton").addEventListener("click", forceWorkersToClaimNow);
    document.getElementById("runWorkflowButton").addEventListener("click", runWorkflowNow);
    document.getElementById("pauseButton").addEventListener("click", () => {
      state.paused = !state.paused;
      document.getElementById("pauseButton").textContent = state.paused ? "Resume" : "Pause";
      setStatus(state.paused ? "" : "success", state.paused ? "Paused" : "Live");
      if (!state.paused) refreshAllData();
    });
    ["searchDomain", "searchWorkflow", "searchPlugin", "statusFilter"].forEach((id) => {
      document.getElementById(id).addEventListener("input", renderAll);
    });
    document.getElementById("limitSelect").addEventListener("change", refreshAllData);

    hydrateTokenFromCookie();
    scheduleRefresh();
    refreshAllData();
  </script>
</body>
</html>
