<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Workflows</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f8fafc; color: #0f172a; }
    h1 { margin-bottom: 8px; }
    .meta { margin-bottom: 12px; color: #475569; font-size: 13px; }
    .toolbar { display: flex; gap: 8px; align-items: center; margin: 10px 0 16px; flex-wrap: wrap; }
    input, select { padding: 6px 8px; border: 1px solid #94a3b8; border-radius: 6px; }
    input[type="text"], input[type="password"] { min-width: 180px; }
    button { border: 1px solid #94a3b8; background: #fff; border-radius: 6px; padding: 6px 10px; cursor: pointer; }
    button.primary { background: #0ea5e9; border-color: #0284c7; color: #fff; }
    .cards { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-bottom: 14px; }
    .card { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .k { font-size: 12px; color: #64748b; }
    .v { font-size: 20px; font-weight: 700; margin-top: 4px; word-break: break-word; }
    .muted { color: #64748b; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    .status-pill { display: inline-flex; align-items: center; gap: 8px; border: 1px solid #cbd5e1; border-radius: 999px; padding: 5px 10px; font-size: 12px; font-weight: 600; background: #fff; color: #334155; }
    .status-dot { width: 9px; height: 9px; border-radius: 999px; background: #94a3b8; }
    .status-loading .status-dot { background: #0284c7; animation: pulse 1s ease-in-out infinite; }
    .status-success .status-dot { background: #16a34a; }
    .status-error .status-dot { background: #dc2626; }
    @keyframes pulse { 0%, 100% { transform: scale(0.8); opacity: 0.7; } 50% { transform: scale(1.2); opacity: 1; } }
    .layout { display: grid; gap: 12px; grid-template-columns: minmax(320px, 1fr) minmax(420px, 2fr); }
    .panel { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .panel h2 { margin: 0 0 10px; font-size: 16px; }
    .table-wrap { max-height: 56vh; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; }
    table { width: 100%; border-collapse: collapse; background: #fff; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; font-size: 12px; vertical-align: top; text-align: left; }
    th { background: #f1f5f9; position: sticky; top: 0; z-index: 2; }
    tr.selected { background: #ecfeff; }
    .badge { display: inline-flex; border: 1px solid #cbd5e1; border-radius: 999px; padding: 2px 8px; font-weight: 600; font-size: 11px; background: #fff; color: #334155; }
    .b-running { border-color: #38bdf8; color: #0369a1; background: #f0f9ff; }
    .b-completed { border-color: #86efac; color: #166534; background: #f0fdf4; }
    .b-failed { border-color: #fca5a5; color: #991b1b; background: #fef2f2; }
    .b-pending { border-color: #cbd5e1; color: #334155; background: #f8fafc; }
    .tabbar { display: flex; gap: 8px; margin-bottom: 12px; }
    .tab-btn { border: 1px solid #cbd5e1; background: #fff; color: #334155; border-radius: 999px; padding: 6px 12px; font-weight: 600; cursor: pointer; }
    .tab-btn.active { background: #0ea5e9; border-color: #0284c7; color: #fff; }
    .view-pane { display: none; }
    .view-pane.active { display: block; }
    .actions { display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); margin-top: 12px; }
    .form-grid { display: grid; gap: 8px; grid-template-columns: 1fr 1fr; }
    .form-grid .full { grid-column: 1 / -1; }
    label { display: grid; gap: 4px; font-size: 12px; color: #334155; }
    .result-box { border: 1px solid #cbd5e1; border-radius: 8px; background: #f8fafc; padding: 8px; max-height: 160px; overflow: auto; white-space: pre-wrap; }
    @media (max-width: 1200px) {
      .layout { grid-template-columns: 1fr; }
      .table-wrap { max-height: 42vh; }
    }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <h1>Workflow Monitor</h1>
  <div class="meta">Live view of workflow/plugin readiness and execution state, with manual enqueue and reset controls. Auto-refresh every 30s.</div>

  <div class="cards">
    <div class="card"><div class="k">Visible Domains</div><div class="v" id="visibleDomains">0</div></div>
    <div class="card"><div class="k">Total Domains</div><div class="v" id="totalDomains">0</div></div>
    <div class="card"><div class="k">Visible Tasks</div><div class="v" id="visibleTasks">0</div></div>
    <div class="card"><div class="k">Running Tasks</div><div class="v" id="runningTasks">0</div></div>
  </div>

  <div class="toolbar">
    <input id="token" type="password" placeholder="Coordinator token">
    <input id="searchDomain" type="text" placeholder="Filter domain">
    <input id="searchWorkflow" type="text" placeholder="Filter workflow">
    <input id="searchPlugin" type="text" placeholder="Filter plugin">
    <select id="statusFilter">
      <option value="">All statuses</option>
      <option value="pending">pending</option>
      <option value="running">running</option>
      <option value="completed">completed</option>
      <option value="failed">failed</option>
    </select>
    <select id="limitSelect">
      <option value="250">250 domains</option>
      <option value="1000" selected>1000 domains</option>
      <option value="2000">2000 domains</option>
      <option value="5000">5000 domains</option>
    </select>
    <button class="primary" id="refreshButton">Refresh</button>
    <button id="pauseButton">Pause</button>
    <span id="statusPill" class="status-pill"><span class="status-dot"></span><span id="statusText">Idle</span></span>
  </div>

  <div class="tabbar">
    <button id="tabMonitor" class="tab-btn active" type="button">Monitor</button>
    <button id="tabTimeline" class="tab-btn" type="button">Timeline</button>
  </div>

  <div id="monitorPane" class="view-pane active">
  <div class="layout">
    <section class="panel">
      <h2>Domains</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Domain</th>
              <th>Targets</th>
              <th>Artifacts</th>
              <th>Task States</th>
            </tr>
          </thead>
          <tbody id="domainRows">
            <tr><td colspan="4" class="muted">Loading domains...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 id="taskPanelTitle">Plugin Tasks</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Workflow</th>
              <th>Plugin</th>
              <th>Status</th>
              <th>Attempt</th>
              <th>Worker</th>
              <th>Updated</th>
              <th>Progress</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="taskRows">
            <tr><td colspan="8" class="muted">Select a domain to inspect plugin tasks.</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="actions">
    <section class="panel">
      <h2>Enqueue Plugin Task</h2>
      <form id="enqueueForm">
        <div class="form-grid">
          <label>Root domain
            <input id="enqueueRootDomain" type="text" placeholder="example.com">
          </label>
          <label>Workflow ID
            <input id="enqueueWorkflowId" type="text" value="default">
          </label>
          <label>Plugin name
            <input id="enqueuePlugin" type="text" placeholder="extractor">
          </label>
          <label>Max attempts (failed retry gate)
            <input id="enqueueMaxAttempts" type="text" value="0">
          </label>
          <label class="full">Reason
            <input id="enqueueReason" type="text" placeholder="manual enqueue from workflow monitor">
          </label>
          <label>Progress artifact type
            <input id="enqueueProgressArtifactType" type="text" placeholder="plugin_progress_json">
          </label>
          <label>Resume mode
            <select id="enqueueResumeMode">
              <option value="exact" selected>exact</option>
            </select>
          </label>
          <label class="full">
            <input id="enqueueAllowRetryFailed" type="checkbox"> Allow retry if current row is failed
          </label>
        </div>
        <div class="toolbar">
          <button class="primary" type="submit">Enqueue</button>
        </div>
      </form>
      <div id="enqueueResult" class="result-box muted">No enqueue action yet.</div>
    </section>

    <section class="panel">
      <h2>Reset Plugin Tasks</h2>
      <form id="resetForm">
        <div class="form-grid">
          <label>Workflow ID (blank = all)
            <input id="resetWorkflowId" type="text" placeholder="default">
          </label>
          <label>Hard delete
            <select id="resetHardDelete">
              <option value="false" selected>false</option>
              <option value="true">true</option>
            </select>
          </label>
          <label class="full">Root domains (comma separated)
            <input id="resetRootDomains" type="text" placeholder="example.com,example.org">
          </label>
          <label class="full">Plugins (comma separated)
            <input id="resetPlugins" type="text" placeholder="nightmare_crawl_core,extractor">
          </label>
        </div>
        <div class="toolbar">
          <button class="primary" type="submit">Reset</button>
        </div>
      </form>
      <div id="resetResult" class="result-box muted">No reset action yet.</div>
    </section>
  </div>
  </div>

  <div id="timelinePane" class="view-pane">
    <section class="panel">
      <h2>Workflow Timeline</h2>
      <div class="toolbar">
        <input id="eventDomainFilter" type="text" placeholder="Domain filter">
        <input id="eventWorkflowFilter" type="text" placeholder="Workflow filter">
        <input id="eventPluginFilter" type="text" placeholder="Plugin filter">
        <input id="eventTextFilter" type="text" placeholder="Search message/payload">
        <select id="eventLimitSelect">
          <option value="250">250 events</option>
          <option value="500" selected>500 events</option>
          <option value="1000">1000 events</option>
          <option value="2000">2000 events</option>
          <option value="5000">5000 events</option>
        </select>
        <button type="button" id="applySelectionToTimeline">Use Selected Domain</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Time</th>
              <th>Type</th>
              <th>Workflow</th>
              <th>Domain</th>
              <th>Plugin</th>
              <th>Worker</th>
              <th>Message</th>
              <th>Aggregate</th>
            </tr>
          </thead>
          <tbody id="timelineRows">
            <tr><td colspan="8" class="muted">Loading workflow task events...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
    const TOKEN_COOKIE_NAME = "nightmare_coord_token";
    const state = { paused: false, timer: null, snapshot: null, events: [], selectedDomain: "", activeTab: "monitor" };

    function readCookie(name) {
      const needle = `${name}=`;
      const cookies = String(document.cookie || "").split(";");
      for (const part of cookies) {
        const item = part.trim();
        if (item.startsWith(needle)) return decodeURIComponent(item.slice(needle.length));
      }
      return "";
    }
    function writeCookie(name, value, days) {
      const maxAge = Math.max(1, Number(days || 30)) * 24 * 60 * 60;
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`;
    }
    function deleteCookie(name) {
      const secure = location.protocol === "https:" ? "; Secure" : "";
      document.cookie = `${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`;
    }
    function authHeaders() {
      const token = document.getElementById("token").value.trim();
      if (token) writeCookie(TOKEN_COOKIE_NAME, token, 30);
      else deleteCookie(TOKEN_COOKIE_NAME);
      return token ? { Authorization: `Bearer ${token}` } : {};
    }
    function hydrateTokenFromCookie() {
      const token = readCookie(TOKEN_COOKIE_NAME);
      if (token) document.getElementById("token").value = token;
    }
    function setStatus(kind, text) {
      const pill = document.getElementById("statusPill");
      const label = document.getElementById("statusText");
      pill.className = "status-pill";
      if (kind) pill.classList.add(`status-${kind}`);
      label.textContent = text;
    }
    function setActiveTab(tab) {
      const next = tab === "timeline" ? "timeline" : "monitor";
      state.activeTab = next;
      document.getElementById("tabMonitor").classList.toggle("active", next === "monitor");
      document.getElementById("tabTimeline").classList.toggle("active", next === "timeline");
      document.getElementById("monitorPane").classList.toggle("active", next === "monitor");
      document.getElementById("timelinePane").classList.toggle("active", next === "timeline");
    }
    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }
    function badgeClass(status) {
      const value = String(status || "").trim().toLowerCase();
      if (value === "running") return "badge b-running";
      if (value === "completed") return "badge b-completed";
      if (value === "failed") return "badge b-failed";
      return "badge b-pending";
    }
    function parseCsv(value) {
      return String(value || "")
        .split(",")
        .map((item) => item.trim().toLowerCase())
        .filter(Boolean);
    }
    function formatStamp(value) {
      if (!value) return "";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return String(value);
      return date.toLocaleString();
    }
    function eventMeta(event) {
      const payload = (event && typeof event === "object" && event.payload && typeof event.payload === "object")
        ? event.payload
        : {};
      const aggregate = String((event && event.aggregate_key) || "");
      const parts = aggregate.split(":");
      const workflowFromKey = (parts.length >= 2 && parts[0] === "workflow_task") ? parts[1] : "";
      const domainFromKey = (parts.length >= 3 && parts[0] === "workflow_task") ? parts[2] : "";
      const pluginFromKey = (parts.length >= 4 && parts[0] === "workflow_task") ? parts.slice(3).join(":") : "";
      return {
        created_at: String((event && event.created_at) || ""),
        event_type: String((event && event.event_type) || ""),
        aggregate_key: aggregate,
        workflow_id: String(payload.workflow_id || workflowFromKey || "").toLowerCase(),
        root_domain: String(payload.root_domain || domainFromKey || "").toLowerCase(),
        plugin_name: String(payload.plugin_name || payload.stage || pluginFromKey || "").toLowerCase(),
        worker_id: String(payload.worker_id || ""),
        message: String((event && event.message) || payload.message || ""),
        payload,
      };
    }
    function timelineFiltersMatch(meta) {
      const domainFilter = document.getElementById("eventDomainFilter").value.trim().toLowerCase();
      const workflowFilter = document.getElementById("eventWorkflowFilter").value.trim().toLowerCase();
      const pluginFilter = document.getElementById("eventPluginFilter").value.trim().toLowerCase();
      const textFilter = document.getElementById("eventTextFilter").value.trim().toLowerCase();
      if (domainFilter && !String(meta.root_domain || "").includes(domainFilter)) return false;
      if (workflowFilter && !String(meta.workflow_id || "").includes(workflowFilter)) return false;
      if (pluginFilter && !String(meta.plugin_name || "").includes(pluginFilter)) return false;
      if (textFilter) {
        const haystack = [
          meta.event_type,
          meta.aggregate_key,
          meta.workflow_id,
          meta.root_domain,
          meta.plugin_name,
          meta.worker_id,
          meta.message,
          JSON.stringify(meta.payload || {}),
        ].join(" ").toLowerCase();
        if (!haystack.includes(textFilter)) return false;
      }
      return true;
    }
    function flattenTasks(domain) {
      const out = [];
      const pluginTasks = (domain && typeof domain === "object" && domain.plugin_tasks && typeof domain.plugin_tasks === "object")
        ? domain.plugin_tasks
        : {};
      for (const [workflowId, pluginMap] of Object.entries(pluginTasks)) {
        if (!pluginMap || typeof pluginMap !== "object") continue;
        for (const [pluginName, row] of Object.entries(pluginMap)) {
          const task = (row && typeof row === "object") ? row : {};
          out.push({
            root_domain: String(domain.root_domain || "").toLowerCase(),
            workflow_id: String(workflowId || "default").toLowerCase(),
            plugin_name: String(pluginName || task.stage || "").toLowerCase(),
            status: String(task.status || "").toLowerCase(),
            attempt_count: Number(task.attempt_count || 0),
            worker_id: String(task.worker_id || ""),
            updated_at_utc: task.updated_at_utc || "",
            completed_at_utc: task.completed_at_utc || "",
            checkpoint: (task.checkpoint && typeof task.checkpoint === "object") ? task.checkpoint : {},
            progress: (task.progress && typeof task.progress === "object") ? task.progress : {},
            error: String(task.error || ""),
          });
        }
      }
      if (out.length === 0 && domain && typeof domain.stage_tasks === "object") {
        for (const [stageName, row] of Object.entries(domain.stage_tasks || {})) {
          const task = (row && typeof row === "object") ? row : {};
          out.push({
            root_domain: String(domain.root_domain || "").toLowerCase(),
            workflow_id: "default",
            plugin_name: String(stageName || "").toLowerCase(),
            status: String(task.status || "").toLowerCase(),
            attempt_count: Number(task.attempt_count || 0),
            worker_id: String(task.worker_id || ""),
            updated_at_utc: task.updated_at_utc || "",
            completed_at_utc: task.completed_at_utc || "",
            checkpoint: (task.checkpoint && typeof task.checkpoint === "object") ? task.checkpoint : {},
            progress: (task.progress && typeof task.progress === "object") ? task.progress : {},
            error: String(task.error || ""),
          });
        }
      }
      return out;
    }
    function progressSummary(task) {
      const progress = task.progress || {};
      const checkpoint = task.checkpoint || {};
      if (typeof progress.percent === "number") return `${progress.percent}%`;
      if (progress.phase) return String(progress.phase);
      if (progress.state) return String(progress.state);
      if (checkpoint.step_name) return String(checkpoint.step_name);
      if (typeof checkpoint.step_index === "number") return `step ${checkpoint.step_index}`;
      if (task.error) return task.error.slice(0, 80);
      return "";
    }
    function filteredDomains() {
      const payload = state.snapshot || {};
      const all = Array.isArray(payload.domains) ? payload.domains : [];
      const domainFilter = document.getElementById("searchDomain").value.trim().toLowerCase();
      return all.filter((domain) => {
        const rootDomain = String(domain.root_domain || "").toLowerCase();
        if (!domainFilter) return true;
        return rootDomain.includes(domainFilter);
      });
    }
    function taskFiltersMatch(task) {
      const workflowFilter = document.getElementById("searchWorkflow").value.trim().toLowerCase();
      const pluginFilter = document.getElementById("searchPlugin").value.trim().toLowerCase();
      const statusFilter = document.getElementById("statusFilter").value.trim().toLowerCase();
      if (workflowFilter && !String(task.workflow_id || "").includes(workflowFilter)) return false;
      if (pluginFilter && !String(task.plugin_name || "").includes(pluginFilter)) return false;
      if (statusFilter && String(task.status || "") !== statusFilter) return false;
      return true;
    }
    function renderDomainRows(domains) {
      const body = document.getElementById("domainRows");
      if (!domains.length) {
        body.innerHTML = '<tr><td colspan="4" class="muted">No domains match the current filter.</td></tr>';
        return;
      }
      if (!state.selectedDomain || !domains.some((item) => String(item.root_domain || "") === state.selectedDomain)) {
        state.selectedDomain = String(domains[0].root_domain || "");
      }
      body.innerHTML = domains.map((domain) => {
        const root = String(domain.root_domain || "");
        const tasks = flattenTasks(domain).filter(taskFiltersMatch);
        const statuses = { pending: 0, running: 0, completed: 0, failed: 0 };
        for (const task of tasks) {
          const key = String(task.status || "").toLowerCase();
          if (Object.prototype.hasOwnProperty.call(statuses, key)) statuses[key] += 1;
        }
        const targetStats = domain.targets || {};
        const targetText = `p:${Number(targetStats.pending || 0)} r:${Number(targetStats.running || 0)} c:${Number(targetStats.completed || 0)} f:${Number(targetStats.failed || 0)}`;
        const statusText = `p:${statuses.pending} r:${statuses.running} c:${statuses.completed} f:${statuses.failed}`;
        const selectedClass = state.selectedDomain === root ? "selected" : "";
        return `
          <tr class="${selectedClass}" data-domain="${escapeHtml(root)}">
            <td class="mono">${escapeHtml(root)}</td>
            <td class="mono">${escapeHtml(targetText)}</td>
            <td>${Number(Array.isArray(domain.artifact_types) ? domain.artifact_types.length : 0)}</td>
            <td class="mono">${escapeHtml(statusText)}</td>
          </tr>
        `;
      }).join("");
      body.querySelectorAll("tr[data-domain]").forEach((row) => {
        row.addEventListener("click", () => {
          state.selectedDomain = String(row.getAttribute("data-domain") || "");
          document.getElementById("enqueueRootDomain").value = state.selectedDomain;
          renderAll();
        });
      });
    }
    function renderTaskRows(domains) {
      const body = document.getElementById("taskRows");
      const selected = domains.find((domain) => String(domain.root_domain || "") === state.selectedDomain);
      if (!selected) {
        document.getElementById("taskPanelTitle").textContent = "Plugin Tasks";
        body.innerHTML = '<tr><td colspan="8" class="muted">Select a domain to inspect plugin tasks.</td></tr>';
        return;
      }
      const root = String(selected.root_domain || "");
      document.getElementById("taskPanelTitle").textContent = `Plugin Tasks: ${root}`;
      const tasks = flattenTasks(selected).filter(taskFiltersMatch);
      if (!tasks.length) {
        body.innerHTML = '<tr><td colspan="8" class="muted">No plugin tasks match filters for this domain.</td></tr>';
        return;
      }
      body.innerHTML = tasks.map((task) => `
        <tr>
          <td class="mono">${escapeHtml(task.workflow_id || "default")}</td>
          <td class="mono">${escapeHtml(task.plugin_name)}</td>
          <td><span class="${badgeClass(task.status)}">${escapeHtml(task.status || "pending")}</span></td>
          <td>${Number(task.attempt_count || 0)}</td>
          <td class="mono">${escapeHtml(task.worker_id || "")}</td>
          <td class="mono">${escapeHtml(formatStamp(task.updated_at_utc || task.completed_at_utc || ""))}</td>
          <td title="${escapeHtml(JSON.stringify(task.progress || {}))}">${escapeHtml(progressSummary(task))}</td>
          <td>
            <button type="button" data-queue="${escapeHtml(task.plugin_name)}" data-workflow="${escapeHtml(task.workflow_id)}">Queue</button>
            <button type="button" data-reset="${escapeHtml(task.plugin_name)}" data-workflow="${escapeHtml(task.workflow_id)}">Reset</button>
          </td>
        </tr>
      `).join("");
      body.querySelectorAll("button[data-queue]").forEach((button) => {
        button.addEventListener("click", async () => {
          const plugin = String(button.getAttribute("data-queue") || "").toLowerCase();
          const workflow = String(button.getAttribute("data-workflow") || "default").toLowerCase();
          document.getElementById("enqueueRootDomain").value = root;
          document.getElementById("enqueuePlugin").value = plugin;
          document.getElementById("enqueueWorkflowId").value = workflow;
          await enqueueTask();
        });
      });
      body.querySelectorAll("button[data-reset]").forEach((button) => {
        button.addEventListener("click", async () => {
          const plugin = String(button.getAttribute("data-reset") || "").toLowerCase();
          const workflow = String(button.getAttribute("data-workflow") || "default").toLowerCase();
          await resetTasks({ workflow, root, plugins: [plugin], hardDelete: false });
        });
      });
    }
    function renderTimelineRows() {
      const body = document.getElementById("timelineRows");
      const rows = (Array.isArray(state.events) ? state.events : [])
        .map((event) => eventMeta(event))
        .filter(timelineFiltersMatch);
      if (!rows.length) {
        body.innerHTML = '<tr><td colspan="8" class="muted">No workflow task events match current timeline filters.</td></tr>';
        return;
      }
      body.innerHTML = rows.map((item) => `
        <tr>
          <td class="mono">${escapeHtml(formatStamp(item.created_at))}</td>
          <td><span class="badge">${escapeHtml(item.event_type)}</span></td>
          <td class="mono">${escapeHtml(item.workflow_id || "")}</td>
          <td class="mono">${escapeHtml(item.root_domain || "")}</td>
          <td class="mono">${escapeHtml(item.plugin_name || "")}</td>
          <td class="mono">${escapeHtml(item.worker_id || "")}</td>
          <td title="${escapeHtml(item.message)}">${escapeHtml(String(item.message || "").slice(0, 220))}</td>
          <td class="mono">${escapeHtml(item.aggregate_key)}</td>
        </tr>
      `).join("");
    }
    function updateCards(domains) {
      const payload = state.snapshot || {};
      let visibleTaskCount = 0;
      let runningTaskCount = 0;
      for (const domain of domains) {
        for (const task of flattenTasks(domain).filter(taskFiltersMatch)) {
          visibleTaskCount += 1;
          if (String(task.status || "").toLowerCase() === "running") runningTaskCount += 1;
        }
      }
      document.getElementById("visibleDomains").textContent = String(domains.length);
      document.getElementById("totalDomains").textContent = String(Number(payload.domain_count || 0));
      document.getElementById("visibleTasks").textContent = String(visibleTaskCount);
      document.getElementById("runningTasks").textContent = String(runningTaskCount);
    }
    function renderAll() {
      const domains = filteredDomains();
      renderDomainRows(domains);
      renderTaskRows(domains);
      renderTimelineRows();
      updateCards(domains);
    }
    async function fetchWorkflowSnapshotData() {
      const limit = Number(document.getElementById("limitSelect").value || 1000);
      const response = await fetch(`/api/coord/workflow-snapshot?limit=${encodeURIComponent(limit)}`, {
        credentials: "same-origin",
        headers: authHeaders(),
      });
      const payload = await response.json();
      if (!response.ok) throw new Error(payload.error || `HTTP ${response.status}`);
      state.snapshot = payload;
    }
    async function fetchWorkflowEventsData() {
      const limit = Number(document.getElementById("eventLimitSelect").value || 500);
      const qs = new URLSearchParams({
        limit: String(Math.max(1, Math.min(5000, limit))),
        sort_dir: "desc",
        event_type: "workflow.task.",
      });
      const response = await fetch(`/api/coord/events?${qs.toString()}`, {
        credentials: "same-origin",
        headers: authHeaders(),
      });
      const payload = await response.json();
      if (!response.ok) throw new Error(payload.error || `HTTP ${response.status}`);
      state.events = Array.isArray(payload.events) ? payload.events : [];
    }
    async function refreshAllData() {
      if (state.paused) return;
      setStatus("loading", "Refreshing...");
      try {
        await Promise.all([fetchWorkflowSnapshotData(), fetchWorkflowEventsData()]);
        renderAll();
        setStatus("success", `Live at ${new Date().toLocaleTimeString()}`);
      } catch (error) {
        setStatus("error", String(error && error.message ? error.message : error));
      }
    }
    async function postJson(path, body) {
      const response = await fetch(path, {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json", ...authHeaders() },
        body: JSON.stringify(body || {}),
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok) {
        const detail = payload && payload.error ? payload.error : `HTTP ${response.status}`;
        throw new Error(detail);
      }
      return payload;
    }
    async function enqueueTask() {
      const rootDomain = document.getElementById("enqueueRootDomain").value.trim().toLowerCase();
      const plugin = document.getElementById("enqueuePlugin").value.trim().toLowerCase();
      const workflowId = document.getElementById("enqueueWorkflowId").value.trim().toLowerCase() || "default";
      const allowRetryFailed = document.getElementById("enqueueAllowRetryFailed").checked;
      const maxAttempts = Number(document.getElementById("enqueueMaxAttempts").value || 0);
      const reason = document.getElementById("enqueueReason").value.trim();
      const progressArtifactType = document.getElementById("enqueueProgressArtifactType").value.trim().toLowerCase();
      const resumeMode = document.getElementById("enqueueResumeMode").value.trim().toLowerCase() || "exact";
      if (!rootDomain || !plugin) {
        document.getElementById("enqueueResult").textContent = "root_domain and plugin are required.";
        return;
      }
      try {
        const payload = await postJson("/api/coord/stage/enqueue", {
          root_domain: rootDomain,
          stage: plugin,
          workflow_id: workflowId,
          reason,
          allow_retry_failed: allowRetryFailed,
          max_attempts: Number.isFinite(maxAttempts) ? maxAttempts : 0,
          progress_artifact_type: progressArtifactType,
          resume_mode: resumeMode,
        });
        document.getElementById("enqueueResult").textContent = JSON.stringify(payload, null, 2);
        await refreshAllData();
      } catch (error) {
        document.getElementById("enqueueResult").textContent = String(error && error.message ? error.message : error);
      }
    }
    async function resetTasks({ workflow = "", root = "", plugins = [], hardDelete = false } = {}) {
      const workflowId = String(workflow || document.getElementById("resetWorkflowId").value || "").trim().toLowerCase();
      const rootDomains = root ? [String(root).trim().toLowerCase()] : parseCsv(document.getElementById("resetRootDomains").value);
      const pluginList = Array.isArray(plugins) && plugins.length ? plugins : parseCsv(document.getElementById("resetPlugins").value);
      const hardDeleteValue = hardDelete || (String(document.getElementById("resetHardDelete").value || "false").toLowerCase() === "true");
      try {
        const payload = await postJson("/api/coord/stage/reset", {
          workflow_id: workflowId,
          root_domains: rootDomains,
          plugins: pluginList,
          hard_delete: hardDeleteValue,
        });
        document.getElementById("resetResult").textContent = JSON.stringify(payload, null, 2);
        await refreshAllData();
      } catch (error) {
        document.getElementById("resetResult").textContent = String(error && error.message ? error.message : error);
      }
    }
    function scheduleRefresh() {
      if (state.timer) clearInterval(state.timer);
      state.timer = setInterval(refreshAllData, 30000);
    }

    document.getElementById("refreshButton").addEventListener("click", refreshAllData);
    document.getElementById("pauseButton").addEventListener("click", () => {
      state.paused = !state.paused;
      document.getElementById("pauseButton").textContent = state.paused ? "Resume" : "Pause";
      setStatus(state.paused ? "" : "success", state.paused ? "Paused" : "Live");
      if (!state.paused) refreshAllData();
    });
    document.getElementById("enqueueForm").addEventListener("submit", async (event) => {
      event.preventDefault();
      await enqueueTask();
    });
    document.getElementById("resetForm").addEventListener("submit", async (event) => {
      event.preventDefault();
      await resetTasks();
    });
    ["searchDomain", "searchWorkflow", "searchPlugin", "statusFilter"].forEach((id) => {
      document.getElementById(id).addEventListener("input", renderAll);
    });
    ["eventDomainFilter", "eventWorkflowFilter", "eventPluginFilter", "eventTextFilter"].forEach((id) => {
      document.getElementById(id).addEventListener("input", renderAll);
    });
    document.getElementById("limitSelect").addEventListener("change", refreshAllData);
    document.getElementById("eventLimitSelect").addEventListener("change", refreshAllData);
    function setTabWithHash(tab) {
      setActiveTab(tab);
      const nextHash = tab === "monitor" ? "" : `#${tab}`;
      if (window.location.hash !== nextHash) {
        const nextUrl = `${window.location.pathname}${nextHash}`;
        window.history.replaceState(null, "", nextUrl);
      }
    }
    document.getElementById("tabMonitor").addEventListener("click", () => setTabWithHash("monitor"));
    document.getElementById("tabTimeline").addEventListener("click", () => setTabWithHash("timeline"));
    document.getElementById("applySelectionToTimeline").addEventListener("click", () => {
      document.getElementById("eventDomainFilter").value = String(state.selectedDomain || "");
      document.getElementById("eventWorkflowFilter").value = document.getElementById("searchWorkflow").value.trim().toLowerCase();
      document.getElementById("eventPluginFilter").value = document.getElementById("searchPlugin").value.trim().toLowerCase();
      setTabWithHash("timeline");
      renderAll();
    });

    function applyTabFromHash() {
      const hash = String(window.location.hash || "").replace(/^#/, "").trim().toLowerCase();
      if (hash === "timeline") setActiveTab("timeline");
      else setActiveTab("monitor");
    }
    window.addEventListener("hashchange", applyTabFromHash);

    hydrateTokenFromCookie();
    scheduleRefresh();
    refreshAllData();
    applyTabFromHash();
  </script>
</body>
</html>
