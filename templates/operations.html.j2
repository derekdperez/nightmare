<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Operations Cockpit</title>
  <style>
    :root {
      --bg: #f8fafc;
      --panel: #ffffff;
      --border: #cbd5e1;
      --border-strong: #94a3b8;
      --text: #0f172a;
      --muted: #64748b;
      --accent: #0ea5e9;
      --accent-dark: #0369a1;
      --ok: #15803d;
      --warn: #b45309;
      --bad: #b91c1c;
      --soft-blue: #eff6ff;
      --soft-green: #f0fdf4;
      --soft-amber: #fffbeb;
      --soft-red: #fef2f2;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 16px;
      font-family: Segoe UI, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
    }
    main {
      max-width: 1600px;
      margin: 0 auto;
    }
    .hero {
      display: grid;
      grid-template-columns: minmax(260px, 1fr) minmax(320px, 520px);
      gap: 16px;
      align-items: stretch;
      margin-bottom: 16px;
    }
    .hero-panel, .panel, .action-card, .metric-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }
    .hero-panel {
      padding: 22px;
      overflow: hidden;
      position: relative;
    }
    .eyebrow {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin: 0 0 8px;
    }
    h1 {
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.05;
      margin: 0 0 12px;
      letter-spacing: -0.04em;
    }
    .hero-copy {
      margin: 0;
      color: #475569;
      max-width: 820px;
      line-height: 1.5;
      font-size: 15px;
    }
    .hero-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }
    .status-stack {
      padding: 14px;
      display: grid;
      gap: 10px;
      align-content: start;
    }
    .status-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      background: #fff;
    }
    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: var(--muted);
      box-shadow: 0 0 0 4px rgba(100, 116, 139, .12);
    }
    .status-dot.ok { background: var(--ok); box-shadow: 0 0 0 4px rgba(21, 128, 61, .14); }
    .status-dot.warn { background: var(--warn); box-shadow: 0 0 0 4px rgba(180, 83, 9, .14); }
    .status-dot.bad { background: var(--bad); box-shadow: 0 0 0 4px rgba(185, 28, 28, .14); }
    .status-title { font-weight: 800; font-size: 14px; }
    .status-note { color: var(--muted); font-size: 12px; margin-top: 2px; }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: #fff;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 800;
      color: #334155;
      text-decoration: none;
      white-space: nowrap;
    }
    .pill.ok { color: var(--ok); background: var(--soft-green); border-color: #bbf7d0; }
    .pill.warn { color: var(--warn); background: var(--soft-amber); border-color: #fde68a; }
    .pill.bad { color: var(--bad); background: var(--soft-red); border-color: #fecaca; }
    .grid {
      display: grid;
      gap: 14px;
    }
    .metrics {
      grid-template-columns: repeat(6, minmax(150px, 1fr));
      margin-bottom: 16px;
    }
    .metric-card {
      padding: 14px;
      min-height: 112px;
    }
    .metric-label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .05em;
    }
    .metric-value {
      font-size: 30px;
      font-weight: 900;
      margin-top: 10px;
      letter-spacing: -0.04em;
    }
    .metric-foot {
      color: var(--muted);
      font-size: 12px;
      margin-top: 8px;
      line-height: 1.35;
    }
    .two-col {
      grid-template-columns: minmax(360px, 1fr) minmax(360px, 1fr);
      align-items: start;
      margin-bottom: 16px;
    }
    .panel {
      padding: 16px;
      min-width: 0;
    }
    .panel-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: start;
      margin-bottom: 12px;
    }
    h2 {
      font-size: 18px;
      margin: 0 0 4px;
      letter-spacing: -0.02em;
    }
    .sub {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }
    .actions-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(220px, 1fr));
      gap: 14px;
      margin-bottom: 16px;
    }
    .action-card {
      padding: 16px;
      display: grid;
      gap: 12px;
      align-content: start;
      min-height: 260px;
    }
    .action-icon {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      background: var(--soft-blue);
      color: var(--accent-dark);
      display: inline-grid;
      place-items: center;
      font-size: 20px;
      font-weight: 900;
    }
    .action-title {
      font-size: 16px;
      font-weight: 900;
      margin: 0;
    }
    label {
      display: block;
      color: #334155;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 5px;
    }
    input, textarea, select {
      width: 100%;
      border: 1px solid var(--border-strong);
      border-radius: 10px;
      padding: 9px 10px;
      font: inherit;
      font-size: 13px;
      background: #fff;
      color: var(--text);
    }
    textarea {
      min-height: 96px;
      resize: vertical;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    button, .button-link {
      border: 1px solid var(--border-strong);
      border-radius: 11px;
      background: #fff;
      color: #0f172a;
      cursor: pointer;
      padding: 9px 12px;
      font-weight: 800;
      font-size: 13px;
      text-decoration: none;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      min-height: 38px;
    }
    button.primary, .button-link.primary {
      background: var(--accent);
      border-color: #0284c7;
      color: white;
    }
    button.danger {
      background: var(--soft-red);
      border-color: #fecaca;
      color: var(--bad);
    }
    button:hover, .button-link:hover { filter: brightness(0.98); }
    button:disabled {
      opacity: .55;
      cursor: not-allowed;
    }
    .inline-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }
    .list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .list li {
      padding: 10px 12px;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background: #fff;
      min-width: 0;
    }
    .item-title {
      font-weight: 800;
      font-size: 13px;
      overflow-wrap: anywhere;
    }
    .item-meta {
      color: var(--muted);
      font-size: 12px;
      margin-top: 4px;
      overflow-wrap: anywhere;
    }
    .command-bar {
      display: grid;
      grid-template-columns: minmax(180px, 1fr) auto auto auto;
      gap: 8px;
      align-items: end;
    }
    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      z-index: 200;
      max-width: min(760px, calc(100vw - 24px));
      background: rgba(15, 23, 42, .96);
      color: #e2e8f0;
      border-radius: 14px;
      padding: 12px 14px;
      box-shadow: 0 18px 50px rgba(15, 23, 42, .25);
      display: none;
      font-size: 13px;
    }
    .empty {
      border: 1px dashed var(--border);
      border-radius: 14px;
      padding: 16px;
      color: var(--muted);
      background: #fff;
      font-size: 13px;
    }
    .table-wrap {
      overflow: auto;
      max-height: 360px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fff;
    }
    table { width: 100%; border-collapse: collapse; min-width: 740px; }
    th, td {
      text-align: left;
      vertical-align: top;
      border-bottom: 1px solid #e2e8f0;
      padding: 9px 10px;
      font-size: 12px;
    }
    th {
      position: sticky;
      top: 0;
      background: #f1f5f9;
      z-index: 1;
      color: #334155;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .05em;
    }
    tr:last-child td { border-bottom: 0; }
    .right { text-align: right; }
    .muted { color: var(--muted); }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    .quick-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    @media (max-width: 1200px) {
      .metrics { grid-template-columns: repeat(3, minmax(150px, 1fr)); }
      .actions-grid { grid-template-columns: 1fr; }
      .hero, .two-col { grid-template-columns: 1fr; }
    }
    @media (max-width: 760px) {
      body { margin: 12px; }
      .metrics { grid-template-columns: repeat(2, minmax(130px, 1fr)); }
      .field-row, .command-bar { grid-template-columns: 1fr; }
      .hero-panel, .panel, .action-card { border-radius: 14px; }
    }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <main>
    <section class="hero">
      <div class="hero-panel">
        <p class="eyebrow">Daily operations</p>
        <h1>Operations Cockpit</h1>
        <p class="hero-copy">
          A single page for the highest-frequency operator tasks: confirm the system is healthy,
          see whether work is moving, add targets, launch workflows, control workers, and jump directly
          to the deeper evidence pages when something needs investigation.
        </p>
        <div class="hero-actions">
          <button class="primary" id="refreshNowBtn">Refresh now</button>
          <a class="button-link" href="/events">Investigate events</a>
          <a class="button-link" href="/errors">Review errors</a>
          <a class="button-link" href="/all-domains-report">Open report</a>
        </div>
      </div>
      <aside class="hero-panel status-stack" aria-label="Operational status">
        <div class="status-row">
          <span id="overallDot" class="status-dot"></span>
          <div>
            <div class="status-title" id="overallTitle">Loading status</div>
            <div class="status-note" id="overallNote">Checking coordinator, workers, database, and recent errors.</div>
          </div>
          <span class="pill" id="lastUpdated">—</span>
        </div>
        <div class="status-row">
          <span id="workersDot" class="status-dot"></span>
          <div>
            <div class="status-title">Worker fleet</div>
            <div class="status-note" id="workersNote">Waiting for worker status.</div>
          </div>
          <a class="pill" href="/workers">Manage</a>
        </div>
        <div class="status-row">
          <span id="databaseDot" class="status-dot"></span>
          <div>
            <div class="status-title">Database</div>
            <div class="status-note" id="databaseNote">Waiting for database status.</div>
          </div>
          <a class="pill" href="/database">Details</a>
        </div>
      </aside>
    </section>

    <section class="grid metrics" aria-label="Key metrics">
      <div class="metric-card"><div class="metric-label">Pending targets</div><div class="metric-value" id="metricPending">—</div><div class="metric-foot">Backlog waiting for workers.</div></div>
      <div class="metric-card"><div class="metric-label">Running targets</div><div class="metric-value" id="metricRunning">—</div><div class="metric-foot">Currently leased or processing.</div></div>
      <div class="metric-card"><div class="metric-label">Completed</div><div class="metric-value" id="metricCompleted">—</div><div class="metric-foot">Successfully finished targets.</div></div>
      <div class="metric-card"><div class="metric-label">Failed</div><div class="metric-value" id="metricFailed">—</div><div class="metric-foot">Needs retry or investigation.</div></div>
      <div class="metric-card"><div class="metric-label">Online workers</div><div class="metric-value" id="metricOnlineWorkers">—</div><div class="metric-foot">Recently seen active workers.</div></div>
      <div class="metric-card"><div class="metric-label">Recent errors</div><div class="metric-value" id="metricRecentErrors">—</div><div class="metric-foot">Latest structured error rows.</div></div>
    </section>

    <section class="actions-grid" aria-label="Common actions">
      <article class="action-card">
        <div class="action-icon">＋</div>
        <div>
          <h2 class="action-title">Add targets</h2>
          <p class="sub">Paste domains or URLs, one per line. The primary action appends by default so operators do not accidentally wipe a queue.</p>
        </div>
        <textarea id="targetsInput" placeholder="example.com&#10;https://app.example.org"></textarea>
        <label><input id="replaceExisting" type="checkbox" style="width:auto; margin-right:6px;"> Replace existing target queue</label>
        <button class="primary" id="registerTargetsBtn">Register targets</button>
      </article>

      <article class="action-card">
        <div class="action-icon">▶</div>
        <div>
          <h2 class="action-title">Launch workflow</h2>
          <p class="sub">Schedule a workflow for pasted domains or, when the domain box is empty, for existing discovered domains.</p>
        </div>
        <div class="field-row">
          <div>
            <label for="workflowSelect">Workflow</label>
            <select id="workflowSelect"><option value="run-recon">run-recon</option></select>
          </div>
          <div>
            <label for="workflowLimit">Domain limit when box is empty</label>
            <input id="workflowLimit" type="number" min="1" max="20000" value="5000">
          </div>
        </div>
        <textarea id="workflowDomains" placeholder="Optional domains, one per line"></textarea>
        <label><input id="allowRetryFailed" type="checkbox" style="width:auto; margin-right:6px;"> Retry failed workflow stages</label>
        <button class="primary" id="runWorkflowBtn">Enqueue workflow</button>
      </article>

      <article class="action-card">
        <div class="action-icon">⏱</div>
        <div>
          <h2 class="action-title">Control workers</h2>
          <p class="sub">Apply a command to all currently online workers. Bulk controls are grouped here because they affect capacity, not individual evidence.</p>
        </div>
        <div class="command-bar">
          <div>
            <label for="workerCommand">Command</label>
            <select id="workerCommand">
              <option value="pause">Pause</option>
              <option value="start">Start</option>
              <option value="reload">Reload</option>
              <option value="stop">Stop</option>
            </select>
          </div>
          <button id="sendWorkerCommandBtn">Send to online</button>
        </div>
        <div class="empty" id="workerCommandHint">Worker IDs will be detected from the live worker list.</div>
      </article>
    </section>

    <section class="grid two-col">
      <article class="panel">
        <div class="panel-head">
          <div>
            <h2>Recommended next actions</h2>
            <p class="sub">Computed from the live health signals so the page tells the operator what to do next.</p>
          </div>
        </div>
        <ul id="recommendations" class="list"><li class="empty">Loading recommendations…</li></ul>
      </article>

      <article class="panel">
        <div class="panel-head">
          <div>
            <h2>Fast navigation</h2>
            <p class="sub">Direct links to the common investigation surfaces. These are placed beside recommendations so the next click is nearby.</p>
          </div>
        </div>
        <div class="quick-links">
          <a class="pill" href="/crawl-progress">Crawl Progress</a>
          <a class="pill" href="/discovered-targets">Discovered Targets</a>
          <a class="pill" href="/discovered-files">Discovered Files</a>
          <a class="pill" href="/extractor-matches">Extractor Matches</a>
          <a class="pill" href="/fuzzing">Fuzzing</a>
          <a class="pill" href="/http-requests">HTTP Requests</a>
          <a class="pill" href="/docker-status">Docker Status</a>
          <a class="pill" href="/view-logs">View Logs</a>
          <a class="pill" href="/workflow-runs">Workflow Runs</a>
          <a class="pill" href="/workflow-definitions">Workflow Builder</a>
          <a class="pill" href="/plugin-definitions">Plugins</a>
        </div>
        <div class="inline-actions" style="margin-top:14px;">
          <button id="regenerateReportBtn">Regenerate master report</button>
          <a class="button-link" href="/all-domains-report">View master report</a>
        </div>
      </article>
    </section>

    <section class="grid two-col">
      <article class="panel">
        <div class="panel-head">
          <div>
            <h2>Online workers</h2>
            <p class="sub">A compact fleet table keeps capacity and stuck-worker symptoms visible without opening the full control page.</p>
          </div>
          <a class="pill" href="/workers">Full worker page</a>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Worker</th><th>Status</th><th>Action</th><th>Last seen</th></tr></thead>
            <tbody id="workersTable"><tr><td colspan="4" class="muted">Loading workers…</td></tr></tbody>
          </table>
        </div>
      </article>

      <article class="panel">
        <div class="panel-head">
          <div>
            <h2>Recent events and errors</h2>
            <p class="sub">Recent activity is interleaved with error hints to make “what just happened?” answerable from one screen.</p>
          </div>
          <div class="inline-actions">
            <a class="pill" href="/events">Events</a>
            <a class="pill" href="/errors">Errors</a>
          </div>
        </div>
        <ul id="activityList" class="list"><li class="empty">Loading activity…</li></ul>
      </article>
    </section>
  </main>
  <div id="toast" class="toast" role="status" aria-live="polite"></div>

  <script>
    const state = {
      summary: null,
      workers: null,
      database: null,
      errors: null,
      events: null,
      workflows: null,
      lastRefresh: null,
    };

    const $ = (id) => document.getElementById(id);
    const fmt = (value) => Number(value || 0).toLocaleString();
    const esc = (value) => String(value ?? "").replace(/[&<>"']/g, (ch) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[ch]));
    const asArray = (value) => Array.isArray(value) ? value : [];
    const nowLabel = () => new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit", second: "2-digit" });

    function toast(message, isError = false) {
      const node = $("toast");
      node.textContent = message;
      node.style.background = isError ? "rgba(127, 29, 29, .96)" : "rgba(15, 23, 42, .96)";
      node.style.display = "block";
      clearTimeout(node._hideTimer);
      node._hideTimer = setTimeout(() => { node.style.display = "none"; }, 4200);
    }

    async function json(url, init = {}) {
      const rsp = await fetch(url, init);
      const text = await rsp.text();
      let data = {};
      try { data = text ? JSON.parse(text) : {}; } catch { data = { raw: text }; }
      if (!rsp.ok) throw new Error(data.error || data.detail || text || `HTTP ${rsp.status}`);
      return data;
    }

    async function optionalJson(url) {
      try { return await json(url); }
      catch (err) { return { error: String(err.message || err) }; }
    }

    function countTargetStatus(name) {
      const counts = state.summary && state.summary.counts && typeof state.summary.counts === "object" ? state.summary.counts : {};
      return Number(counts[name] || 0);
    }

    function workerRows() {
      return asArray(state.workers && state.workers.workers);
    }

    function onlineWorkers() {
      return workerRows().filter((row) => {
        const status = String(row.status || "").toLowerCase();
        return status && status !== "stale" && status !== "offline" && status !== "stopped";
      });
    }

    function setDot(id, severity) {
      const node = $(id);
      if (!node) return;
      node.className = `status-dot ${severity || ""}`.trim();
    }

    function setMetric(id, value) {
      const node = $(id);
      if (node) node.textContent = value;
    }

    function inferDbOk() {
      if (!state.database || state.database.error) return false;
      if (state.database.ok === false) return false;
      if (state.database.status && String(state.database.status).toLowerCase().includes("error")) return false;
      return true;
    }

    function renderStatus() {
      const pending = countTargetStatus("pending");
      const running = countTargetStatus("running");
      const completed = countTargetStatus("completed");
      const failed = countTargetStatus("failed");
      const workerCounts = (state.workers && state.workers.counts) || {};
      const online = Number(workerCounts.online_workers || onlineWorkers().length || 0);
      const totalWorkers = Number(workerCounts.total_workers || workerRows().length || 0);
      const recentErrors = asArray(state.errors && (state.errors.items || state.errors.rows || state.errors.errors)).length;

      setMetric("metricPending", fmt(pending));
      setMetric("metricRunning", fmt(running));
      setMetric("metricCompleted", fmt(completed));
      setMetric("metricFailed", fmt(failed));
      setMetric("metricOnlineWorkers", fmt(online));
      setMetric("metricRecentErrors", fmt(recentErrors));

      const dbOk = inferDbOk();
      const workersOk = online > 0 || totalWorkers === 0;
      const hasProblems = failed > 0 || recentErrors > 0 || !dbOk || (!workersOk && (pending > 0 || running > 0));
      const overallSeverity = hasProblems ? (failed > 0 || !dbOk ? "bad" : "warn") : "ok";
      setDot("overallDot", overallSeverity);
      $("overallTitle").textContent = hasProblems ? "Attention needed" : "System looks healthy";
      $("overallNote").textContent = hasProblems
        ? "There are failures, unavailable dependencies, or worker capacity concerns to review."
        : "No obvious blocker detected from the latest summary.";
      $("lastUpdated").textContent = state.lastRefresh ? `Updated ${nowLabel()}` : "—";

      setDot("workersDot", online > 0 ? "ok" : (pending > 0 || running > 0 ? "warn" : ""));
      $("workersNote").textContent = `${fmt(online)} online of ${fmt(totalWorkers)} known workers.`;

      setDot("databaseDot", dbOk ? "ok" : "bad");
      $("databaseNote").textContent = state.database && state.database.error
        ? state.database.error
        : (dbOk ? "Database status endpoint responded." : "Database may be unavailable.");
    }

    function renderRecommendations() {
      const pending = countTargetStatus("pending");
      const running = countTargetStatus("running");
      const failed = countTargetStatus("failed");
      const online = Number((state.workers && state.workers.counts && state.workers.counts.online_workers) || onlineWorkers().length || 0);
      const recentErrors = asArray(state.errors && (state.errors.items || state.errors.rows || state.errors.errors)).length;
      const rows = [];

      if (!inferDbOk()) rows.push(["Database needs attention", "Open Database Status first; the rest of the cockpit depends on coordinator data.", "/database", "Open database"]);
      if (online === 0 && (pending > 0 || running > 0)) rows.push(["No online workers", "Start or debug workers before adding more work; queued/running targets cannot progress without capacity.", "/workers", "Manage workers"]);
      if (failed > 0) rows.push(["Failed targets exist", "Review failures and decide whether to retry workflow stages or inspect logs for a systemic cause.", "/errors", "Review errors"]);
      if (recentErrors > 0) rows.push(["Recent errors detected", "Inspect structured errors before launching large new batches.", "/errors", "Open errors"]);
      if (pending > 0 && online > 0) rows.push(["Backlog is ready", "Workers are online and pending work exists. Monitor crawl progress and worker activity.", "/crawl-progress", "Track progress"]);
      if (pending === 0 && running === 0 && failed === 0) rows.push(["Ready for new input", "No queued or active target work is visible. Add targets or launch a workflow.", "#targetsInput", "Add targets"]);
      if (!rows.length) rows.push(["Monitor active run", "Work is in progress. Keep an eye on events and discovered artifacts.", "/events", "Open events"]);

      $("recommendations").innerHTML = rows.map(([title, detail, href, cta]) => `
        <li>
          <div class="item-title">${esc(title)}</div>
          <div class="item-meta">${esc(detail)}</div>
          <div style="margin-top:8px;"><a class="pill" href="${esc(href)}">${esc(cta)}</a></div>
        </li>
      `).join("");
    }

    function renderWorkers() {
      const rows = onlineWorkers().slice(0, 12);
      $("workerCommandHint").textContent = rows.length
        ? `${rows.length} online worker${rows.length === 1 ? "" : "s"} will receive bulk commands.`
        : "No online workers detected yet; use the full worker page for stale/offline details.";
      if (!rows.length) {
        $("workersTable").innerHTML = `<tr><td colspan="4" class="muted">No online workers detected.</td></tr>`;
        return;
      }
      $("workersTable").innerHTML = rows.map((row) => {
        const lastSeen = row.last_seen_time_at_utc || row.last_seen_at_utc || row.last_presence_heartbeat || row.last_target_heartbeat || row.last_stage_heartbeat || "";
        return `<tr>
          <td class="mono">${esc(row.worker_id || row.id || "")}</td>
          <td>${esc(row.status || "")}</td>
          <td>${esc(row.current_action || row.last_action_performed || row.last_activity || "")}</td>
          <td>${esc(lastSeen)}</td>
        </tr>`;
      }).join("");
    }

    function renderActivity() {
      const errors = asArray(state.errors && (state.errors.items || state.errors.rows || state.errors.errors)).slice(0, 4).map((item) => ({
        kind: "Error",
        title: item.message || item.error || item.exception_type || item.event_type || "Error",
        meta: item.created_at_utc || item.timestamp_utc || item.logged_at_utc || item.program_name || "",
        href: "/errors",
      }));
      const events = asArray(state.events && (state.events.items || state.events.rows || state.events.events)).slice(0, 6).map((item) => ({
        kind: "Event",
        title: item.event_type || item.message || item.aggregate_key || "Event",
        meta: item.created_at_utc || item.timestamp_utc || item.source || item.aggregate_key || "",
        href: "/events",
      }));
      const rows = [...errors, ...events].slice(0, 8);
      if (!rows.length) {
        $("activityList").innerHTML = `<li class="empty">No recent events or errors returned by the available endpoints.</li>`;
        return;
      }
      $("activityList").innerHTML = rows.map((item) => `
        <li>
          <div class="item-title"><span class="pill ${item.kind === "Error" ? "bad" : ""}" style="margin-right:8px;">${esc(item.kind)}</span>${esc(item.title)}</div>
          <div class="item-meta">${esc(item.meta)}</div>
        </li>
      `).join("");
    }

    function renderWorkflowOptions() {
      const items = asArray(state.workflows && state.workflows.items);
      if (!items.length) return;
      const options = items.map((item) => {
        const value = item.workflow_id || item.key || item.name || item.slug || "run-recon";
        const label = item.name || item.title || item.workflow_id || value;
        return `<option value="${esc(value)}">${esc(label)}</option>`;
      }).join("");
      $("workflowSelect").innerHTML = options;
    }

    function renderAll() {
      renderStatus();
      renderRecommendations();
      renderWorkers();
      renderActivity();
      renderWorkflowOptions();
    }

    async function refreshAll() {
      const [summary, workers, database, errors, events, workflows] = await Promise.all([
        optionalJson("/api/coord/state"),
        optionalJson("/api/coord/workers"),
        optionalJson("/api/coord/database-status"),
        optionalJson("/api/errors?limit=12"),
        optionalJson("/api/coord/events?limit=12"),
        optionalJson("/api/workflow-definitions"),
      ]);
      Object.assign(state, { summary, workers, database, errors, events, workflows, lastRefresh: new Date() });
      renderAll();
    }

    function linesFromTextarea(id) {
      return String($(id).value || "").split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
    }

    async function registerTargets() {
      const targets = linesFromTextarea("targetsInput");
      if (!targets.length) { toast("Paste at least one target first.", true); return; }
      const replace_existing = $("replaceExisting").checked;
      const result = await json("/api/coord/register-targets", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ targets, replace_existing }),
      });
      $("targetsInput").value = "";
      toast(`Registered ${fmt(result.inserted || result.registered || targets.length)} target(s).`);
      await refreshAll();
    }

    async function runWorkflow() {
      const workflow_id = $("workflowSelect").value || "run-recon";
      const root_domains = linesFromTextarea("workflowDomains");
      const domain_limit = Math.max(1, Math.min(20000, Number($("workflowLimit").value || 5000)));
      const allow_retry_failed = $("allowRetryFailed").checked;
      const result = await json("/api/coord/workflow/run", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ workflow_id, root_domains, domain_limit, allow_retry_failed, reason: "operations_cockpit" }),
      });
      $("workflowDomains").value = "";
      const scheduled = result.counts && typeof result.counts === "object" ? result.counts.scheduled : undefined;
      toast(`Workflow ${workflow_id} enqueued. Scheduled stages: ${fmt(scheduled || 0)}.`);
      await refreshAll();
    }

    async function sendWorkerCommand() {
      const command = $("workerCommand").value;
      const worker_ids = onlineWorkers().map((row) => String(row.worker_id || row.id || "").trim()).filter(Boolean);
      if (!worker_ids.length) { toast("No online workers are available for a bulk command.", true); return; }
      const result = await json("/api/coord/workers/command", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ command, worker_ids }),
      });
      toast(`Queued ${command} for ${fmt(result.queued || 0)} worker(s).`);
      await refreshAll();
    }

    async function regenerateReport() {
      const result = await json("/api/regenerate-master-report", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ source: "operations_cockpit" }),
      });
      toast(result.ok ? "Master report regeneration requested." : "Report regeneration request completed.");
    }

    function bindAction(id, fn) {
      const node = $(id);
      if (!node) return;
      node.addEventListener("click", async () => {
        node.disabled = true;
        try { await fn(); }
        catch (err) { toast(String(err.message || err), true); }
        finally { node.disabled = false; }
      });
    }

    bindAction("refreshNowBtn", refreshAll);
    bindAction("registerTargetsBtn", registerTargets);
    bindAction("runWorkflowBtn", runWorkflow);
    bindAction("sendWorkerCommandBtn", sendWorkerCommand);
    bindAction("regenerateReportBtn", regenerateReport);

    refreshAll().catch((err) => {
      toast(String(err.message || err), true);
      renderAll();
    });
    setInterval(() => {
      if (!document.hidden) refreshAll().catch((err) => toast(String(err.message || err), true));
    }, 30000);
  </script>
</body>
</html>
