<!doctype html><html lang="en"><head><meta charset="utf-8"><title>Workflow Runs</title>
<style>body{font-family:Segoe UI,Arial,sans-serif;margin:16px;background:#f8fafc;color:#0f172a}.panel{background:white;border:1px solid #cbd5e1;border-radius:10px;padding:12px;margin-bottom:12px}table{width:100%;border-collapse:collapse;background:white}td,th{border:1px solid #cbd5e1;padding:7px;text-align:left;font-size:13px}th{background:#f1f5f9}.muted{color:#64748b}.badge{border:1px solid #cbd5e1;border-radius:999px;padding:2px 8px;font-weight:700;font-size:11px;text-transform:uppercase}.b-queued,.b-created{border-color:#cbd5e1;background:#f8fafc;color:#334155}.b-running{border-color:#38bdf8;background:#f0f9ff;color:#0369a1}.b-completed,.b-succeeded{border-color:#86efac;background:#f0fdf4;color:#166534}.b-failed{border-color:#fca5a5;background:#fef2f2;color:#991b1b}.b-canceled{border-color:#ddd6fe;background:#f5f3ff;color:#5b21b6}</style></head>
<body>{% include "_navbar.html.j2" %}<h1>Workflow Runs</h1><div class="panel"><button onclick="loadRuns()">Refresh</button> <a href="/workflow-definitions">Launch from Workflow Definitions</a></div><div class="panel"><table><thead><tr><th>Run</th><th>Workflow</th><th>Domain</th><th>Status</th><th>Steps</th><th>Created</th></tr></thead><tbody id="rows"></tbody></table></div><pre id="detail" class="panel muted"></pre>
<script>
function esc(v){return String(v ?? '').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function statusBadge(status){const s=String(status||'queued').toLowerCase(); const cls=['queued','created','running','completed','failed','canceled','succeeded'].includes(s)?s:'queued'; return `<span class="badge b-${esc(cls)}">${esc(s)}</span>`;}
async function api(u){return window.NightmareAuth ? NightmareAuth.fetchJson(u) : (async()=>{const r=await fetch(u);const j=await r.json().catch(()=>({}));if(!r.ok)throw new Error(JSON.stringify(j));return j})();}
async function loadRuns(){if(document.hidden)return; const data=await api('/api/workflow-runs'); rows.innerHTML=(data.items||[]).map(r=>`<tr onclick="loadDetail('${esc(r.id)}')"><td>${esc(r.id)}</td><td>${esc(r.workflow_key)} v${esc(r.workflow_version)}</td><td>${esc(r.root_domain||'')}</td><td>${statusBadge(r.status)}</td><td>${esc(r.completed_steps)}/${esc(r.total_steps)}</td><td>${esc(r.created_at_utc||'')}</td></tr>`).join('')}
async function loadDetail(id){detail.textContent=JSON.stringify((await api('/api/workflow-runs/'+encodeURIComponent(id))).item,null,2)}
loadRuns(); setInterval(loadRuns,30000); document.addEventListener("visibilitychange",()=>{if(!document.hidden)loadRuns();});
</script></body></html>