<!doctype html><html lang="en"><head><meta charset="utf-8"><title>Workflow Runs</title>
<style>body{font-family:Segoe UI,Arial,sans-serif;margin:16px;background:#f8fafc;color:#0f172a}.panel{background:white;border:1px solid #cbd5e1;border-radius:10px;padding:12px;margin-bottom:12px}.toolbar{display:flex;gap:8px;align-items:center;flex-wrap:wrap}input{padding:6px 8px;border:1px solid #94a3b8;border-radius:6px}button{border:1px solid #94a3b8;background:#fff;border-radius:6px;padding:6px 10px;cursor:pointer}.primary{background:#0ea5e9;border-color:#0284c7;color:#fff}.warn{background:#dc2626;border-color:#b91c1c;color:#fff}table{width:100%;border-collapse:collapse;background:white}td,th{border:1px solid #cbd5e1;padding:7px;text-align:left;font-size:13px}th{background:#f1f5f9}.muted{color:#64748b}.row-selected{background:#ecfeff}.badge{border:1px solid #cbd5e1;border-radius:999px;padding:2px 8px;font-weight:700;font-size:11px;text-transform:uppercase}.b-queued,.b-created{border-color:#cbd5e1;background:#f8fafc;color:#334155}.b-running{border-color:#38bdf8;background:#f0f9ff;color:#0369a1}.b-completed,.b-succeeded{border-color:#86efac;background:#f0fdf4;color:#166534}.b-failed{border-color:#fca5a5;background:#fef2f2;color:#991b1b}.b-canceled{border-color:#ddd6fe;background:#f5f3ff;color:#5b21b6}</style></head>
<body>{% include "_navbar.html.j2" %}<h1>Workflow Runs</h1>
<div class="panel toolbar"><input id="token" type="password" placeholder="Coordinator token (optional)"><button onclick="loadRuns()">Refresh</button> <a href="/workflow-definitions">Launch from Workflow Definitions</a> <span id="status" class="muted"></span></div>
<div class="panel toolbar"><input id="reason" type="text" placeholder="Reason for cancel/retry" value="Manual UI operation"><button class="warn" id="cancelRunBtn" disabled>Cancel Selected Run</button><button class="primary" id="retryRunBtn" disabled>Retry Failed Tasks (Selected Run)</button></div>
<div class="panel"><table><thead><tr><th>Run</th><th>Workflow</th><th>Domain</th><th>Status</th><th>Steps</th><th>Created</th></tr></thead><tbody id="rows"></tbody></table></div><pre id="detail" class="panel muted"></pre>
<script>
const TOKEN_COOKIE_NAME='nightmare_coord_token'; let selectedRunId='';
function esc(v){return String(v ?? '').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function statusBadge(status){const s=String(status||'queued').toLowerCase(); const cls=['queued','created','running','completed','failed','canceled','succeeded'].includes(s)?s:'queued'; return `<span class="badge b-${esc(cls)}">${esc(s)}</span>`;}
function readCookie(name){const needle=`${name}=`; for(const part of String(document.cookie||'').split(';')){const item=part.trim(); if(item.startsWith(needle)) return decodeURIComponent(item.slice(needle.length));} return '';}
function writeCookie(name,value,days){const maxAge=Math.max(1,Number(days||30))*24*60*60; const secure=location.protocol==='https:'?'; Secure':''; document.cookie=`${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${maxAge}; SameSite=Strict${secure}`;}
function deleteCookie(name){const secure=location.protocol==='https:'?'; Secure':''; document.cookie=`${name}=; Path=/; Max-Age=0; SameSite=Strict${secure}`;}
function authHeaders(){const token=document.getElementById('token').value.trim(); if(token) writeCookie(TOKEN_COOKIE_NAME,token,30); else deleteCookie(TOKEN_COOKIE_NAME); return token?{Authorization:`Bearer ${token}`}:{ };}
function hydrateToken(){const token=readCookie(TOKEN_COOKIE_NAME); if(token) document.getElementById('token').value=token;}
function setStatus(msg){document.getElementById('status').textContent=String(msg||'');}
function actionButtonsEnabled(enabled){document.getElementById('cancelRunBtn').disabled=!enabled; document.getElementById('retryRunBtn').disabled=!enabled;}
async function api(u, opts){if(window.NightmareAuth){return NightmareAuth.fetchJson(u, opts||{});} const r=await fetch(u, opts); const j=await r.json().catch(()=>({})); if(!r.ok)throw new Error(typeof j.detail==='string'?j.detail:JSON.stringify(j.detail||j)); return j;}
async function loadRuns(){if(document.hidden)return; setStatus('Loading runs...'); const data=await api('/api/workflow-runs'); rows.innerHTML=(data.items||[]).map(r=>{const id=String(r.id||''); const selected=selectedRunId===id?'row-selected':''; return `<tr class="${selected}" data-run-id="${esc(id)}"><td>${esc(id)}</td><td>${esc(r.workflow_key)} v${esc(r.workflow_version)}</td><td>${esc(r.root_domain||'')}</td><td>${statusBadge(r.status)}</td><td>${esc(r.completed_steps)}/${esc(r.total_steps)}</td><td>${esc(r.created_at_utc||'')}</td></tr>`}).join('');
 if(!selectedRunId && (data.items||[]).length){selectedRunId=String(data.items[0].id||'');}
 rows.querySelectorAll('tr[data-run-id]').forEach(row=>row.addEventListener('click',async()=>{selectedRunId=String(row.getAttribute('data-run-id')||''); await loadDetail(selectedRunId); await loadRuns();}));
 actionButtonsEnabled(Boolean(selectedRunId)); if(selectedRunId) await loadDetail(selectedRunId); setStatus(`Loaded ${(data.items||[]).length} run(s)`);}
async function loadDetail(id){if(!id){detail.textContent='';return;} detail.textContent=JSON.stringify((await api('/api/workflow-runs/'+encodeURIComponent(id))).item,null,2)}
async function cancelSelectedRun(){if(!selectedRunId)return; const reason=String(document.getElementById('reason').value||'Manual UI operation'); if(!confirm(`Cancel workflow run ${selectedRunId}?`)) return; setStatus('Canceling run...'); await api('/api/coord/workflow/run/cancel',{method:'POST',headers:{'Content-Type':'application/json',...authHeaders()},body:JSON.stringify({workflow_run_id:selectedRunId,actor:'web-ui',reason})}); await loadRuns(); setStatus(`Canceled run ${selectedRunId}`);}
async function retrySelectedRun(){if(!selectedRunId)return; const reason=String(document.getElementById('reason').value||'Manual UI operation'); if(!confirm(`Retry failed tasks for run ${selectedRunId}?`)) return; setStatus('Retrying failed tasks...'); const result=await api('/api/coord/workflow/tasks/retry-failed',{method:'POST',headers:{'Content-Type':'application/json',...authHeaders()},body:JSON.stringify({workflow_run_id:selectedRunId,actor:'web-ui',reason,limit:5000})}); await loadRuns(); setStatus(`Retried ${Number(result.retried||0)} failed task(s) for ${selectedRunId}`);}
document.getElementById('cancelRunBtn').addEventListener('click',()=>{cancelSelectedRun().catch(e=>setStatus(`Cancel failed: ${e.message||e}`));});
document.getElementById('retryRunBtn').addEventListener('click',()=>{retrySelectedRun().catch(e=>setStatus(`Retry failed: ${e.message||e}`));});
hydrateToken(); loadRuns().catch(e=>setStatus(`Load failed: ${e.message||e}`)); setInterval(()=>loadRuns().catch(()=>{}),30000); document.addEventListener("visibilitychange",()=>{if(!document.hidden)loadRuns().catch(()=>{});});
</script></body></html>