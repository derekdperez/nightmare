<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Nightmare Dashboard</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 16px; background: #f7fafc; color: #0f172a; }
    h1 { margin: 0 0 10px; }
    .meta { color: #475569; margin-bottom: 14px; font-size: 13px; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; margin-bottom: 16px; }
    .card { background: #fff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px; }
    .k { font-size: 12px; color: #475569; }
    .v { font-size: 22px; font-weight: 700; margin-top: 4px; }
    .table-wrap { max-height: 680px; overflow: auto; border: 1px solid #cbd5e1; border-radius: 8px; background: #fff; }
    table { width: 100%; border-collapse: collapse; background: #fff; border: 0; }
    th, td { border: 1px solid #cbd5e1; padding: 6px 8px; font-size: 12px; vertical-align: top; text-align: left; }
    th { background: #e2e8f0; position: sticky; top: 0; z-index: 3; }
    .log { white-space: pre-wrap; word-break: break-word; max-height: 220px; overflow: auto; margin: 0; background: #0b1220; color: #c8d3f5; padding: 8px; border-radius: 6px; }
    .rowlinks a { margin-right: 8px; }
    .muted { color: #64748b; }
    code { background: #e2e8f0; padding: 1px 4px; border-radius: 4px; }
  </style>
</head>
<body>
  {% include '_navbar.html.j2' %}
  <h1>Nightmare Live Dashboard</h1>
  <div class="meta">Auto-refresh every 5s. Reports are served from this app via <code>/files/*</code>.</div>
  <div class="meta">Workflow controls: <a href="/workflows">Workflow Monitor</a> | <a href="/workflows#recon">Run Recon</a></div>
  <div class="meta"><input id="domainSearch" type="text" placeholder="Search all domain table columns" style="padding:6px 8px;border:1px solid #94a3b8;border-radius:6px;min-width:320px;"></div>
  <div id="cards" class="cards"></div>
  <h2>Master Reports</h2>
  <div id="masters" class="muted">Loading...</div>
  <h2>Domains</h2>
  <div class="table-wrap">
    <table id="dashboardDomainsTable">
      <thead>
        <tr>
          <th>Domain</th>
          <th>Status</th>
          <th>URLs</th>
          <th>Findings</th>
          <th>Reports</th>
          <th>Latest Log Tail</th>
        </tr>
      </thead>
      <tbody id="rows"><tr><td colspan="6">Loading...</td></tr></tbody>
    </table>
  </div>
  {% include '_grid_controls.html.j2' %}
  <script>
    let dashboardGridCtrl = null;
    const DASHBOARD_CACHE_KEY = "nightmare_dashboard_summary_cache_v1";
    const DASHBOARD_CACHE_TTL_MS = 2 * 60 * 1000;
    function esc(v) {
      return String(v || "").replace(/[&<>\"']/g, (ch) => ({ "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;" }[ch]));
    }
    function readLocalJson(key) {
      try {
        const raw = localStorage.getItem(String(key || ""));
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : null;
      } catch (_e) {
        return null;
      }
    }
    function writeLocalJson(key, value) {
      try {
        localStorage.setItem(String(key || ""), JSON.stringify(value ?? {}));
      } catch (_e) {
        // Ignore cache write failures; live fetch is still authoritative.
      }
    }
    function loadCachedDashboard() {
      const row = readLocalJson(DASHBOARD_CACHE_KEY);
      if (!row) return null;
      const cachedAt = Number(row.cached_at_epoch_ms || 0);
      if (!Number.isFinite(cachedAt) || cachedAt <= 0) return null;
      if ((Date.now() - cachedAt) > DASHBOARD_CACHE_TTL_MS) return null;
      const payload = row.payload;
      return payload && typeof payload === "object" ? payload : null;
    }
    function saveCachedDashboard(payload) {
      writeLocalJson(DASHBOARD_CACHE_KEY, {
        cached_at_epoch_ms: Date.now(),
        payload: payload || {},
      });
    }
    function fileLink(relPath, label) {
      if (!relPath) return "";
      const encoded = encodeURIComponent(relPath).replace(/%2F/g, "/");
      return `<a href="/files/${encoded}" target="_blank" rel="noopener noreferrer">${esc(label)}</a>`;
    }
    function showLoadError(message) {
      const msg = esc(message || "Unknown error");
      document.getElementById("masters").innerHTML = `<span class='muted'>Failed to load: ${msg}</span>`;
      document.getElementById("rows").innerHTML = `<tr><td colspan='6'>Failed to load dashboard summary: ${msg}</td></tr>`;
    }
    function buildCards(t) {
      const cards = [
        ["Domains", t.domains],
        ["Running", t.running],
        ["Pending", t.pending],
        ["Completed", t.completed],
        ["Failed", t.failed],
        ["Discovered Only", t.discovered],
      ];
      return cards.map(([k, v]) => `<div class="card"><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`).join("");
    }
    function render(data) {
      document.getElementById("cards").innerHTML = buildCards(data.totals || {});
      const masters = (data.master_reports || []).map((m) => fileLink(m.relative, m.name)).join(" | ");
      document.getElementById("masters").innerHTML = masters || "<span class='muted'>No master reports found.</span>";

      const rows = data.domains || [];
      if (!rows.length) {
        document.getElementById("rows").innerHTML = "<tr><td colspan='6'>No domain output folders found.</td></tr>";
        return;
      }
      document.getElementById("rows").innerHTML = rows.map((d) => {
        const p = d.paths_rel || {};
        const links = [
          fileLink(p.nightmare_report_html, "Nightmare HTML"),
          fileLink(p.fozzy_results_html, "Fozzy HTML"),
          fileLink(p.url_inventory, "URL Inventory"),
          fileLink(p.requests, "Requests JSON"),
          fileLink(p.fozzy_summary_json, "Fozzy Summary")
        ].filter(Boolean).join(" ");
        return `<tr>
          <td>${esc(d.domain)}</td>
          <td>${esc(d.status)}</td>
          <td>unique=${esc(d.unique_urls)}<br>requested=${esc(d.requested_urls)}</td>
          <td>anomalies=${esc(d.anomalies)}<br>reflections=${esc(d.reflections)}</td>
          <td class="rowlinks">${links || "<span class='muted'>none</span>"}</td>
          <td><pre class="log">${esc(d.latest_log_tail || "")}</pre></td>
        </tr>`;
      }).join("");
      if (!dashboardGridCtrl) {
        dashboardGridCtrl = window.NightmareGridControls.enhance({
          table: "dashboardDomainsTable",
          page: "dashboard",
          prefKey: "domains_table_v1",
          mode: "full",
          globalSearchInputId: "domainSearch",
        });
      } else {
        dashboardGridCtrl.refresh();
      }
    }
    async function refresh(options) {
      const useCacheFirst = Boolean(options && options.useCacheFirst);
      let showedCached = false;
      if (useCacheFirst) {
        const cached = loadCachedDashboard();
        if (cached) {
          render(cached);
          showedCached = true;
        }
      }
      try {
        const rsp = await fetch("/api/summary", { cache: "no-store" });
        if (!rsp.ok) {
          if (!showedCached) showLoadError(`HTTP ${rsp.status}`);
          return;
        }
        const data = await rsp.json();
        render(data);
        saveCachedDashboard(data);
      } catch (e) {
        if (!showedCached) showLoadError(e && e.message ? e.message : "request failed");
      }
    }
    refresh({ useCacheFirst: true });
    setInterval(() => refresh(), 5000);
  </script>
</body>
</html>
