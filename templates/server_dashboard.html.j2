<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Nightmare Dashboard</title>
  <style>
    :root {
      --bg: #f8fafc;
      --surface: #ffffff;
      --surface-soft: #f1f5f9;
      --text: #0f172a;
      --muted: #64748b;
      --border: #cbd5e1;
      --border-strong: #94a3b8;
      --primary: #0284c7;
      --primary-strong: #0369a1;
      --danger: #b91c1c;
      --danger-bg: #fef2f2;
      --ok-bg: #ecfdf5;
      --ok-text: #047857;
      --warn-bg: #fffbeb;
      --warn-text: #b45309;
      --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
      --radius: 14px;
    }
    * { box-sizing: border-box; }
    body {
      font-family: Segoe UI, system-ui, -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
      margin: 16px;
      background: var(--bg);
      color: var(--text);
      line-height: 1.45;
    }
    a { color: var(--primary-strong); }
    .skip-link {
      position: absolute;
      left: 12px;
      top: -48px;
      z-index: 200;
      background: var(--text);
      color: #fff;
      padding: 8px 12px;
      border-radius: 8px;
      text-decoration: none;
      transition: top .15s ease;
    }
    .skip-link:focus { top: 12px; }
    .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
    .page-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 16px;
      align-items: end;
      margin-bottom: 16px;
    }
    h1 { margin: 0; font-size: clamp(1.7rem, 3vw, 2.45rem); letter-spacing: -0.035em; }
    h2 { margin: 0; font-size: 1rem; letter-spacing: -0.01em; }
    .meta { color: #475569; font-size: 13px; }
    .page-header .meta { max-width: 760px; margin-top: 6px; }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      margin: 12px 0 18px;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }
    .card .k { font-size: 12px; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
    .card .v { font-size: 24px; font-weight: 800; margin-top: 5px; letter-spacing: -0.03em; }
    .section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      margin-bottom: 16px;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }
    .section-count { color: var(--muted); font-size: 12px; font-weight: 600; }
    .table-wrap {
      max-height: 460px;
      overflow: auto;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--surface);
      box-shadow: inset 0 1px 0 rgba(15, 23, 42, 0.04);
    }
    .table-wrap.events-stream { max-height: 28vh; min-height: 160px; }
    table { width: 100%; border-collapse: separate; border-spacing: 0; }
    th, td {
      border-bottom: 1px solid #e2e8f0;
      padding: 8px 10px;
      font-size: 12px;
      text-align: left;
      vertical-align: top;
    }
    tbody tr:nth-child(even) { background: #f8fafc; }
    tbody tr:hover { background: #eff6ff; }
    th {
      background: #e2e8f0;
      position: sticky;
      top: 0;
      z-index: 2;
      color: #334155;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }
    td code, code { background: #e2e8f0; border-radius: 6px; padding: 2px 5px; }
    .toolbar {
      position: sticky;
      top: 78px;
      z-index: 20;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 12px;
      padding: 10px;
      background: rgba(248, 250, 252, 0.9);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(203, 213, 225, 0.9);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .search-wrap { position: relative; flex: 1 1 320px; max-width: 560px; }
    input {
      width: 100%;
      padding: 9px 12px;
      border: 1px solid var(--border-strong);
      border-radius: 10px;
      background: #fff;
      color: var(--text);
      min-height: 38px;
    }
    input:focus, button:focus-visible {
      outline: 3px solid rgba(14, 165, 233, 0.32);
      outline-offset: 2px;
      border-color: var(--primary);
    }
    button {
      border: 1px solid var(--border-strong);
      background: #fff;
      border-radius: 10px;
      padding: 8px 11px;
      min-height: 38px;
      cursor: pointer;
      font-weight: 700;
      color: #334155;
    }
    button:hover { background: #f1f5f9; border-color: #64748b; }
    button.primary { background: var(--primary); border-color: var(--primary); color: #fff; }
    button.primary:hover { background: var(--primary-strong); }
    button.warn { background: var(--danger-bg); border-color: #fecaca; color: var(--danger); }
    .muted { color: var(--muted); }
    .status-line {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      min-height: 24px;
      font-size: 13px;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 3px 9px;
      font-size: 11px;
      font-weight: 800;
      border: 1px solid var(--border);
      background: var(--surface-soft);
      color: #334155;
      white-space: nowrap;
    }
    .pill.ok { background: var(--ok-bg); color: var(--ok-text); border-color: #bbf7d0; }
    .pill.warn { background: var(--warn-bg); color: var(--warn-text); border-color: #fde68a; }
    .pill.danger { background: var(--danger-bg); color: var(--danger); border-color: #fecaca; }
    .empty-state { color: var(--muted); text-align: center; padding: 24px; }
    @media (max-width: 800px) {
      body { margin: 12px; }
      .page-header { grid-template-columns: 1fr; align-items: start; }
      .toolbar { top: 96px; }
      th, td { padding: 7px 8px; }
    }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { scroll-behavior: auto !important; transition-duration: .001ms !important; animation-duration: .001ms !important; }
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#nightmare-dashboard-main">Skip to dashboard content</a>
  {% include '_navbar.html.j2' %}
  <header class="page-header">
    <div>
      <h1>Nightmare Live Dashboard</h1>
      <div class="meta">System health, worker activity, logs, events, and workflow status in one operational view.</div>
    </div>
    <div class="status-line" aria-live="polite">
      <span id="statusText" class="muted">Preparing dashboard...</span>
    </div>
  </header>
  <div class="toolbar" role="search" aria-label="Dashboard controls">
    <label class="search-wrap">
      <span class="sr-only">Search all dashboard tables</span>
      <input id="globalSearch" type="search" autocomplete="off" placeholder="Search VMs, containers, events, logs, workers...">
    </label>
    <button type="button" id="clearSearchBtn">Clear</button>
    <button type="button" id="refreshBtn" class="primary">Refresh now</button>
    <button type="button" id="toggleAutoRefreshBtn" aria-pressed="false">Pause auto-refresh</button>
    <button type="button" id="downloadDiagnosticsBtn">Download diagnostics</button>
    <span id="perfStats" class="muted">Cache: waiting. Network: waiting.</span>
  </div>
  <div id="cards" class="cards" aria-label="Dashboard summary"></div>

  <main id="nightmare-dashboard-main" tabindex="-1">
  <section class="section" aria-labelledby="vm-heading">
    <div class="section-header"><h2 id="vm-heading">Virtual Machines</h2><span class="section-count" data-count-for="vmRows">Loading</span></div>
    <div class="table-wrap"><table id="vmTable"><thead><tr><th>Name</th><th>Instance ID</th><th>State</th><th>Private IP</th><th>Public IP</th><th>Disk (Total/Free GB)</th><th>Uptime</th><th>Last Seen (EST)</th><th>Actions</th></tr></thead><tbody id="vmRows"><tr><td colspan="9">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="docker-heading">
    <div class="section-header"><h2 id="docker-heading">Docker Images / Containers</h2><span class="section-count" data-count-for="dockerRows">Loading</span></div>
    <div class="table-wrap"><table id="dockerTable"><thead><tr><th>Container</th><th>Host</th><th>Image</th><th>Status</th><th>Running For</th><th>Ports</th><th>Container ID</th></tr></thead><tbody id="dockerRows"><tr><td colspan="7">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="events-heading">
    <div class="section-header"><h2 id="events-heading">System Events</h2><span class="section-count" data-count-for="eventRows">Loading</span></div>
    <div class="table-wrap events-stream"><table id="eventTable"><thead><tr><th>When</th><th>Type</th><th>Source</th><th>Aggregate</th><th>Message</th></tr></thead><tbody id="eventRows"><tr><td colspan="5">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="db-heading">
    <div class="section-header"><h2 id="db-heading">Database Inserts / Table Activity</h2><span class="section-count" data-count-for="dbRows">Loading</span></div>
    <div class="table-wrap"><table id="dbTable"><thead><tr><th>Schema</th><th>Table</th><th>Rows</th><th>Columns</th><th>Last Update (EST)</th><th>Table Size (MB)</th></tr></thead><tbody id="dbRows"><tr><td colspan="6">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="logs-heading">
    <div class="section-header"><h2 id="logs-heading">Recent Log Messages</h2><span class="section-count" data-count-for="logRows">Loading</span></div>
    <div class="table-wrap"><table id="logTable"><thead><tr><th>When</th><th>Severity</th><th>Machine</th><th>Source</th><th>Description</th></tr></thead><tbody id="logRows"><tr><td colspan="5">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="workers-heading">
    <div class="section-header"><h2 id="workers-heading">Plugin Worker Details</h2><span class="section-count" data-count-for="pluginWorkerRows">Loading</span></div>
    <div class="table-wrap"><table id="pluginWorkerTable"><thead><tr><th>Worker</th><th>Status</th><th>State</th><th>Current Domain</th><th>Current Stage</th><th>Running Targets</th><th>Running Stage Tasks</th><th>Last Heartbeat</th><th>Last Run Time (EST)</th><th>Last Workflow Ran</th></tr></thead><tbody id="pluginWorkerRows"><tr><td colspan="10">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="workflow-heading">
    <div class="section-header"><h2 id="workflow-heading">Running Workflow Details</h2><span class="section-count" data-count-for="workflowRows">Loading</span></div>
    <div class="table-wrap"><table id="workflowTable"><thead><tr><th>Domain</th><th>Running Tasks</th><th>Pending Tasks</th><th>Failed Tasks</th><th>Active Stages</th><th>Workflow IDs</th></tr></thead><tbody id="workflowRows"><tr><td colspan="6">Loading...</td></tr></tbody></table></div>
  </section>
  <section class="section" aria-labelledby="observability-heading">
    <div class="section-header"><h2 id="observability-heading">Coordinator Observability</h2><span class="section-count" data-count-for="observabilityRows">Loading</span></div>
    <div class="table-wrap"><table id="observabilityTable"><thead><tr><th>Metric</th><th>Value</th></tr></thead><tbody id="observabilityRows"><tr><td colspan="2">Loading...</td></tr></tbody></table></div>
    <div class="muted" style="margin-top:8px">
      Workflow controls are available at <a href="/workflow-runs">Workflow Runs</a> (cancel run + retry failed tasks).
    </div>
  </section>
  <section class="section" aria-labelledby="sources-heading">
    <div class="section-header"><h2 id="sources-heading">Detailed Log Sources</h2><span class="section-count" data-count-for="logSourceRows">Loading</span></div>
    <div class="table-wrap"><table id="logSourceTable"><thead><tr><th>Label</th><th>Type</th><th>Source ID</th><th>Details</th></tr></thead><tbody id="logSourceRows"><tr><td colspan="4">Loading...</td></tr></tbody></table></div>
  </section>
  </main>

  <script>
    const DASHBOARD_CACHE_KEY = "nightmare_dashboard_snapshot_v1";
    const DASHBOARD_CACHE_MAX_AGE_MS = 120000;
    function esc(v){return String(v ?? "").replace(/[&<>\"']/g,(ch)=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[ch]));}
    function showLoadError(message){ document.getElementById("statusText").textContent = `Load failed: ${String(message || "unknown error")}`; }
    function debounce(fn, delayMs) {
      let timer = null;
      return (...args) => {
        window.clearTimeout(timer);
        timer = window.setTimeout(() => fn(...args), delayMs);
      };
    }
    function updateRowCount(tbodyId) {
      const tbody = document.getElementById(tbodyId);
      const label = document.querySelector(`[data-count-for="${tbodyId}"]`);
      if (!tbody || !label) return;
      const rows = Array.from(tbody.querySelectorAll("tr"));
      const total = rows.filter((tr) => !tr.dataset.emptyRow).length;
      const visible = rows.filter((tr) => !tr.dataset.emptyRow && tr.style.display !== "none").length;
      label.textContent = total ? `${visible} of ${total} shown` : "No rows";
    }
    function updateAllRowCounts() {
      document.querySelectorAll("[data-count-for]").forEach((node) => updateRowCount(node.dataset.countFor || ""));
    }
    function applySearch() {
      const root = document.getElementById("nightmare-dashboard-main");
      const input = document.getElementById("globalSearch");
      const needle = String(input && input.value || "").trim().toLowerCase();
      const scope = root && root.querySelectorAll ? root.querySelectorAll(".table-wrap tbody tr") : document.querySelectorAll(".table-wrap tbody tr");
      scope.forEach((tr) => {
        if (tr.dataset.emptyRow) return;
        const text = String(tr.textContent || "").toLowerCase();
        tr.style.display = (!needle || text.includes(needle)) ? "" : "none";
      });
      updateAllRowCounts();
    }
    /** Prefer the first array found (APIs use different keys across endpoints). */
    function firstArray(...candidates) {
      for (let i = 0; i < candidates.length; i += 1) {
        const c = candidates[i];
        if (Array.isArray(c)) return c;
      }
      return [];
    }
    async function authJson(url, init = { method: "GET" }) {
      const reqInit = { cache: "no-store", credentials: "same-origin", ...(init || {}) };
      if (window.NightmareAuth && typeof window.NightmareAuth.fetchJson === "function") {
        return await window.NightmareAuth.fetchJson(url, reqInit);
      }
      const rsp = await fetch(url, reqInit);
      const payload = await rsp.json().catch(() => ({}));
      if (!rsp.ok) throw new Error(String(payload.error || payload.detail || `HTTP ${rsp.status}`));
      return payload;
    }
    function setRows(id, html, cols) {
      const el = document.getElementById(id);
      if (!el) return;
      el.innerHTML = html || `<tr data-empty-row="true"><td class="empty-state" colspan="${cols}">No rows match this view.</td></tr>`;
      updateRowCount(id);
    }
    function _safeReadDashboardCache() {
      try {
        const raw = window.localStorage.getItem(DASHBOARD_CACHE_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object") return null;
        const createdAtMs = Number(parsed.created_at_ms || 0);
        if (!createdAtMs || (Date.now() - createdAtMs) > DASHBOARD_CACHE_MAX_AGE_MS) return null;
        return parsed;
      } catch (_) {
        return null;
      }
    }
    function _safeWriteDashboardCache(snapshot) {
      try {
        window.localStorage.setItem(DASHBOARD_CACHE_KEY, JSON.stringify(snapshot));
      } catch (_) {
        // Best-effort cache only.
      }
    }
    function _applyCachedDashboardSnapshot() {
      const snapshot = _safeReadDashboardCache();
      if (!snapshot) return false;
      const rows = snapshot.rows || {};
      if (rows.vmRows) setRows("vmRows", rows.vmRows, 9);
      if (rows.dockerRows) setRows("dockerRows", rows.dockerRows, 7);
      if (rows.eventRows) setRows("eventRows", rows.eventRows, 5);
      if (rows.dbRows) setRows("dbRows", rows.dbRows, 6);
      if (rows.logRows) setRows("logRows", rows.logRows, 5);
      if (rows.pluginWorkerRows) setRows("pluginWorkerRows", rows.pluginWorkerRows, 10);
      if (rows.workflowRows) setRows("workflowRows", rows.workflowRows, 6);
      if (rows.observabilityRows) setRows("observabilityRows", rows.observabilityRows, 2);
      if (rows.logSourceRows) setRows("logSourceRows", rows.logSourceRows, 4);
      if (snapshot.cardsHtml) {
        const cardsEl = document.getElementById("cards");
        if (cardsEl) cardsEl.innerHTML = String(snapshot.cardsHtml);
      }
      const status = document.getElementById("statusText");
      if (status) {
        const ts = snapshot.generated_at || "";
        status.textContent = `Loaded cached snapshot${ts ? ` (${ts})` : ""}; refreshing...`;
      }
      applySearch();
      return true;
    }
    function settledValue(result, fallback) {
      if (!result || result.status !== "fulfilled") return fallback;
      return result.value ?? fallback;
    }
    function settledError(result) {
      if (!result || result.status !== "rejected") return "";
      const reason = result.reason;
      return reason && reason.message ? String(reason.message) : String(reason || "request failed");
    }
    function asArray(value) {
      return Array.isArray(value) ? value : [];
    }
    function est(value) {
      if (!value) return "";
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return String(value || "");
      return d.toLocaleString("en-US", { timeZone: "Etc/GMT+5", hour12: false });
    }
    function statusPill(value) {
      const text = String(value || "").trim();
      if (!text) return "";
      const lowered = text.toLowerCase();
      const tone = /fail|error|terminate|down|stopped|offline|critical/.test(lowered)
        ? "danger"
        : /warn|pending|stale|starting|unknown/.test(lowered)
          ? "warn"
          : /run|online|active|ok|success|ready|idle/.test(lowered)
            ? "ok"
            : "";
      return `<span class="pill ${tone}">${esc(text)}</span>`;
    }
    const TOKEN_COOKIE_NAME = "nightmare_coord_token";
    function readCookie(name) {
      return document.cookie.split(";").map((p) => p.trim()).find((p) => p.startsWith(`${name}=`))?.slice(name.length + 1) || "";
    }
    function readAuthToken() {
      const cookieToken = decodeURIComponent(readCookie(TOKEN_COOKIE_NAME) || "").trim();
      if (cookieToken) return cookieToken;
      try { return String(window.localStorage.getItem(TOKEN_COOKIE_NAME) || "").trim(); } catch { return ""; }
    }
    function buildEventLogStreamUrl() {
      const params = new URLSearchParams();
      params.set("after_sequence", "0");
      params.set("poll_interval_ms", "1000");
      const token = readAuthToken();
      if (token) params.set("coordinator_token", token);
      return `/api/coord/event-log/stream?${params.toString()}`;
    }
    async function handleVmAction(action, instanceId) {
      if (!instanceId) return;
      if (!window.confirm(`${action} VM ${instanceId}?`)) return;
      try {
        document.getElementById("statusText").textContent = `${action} requested for ${instanceId}...`;
        await authJson("/api/coord/vm/action", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action, instance_id: instanceId }),
        });
        document.getElementById("statusText").textContent = `${action} command submitted for ${instanceId}.`;
        await refreshDashboard();
      } catch (error) {
        showLoadError(error && error.message ? error.message : String(error));
      }
    }
    let dashboardEventStream = null;
    let dashboardRefreshInFlight = false;
    let dashboardAutoRefreshPaused = false;
    let dashboardAutoRefreshTimer = null;
    function closeEventStream() {
      if (!dashboardEventStream) return;
      try { dashboardEventStream.close(); } catch (_) {}
      dashboardEventStream = null;
    }
    function getPerfStatsNode() {
      return document.getElementById("perfStats");
    }
    function setCacheTiming(ms, ageMs) {
      const node = getPerfStatsNode();
      if (!node) return;
      const age = Number(ageMs || 0);
      const cacheAgeLabel = age > 0 ? ` (cache age ${Math.round(age)} ms)` : "";
      const existing = String(node.textContent || "");
      const dbPart = existing.includes("Database fetch:") ? existing.split("Database fetch:")[1].trim() : "waiting.";
      node.textContent = `Cache load: ${Math.round(Number(ms || 0))} ms${cacheAgeLabel}. Database fetch: ${dbPart}`;
    }
    function setDbTiming(ms) {
      const node = getPerfStatsNode();
      if (!node) return;
      const existing = String(node.textContent || "");
      const cachePart = existing.includes("Database fetch:") ? existing.split("Database fetch:")[0].trim() : "Cache load: waiting.";
      node.textContent = `${cachePart} Database fetch: ${Math.round(Number(ms || 0))} ms.`;
    }
    function renderEventRows(eventList) {
      const rows = asArray(eventList).map((e) =>
        `<tr><td>${esc(est(e.created_at || e.created_at_utc || ""))}</td><td>${esc(e.event_type || "")}</td><td>${esc(e.source || "")}</td><td>${esc(e.aggregate_key || "")}</td><td>${esc(e.message || "")}</td></tr>`
      ).join("");
      setRows("eventRows", rows, 5);
      return rows;
    }
    function appendEventLogItem(e) {
      if (dashboardAutoRefreshPaused) return;
      const tbody = document.getElementById("eventRows");
      if (!tbody) return;
      if (tbody.children.length === 1 && String(tbody.textContent || "").toLowerCase().includes("loading")) {
        tbody.innerHTML = "";
      }
      const tr = document.createElement("tr");
      tr.innerHTML = `<td>${esc(est(e.created_at || e.created_at_utc || ""))}</td><td>${esc(e.event_type || "")}</td><td>${esc(e.source || "")}</td><td>${esc(e.aggregate_key || "")}</td><td>${esc(e.message || "")}</td>`;
      tbody.prepend(tr);
      while (tbody.children.length > 1000) tbody.removeChild(tbody.lastChild);
      applySearch();
    }
    function subscribeToEventStream() {
      if (dashboardAutoRefreshPaused) return;
      if (dashboardEventStream) return;
      try {
        const es = new EventSource(buildEventLogStreamUrl(), { withCredentials: true });
        es.addEventListener("coordinator_event", (event) => {
          try {
            const payload = JSON.parse(String(event && event.data || "{}"));
            appendEventLogItem(payload);
          } catch (_) {
            // Ignore malformed SSE payloads and continue streaming.
          }
        });
        es.onerror = () => {
          // Keep the UI resilient if stream temporarily fails.
        };
        dashboardEventStream = es;
      } catch (_) {
        dashboardEventStream = null;
      }
    }
    function setAutoRefreshPaused(paused) {
      dashboardAutoRefreshPaused = Boolean(paused);
      if (dashboardAutoRefreshPaused) {
        closeEventStream();
      } else {
        subscribeToEventStream();
      }
      const btn = document.getElementById("toggleAutoRefreshBtn");
      if (btn) {
        btn.setAttribute("aria-pressed", String(dashboardAutoRefreshPaused));
        btn.textContent = dashboardAutoRefreshPaused ? "Resume auto-refresh" : "Pause auto-refresh";
      }
      const status = document.getElementById("statusText");
      if (status) status.textContent = dashboardAutoRefreshPaused ? "Auto-refresh paused." : "Auto-refresh resumed.";
    }
    async function refreshDashboard({ silent = false } = {}) {
      if (dashboardRefreshInFlight) return;
      dashboardRefreshInFlight = true;
      const status = document.getElementById("statusText");
      const refreshBtn = document.getElementById("refreshBtn");
      if (refreshBtn) refreshBtn.disabled = true;
      if (!silent && status) status.textContent = "Loading...";
      try {
        const startedAt = performance.now();
        const results = await Promise.allSettled([
          authJson("/api/coord/docker-status?include_logs=0&log_lines=100"),
          authJson("/api/coord/events?limit=1000&offset=0&sort_dir=desc"),
          authJson("/api/coord/database-activity?limit=1000"),
          authJson("/api/coord/log-events?source_id=__all__&limit=100&offset=0&sort_dir=desc"),
          authJson("/api/coord/workers?stale_after_seconds=180"),
          authJson("/api/coord/workflow-snapshot?limit=2000"),
          authJson("/api/coord/log-sources"),
          authJson("/api/coord/observability/summary"),
        ]);
        const docker = settledValue(results[0], {});
        const events = settledValue(results[1], {});
        const db = settledValue(results[2], {});
        const logs = settledValue(results[3], {});
        const workers = settledValue(results[4], {});
        const workflows = settledValue(results[5], {});
        const logSources = settledValue(results[6], {});
        const observability = settledValue(results[7], {});
        setDbTiming(performance.now() - startedAt);

        const failedSources = [
          ["docker-status", settledError(results[0])],
          ["events", settledError(results[1])],
          ["database-status", settledError(results[2])],
          ["log-events", settledError(results[3])],
          ["workers", settledError(results[4])],
          ["workflow-snapshot", settledError(results[5])],
          ["log-sources", settledError(results[6])],
          ["observability-summary", settledError(results[7])],
        ].filter((item) => item[1]);

        const vmRows = asArray(docker.ec2_instances && docker.ec2_instances.instances).map((r) =>
          `<tr>
            <td>${esc(r.name || "")}</td>
            <td>${esc(r.instance_id || "")}</td>
            <td>${statusPill(r.state || "")}</td>
            <td>${esc(r.private_ip || "")}</td>
            <td>${esc(r.public_ip || "")}</td>
            <td>${esc(r.disk_total_gb || 0)}/${esc(r.disk_free_gb || 0)}</td>
            <td>${esc(r.uptime_text || "")}</td>
            <td>${esc(r.last_seen_est || est(r.last_seen_utc || ""))}</td>
            <td>
              <button type="button" data-vm-action="reboot" data-vm-id="${esc(r.instance_id || "")}">Reboot</button>
              <button type="button" data-vm-action="terminate" data-vm-id="${esc(r.instance_id || "")}" class="warn">Terminate</button>
              <button type="button" data-vm-action="update" data-vm-id="${esc(r.instance_id || "")}" class="primary">Update</button>
            </td>
          </tr>`
        ).join("");
        setRows("vmRows", vmRows, 9);
        document.querySelectorAll("button[data-vm-action][data-vm-id]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const vmId = String(btn.getAttribute("data-vm-id") || "");
            const action = String(btn.getAttribute("data-vm-action") || "");
            if (!vmId || vmId === "local-coordinator") return;
            void handleVmAction(action, vmId);
          });
        });

        const dockerRows = asArray(docker.all_containers).map((r) =>
          `<tr><td>${esc(r.name || "")}</td><td>${esc(r.host_label || r.host_type || "")}</td><td>${esc(r.image || "")}</td><td>${statusPill(r.status || "")}</td><td>${esc(r.running_for || "")}</td><td>${esc(r.ports || "")}</td><td><code>${esc(r.id || "")}</code></td></tr>`
        ).join("");
        setRows("dockerRows", dockerRows, 7);

        const eventList = firstArray(events.items, events.events);
        const eventRows = renderEventRows(eventList);

        const dbRows = asArray(db.tables).map((t) =>
          `<tr><td>${esc(t.schema || "")}</td><td>${esc(t.name || "")}</td><td>${esc(t.row_count || 0)}</td><td>${esc(t.column_count || 0)}</td><td>${esc(est(t.last_update_utc || ""))}</td><td>${esc(t.table_size_mb || 0)}</td></tr>`
        ).join("");
        setRows("dbRows", dbRows, 6);

        const logList = firstArray(logs.items, logs.events);
        const logRows = logList.map((l) =>
          `<tr><td>${esc(l.event_time_utc || "")}</td><td>${statusPill(l.severity || "")}</td><td>${esc(l.machine || "")}</td><td>${esc(l.source_id || "")}</td><td>${esc(l.description || "")}</td></tr>`
        ).join("");
        setRows("logRows", logRows, 5);

        const pluginWorkers = asArray(workers.workers).filter((w) => String(w.worker_id || "").toLowerCase().includes("-plugin-"));
        const pluginWorkerRows = pluginWorkers.map((w) =>
          `<tr><td>${esc(w.worker_id || "")}</td><td>${statusPill(w.status || "")}</td><td>${statusPill(w.worker_state || "")}</td><td>${esc(w.current_root_domain || w.current_stage_root_domain || "")}</td><td>${esc(w.current_stage || w.current_plugin_name || "")}</td><td>${esc(w.running_targets || 0)}</td><td>${esc(w.running_stage_tasks || 0)}</td><td>${esc(w.last_heartbeat_at_utc || "")}</td><td>${esc(est(w.last_run_time_at_utc || w.last_seen_time_at_utc || ""))}</td><td>${esc(w.last_workflow_ran || w.current_workflow_id || "")}</td></tr>`
        ).join("");
        setRows("pluginWorkerRows", pluginWorkerRows, 10);

        const runningWorkflowRows = [];
        for (const d of asArray(workflows.domains)) {
          const pluginTasks = d.plugin_tasks || {};
          let running = 0, pending = 0, failed = 0;
          const activeStages = [];
          const workflowIds = Object.keys(pluginTasks);
          for (const workflowId of workflowIds) {
            const stageMap = pluginTasks[workflowId] || {};
            for (const stageName of Object.keys(stageMap)) {
              const statusValue = String((stageMap[stageName] || {}).status || "").toLowerCase();
              if (statusValue === "running") { running += 1; activeStages.push(stageName); }
              else if (statusValue === "pending" || statusValue === "ready") pending += 1;
              else if (statusValue === "failed") failed += 1;
            }
          }
          if (running <= 0 && pending <= 0 && failed <= 0) continue;
          runningWorkflowRows.push(
            `<tr><td>${esc(d.root_domain || "")}</td><td>${running}</td><td>${pending}</td><td>${failed}</td><td>${esc(activeStages.slice(0, 8).join(", "))}</td><td>${esc(workflowIds.join(", "))}</td></tr>`
          );
        }
        setRows("workflowRows", runningWorkflowRows.join(""), 6);

        const logSourceRows = asArray(logSources.sources).map((s) => {
          const sourceId = String(s.source_id || "");
          const detailsHref = `/view-logs#source=${encodeURIComponent(sourceId)}`;
          const apiHref = `/api/coord/log-tail?source_id=${encodeURIComponent(sourceId)}&lines=200`;
          return `<tr><td>${esc(s.label || "")}</td><td>${esc(s.source_type || "")}</td><td><code>${esc(sourceId)}</code></td><td><a href="${detailsHref}">View Logs</a> | <a href="${apiHref}" target="_blank" rel="noopener noreferrer">Tail API</a></td></tr>`;
        }).join("");
        setRows("logSourceRows", logSourceRows, 4);

        const statusCounts = observability.stage_task_status_counts || {};
        const workerCounts = observability.workers || {};
        const observabilityRows = [
          ["Generated At", observability.generated_at_utc || ""],
          ["Active Workflow Runs", observability.active_workflow_runs || 0],
          ["Oldest Ready Task Age (s)", observability.oldest_ready_task_age_seconds || 0],
          ["Events (Last 5m)", (observability.event_volume || {}).last_5m || 0],
          ["Events (Last 1h)", (observability.event_volume || {}).last_1h || 0],
          ["Active Leases", (observability.leases || {}).active_leases || 0],
          ["Expired Leases", (observability.leases || {}).expired_leases || 0],
          ["Tasks Running", statusCounts.running || 0],
          ["Tasks Ready", statusCounts.ready || 0],
          ["Tasks Failed", statusCounts.failed || 0],
          ["Workers Online", workerCounts.online_workers || 0],
          ["Workers Idle", workerCounts.idle_workers || 0],
          ["Workers Running", workerCounts.running_workers || 0],
        ].map((row) => `<tr><td>${esc(row[0])}</td><td>${esc(row[1])}</td></tr>`).join("");
        setRows("observabilityRows", observabilityRows, 2);

        const cards = [
          ["VMs", asArray(docker.ec2_instances && docker.ec2_instances.instances).length],
          ["Containers", asArray(docker.all_containers).length],
          ["Events", eventList.length],
          ["DB Tables", asArray(db.tables).length],
          ["Log Messages", logList.length],
          ["Plugin Workers", pluginWorkers.length],
          ["Workflow Domains", asArray(workflows.domains).length],
          ["Active Runs", observability.active_workflow_runs || 0],
          ["Event Rate (5m)", (observability.event_volume || {}).last_5m || 0],
          ["Log Sources", asArray(logSources.sources).length],
        ];
        const cardsHtml = cards.map(([k,v]) => `<div class="card"><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`).join("");
        document.getElementById("cards").innerHTML = cardsHtml;
        _safeWriteDashboardCache({
          created_at_ms: Date.now(),
          generated_at: new Date().toISOString(),
          cardsHtml,
          rows: {
            vmRows,
            dockerRows,
            eventRows,
            dbRows,
            logRows,
            pluginWorkerRows,
            workflowRows: runningWorkflowRows.join(""),
            observabilityRows,
            logSourceRows,
          },
        });
        if (failedSources.length) {
          const summary = failedSources.map(([name, msg]) => `${name}: ${msg}`).join(" | ");
          status.textContent = `Partial update ${new Date().toISOString()} (${failedSources.length} source error${failedSources.length === 1 ? "" : "s"}): ${summary}`;
        } else {
          status.textContent = `Updated ${new Date().toISOString()}`;
        }
        applySearch();
      } catch (error) {
        showLoadError(error && error.message ? error.message : String(error || "request failed"));
      } finally {
        dashboardRefreshInFlight = false;
        if (refreshBtn) refreshBtn.disabled = false;
      }
    }
    async function downloadDiagnosticsData() {
      const status = document.getElementById("statusText");
      status.textContent = "Building diagnostics bundle...";
      try {
        const payload = await authJson("/api/coord/diagnostics/download?events_limit=1200&logs_limit=600&workflow_limit=4000");
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
        const ts = new Date().toISOString().replace(/[:.]/g, "-");
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.download = `nightmare-diagnostics-${ts}.json`;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(link.href);
        status.textContent = `Diagnostics download ready (${ts}).`;
      } catch (error) {
        showLoadError(error && error.message ? error.message : String(error || "diagnostics download failed"));
      }
    }
    const debouncedSearch = debounce(applySearch, 120);
    document.getElementById("globalSearch").addEventListener("input", debouncedSearch);
    document.getElementById("clearSearchBtn").addEventListener("click", () => {
      const input = document.getElementById("globalSearch");
      if (input) input.value = "";
      applySearch();
      input && input.focus();
    });
    document.getElementById("refreshBtn").addEventListener("click", () => refreshDashboard());
    document.getElementById("downloadDiagnosticsBtn").addEventListener("click", downloadDiagnosticsData);
    document.getElementById("toggleAutoRefreshBtn").addEventListener("click", (event) => {
      event.preventDefault();
      setAutoRefreshPaused(!dashboardAutoRefreshPaused);
    });
    {
      const cacheStartedAt = performance.now();
      const hadCache = _applyCachedDashboardSnapshot();
      const cacheDuration = performance.now() - cacheStartedAt;
      const snapshot = _safeReadDashboardCache();
      const ageMs = snapshot && snapshot.created_at_ms ? (Date.now() - Number(snapshot.created_at_ms || 0)) : 0;
      setCacheTiming(cacheDuration, hadCache ? ageMs : 0);
    }
    refreshDashboard();
    dashboardAutoRefreshTimer = setInterval(() => {
      if (!dashboardAutoRefreshPaused) refreshDashboard({ silent: true });
    }, 10000);
    subscribeToEventStream();
  </script>
</body>
</html>
